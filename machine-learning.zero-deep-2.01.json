{"version":3,"kind":"Notebook","sha256":"be258f2a3ca2aeeb2cc8ecd5debe2a10b9b324ed5d7a53c479dc0f7c2ccbfe52","slug":"machine-learning.zero-deep-2.01","location":"/machine_learning/zero-deep-2/01.ipynb","dependencies":[],"frontmatter":{"title":"01","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":2}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/zero-deep-2/01.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/zero-deep-2/01.ipynb","exports":[{"format":"ipynb","filename":"01.ipynb","url":"/notes/build/01-be6c87a468bf96ec10209343e99f4dc4.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Feed-Forward-Neural Network","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"tnUO0oiVvR"}],"key":"CpzWMnZ2JK"}],"key":"CvqaxkozBH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# coding: utf-8\nimport numpy as np\n\n\nclass Sigmoid:\n    def __init__(self):\n        self.params = []\n\n    def forward(self, x):\n        return 1 / (1 + np.exp(-x))\n\n\nclass Affine:\n    \"\"\"全結合層\"\"\"\n    def __init__(self, W, b):\n        self.params = [W, b]\n\n    def forward(self, x):\n        W, b = self.params\n        out = np.dot(x, W) + b\n        return out\n\n\nclass TwoLayerNet:\n    def __init__(self, input_size, hidden_size, output_size):\n        I, H, O = input_size, hidden_size, output_size\n\n        # 重みとバイアスの初期化\n        W1 = np.random.randn(I, H)\n        b1 = np.random.randn(H)\n        W2 = np.random.randn(H, O)\n        b2 = np.random.randn(O)\n\n        # レイヤの生成\n        self.layers = [\n            Affine(W1, b1),\n            Sigmoid(),\n            Affine(W2, b2)\n        ]\n\n        # すべての重みをリストにまとめる\n        self.params = []\n        for layer in self.layers:\n            self.params += layer.params\n\n    def predict(self, x):\n        for layer in self.layers:\n            x = layer.forward(x)\n        return x\n\n\nx = np.random.randn(10, 2)\nmodel = TwoLayerNet(2, 4, 3)\ns = model.predict(x)\nprint(s)\n","key":"AbJbA9XmcS"},{"type":"outputs","id":"SEI9l5T97IfxvcB5Q5SwJ","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[[ 1.40663229 -0.85494722  1.16443209]\n [ 1.99868227 -2.67328285  1.12598685]\n [ 1.48731375 -1.01911847  1.21029006]\n [ 1.15213398 -1.55998636  0.54425216]\n [ 2.03657236 -2.36520637  1.31864512]\n [ 2.23340046 -3.08404013  1.24597028]\n [ 1.49560536 -1.37479342  1.08182005]\n [ 1.23958604 -1.19529964  0.81686411]\n [ 2.38592354 -3.06367859  1.44795461]\n [ 1.70561659 -2.92434904  0.63195006]]\n"},"children":[],"key":"YXl06oimLI"}],"key":"gYJydEylLn"}],"key":"Oz13cRWUyS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"逆伝播","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wiXhn2NfbS"}],"identifier":"id","label":"逆伝播","html_id":"id","implicit":true,"key":"UNpWw2Kzw9"},{"type":"heading","depth":3,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"MatMul（行列積）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gbpQD5kqaf"}],"identifier":"matmul","label":"MatMul（行列積）","html_id":"matmul","implicit":true,"key":"oRQmzALD8T"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":