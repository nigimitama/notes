/span></span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2861em;\"><span></span></span></span></span></span></span></span></span></span>","key":"I9rLvMSQsv"},{"type":"text","value":"の平均を集計","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"cVdnkWl1ou"}],"key":"SikxI83Kyx"}],"key":"cJCr77EUr1"}],"key":"hjfQDTPJLV"}],"key":"hN6rZFNEmD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from lightgbm import LGBMRegressor\nfrom sklearn.model_selection import KFold\n\ndef dml1(Y, D, X):\n    kf = KFold(n_splits=5)\n    kf.get_n_splits(X)\n    thetas = []\n    for i, (train_idx, test_idx) in enumerate(kf.split(X)):\n        # 局外関数の推定\n        m = LGBMRegressor(verbose=-1).fit(X[train_idx], D[train_idx])\n        l = LGBMRegressor(verbose=-1).fit(X[train_idx], Y[train_idx])\n        # 残差の計算\n        V_hat = D[test_idx] - m.predict(X[test_idx])\n        Y_res = Y[test_idx] - l.predict(X[test_idx])\n        # θの推定\n        theta_hat = np.mean(V_hat * V_hat) ** (-1) * np.mean(V_hat * Y_res)\n        thetas.append(theta_hat)\n    return np.mean(thetas)\n\ndml1(Y, D, X)","key":"dqqz8xqWLs"},{"type":"outputs","id":"cl33tBM-cwG76slM0XNlK","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":31,"metadata":{},"data":{"text/plain":{"content":"4.996210951148309","content_type":"text/plain"}}},"children":[],"key":"v8ShkLg3kc"}],"key":"pfuYrg45mR"}],"key":"tm6o8Irz4J"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"DML","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DdkZhJy9PX"}],"identifier":"dml","label":"DML","html_id":"dml","implicit":true,"key":"f0kN2PiIuU"}],"key":"FfYP9vp5Sx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\ntheta = 5\nn_rep = 1000\nestimation_errors = []\nfor i_rep in range(n_rep):\n    Y, D, X = gen_data(seed=i_rep, theta=theta)\n    theta_hat = dml1(Y, D, X)\n    estimation_error = theta - theta_hat\n    estimation_errors.append(estimation_error)\n\nimport matplotlib.pyplot as plt\nfig, ax = plt.subplots()\nax.hist(estimation_errors, bins=30)\nax.set(xlabel=r\"$\\theta - \\hat{\\theta}$\", title=\"Estimation Error\")\n\nmean_error = np.mean(estimation_errors)\nax.axvline(mean_error, color=\"darkblue\")\nax.text(mean_error, 10, f\" mean={mean_error:.2g}\")\n\nfig.show()","key":"WasrPWXqMB"},{"type":"outputs","id":"Tn_hZYyILXOdzcu8D-Swp","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"CPU times: user 18min 22s, sys: 8.91 s, total: 18min 31s\nWall time: 2min 20s\n"},"children":[],"key":"E4IHW0Okop"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"3245246707160e0c6f9468b9a61d1b85","path":"/notes/build/3245246707160e0c6f9468b9a61d1b85.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"cLjVQ664By"}],"key":"X83zvnFmha"}],"key":"JtblCHCnMu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"もしCross Fittingがなければ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OvQYkNWXZH"}],"identifier":"id-cross-fitting","label":"もしCross Fittingがなければ","html_id":"id-cross-fitting","implicit":true,"key":"j6qdaxL1ul"}],"key":"wIJrd8pc8n"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def estimate_without_cross_fitting(Y, D, X):\n    # 局外関数の推定\n    m = LGBMRegressor(max_depth=4, verbose=-1).fit(X, D)\n    l = LGBMRegressor(max_depth=4, verbose=-1).fit(X, Y)\n    # 残差の計算\n    V_hat = D - m.predict(X)\n    Y_res = Y - l.predict(X)\n    # θの推定\n    theta_hat = np.mean(V_hat * V_hat) ** (-1) * np.mean(V_hat * Y_res)\n    return theta_hat\n\nestimate_without_cross_fitting(Y, D, X)","key":"b8DE92vmJy"},{"type":"outputs","id":"qp_8XNf6TGzOFfZlNl1aY","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":33,"metadata":{},"data":{"text/plain":{"content":"4.8689337039631475","content_type":"text/plain"}}},"children":[],"key":"wEFGbE2Gaa"}],"key":"Wj45hurdC4"}],"key":"rIMck76FQi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\nn_rep = 1000\nestimation_errors = []\nfor i_rep in range(n_rep):\n    Y, D, X = gen_data(seed=i_rep, theta=theta)\n    theta_hat = estimate_without_cross_fitting(Y, D, X)\n    estimation_error = theta - theta_hat\n    estimation_errors.append(estimation_error)\n\nimport matplotlib.pyplot as plt\nfig, ax = plt.subplots()\nax.hist(estimation_errors, bins=30)\nax.set(xlabel=r\"$\\theta - \\hat{\\theta}$\", title=\"Estimation Error (without splitting)\")\n\nmean_error = np.mean(estimation_errors)\nax.axvline(mean_error, color=\"darkblue\")\nax.text(mean_error, 10, f\" mean={mean_error:.2g}\")\n\nfig.show()","key":"RusIDdLX2b"},{"type":"outputs","id":"fxc6HJMCDZKQGnJNlLbe8","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"CPU times: user 2min 39s, sys: 868 ms, total: 2min 40s\nWall time: 20.3 s\n"},"children":[],"key":"LyJEGjqD8j"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"5b93be7bab656f59e68d163efcdf286f","path":"/notes/build/5b93be7bab656f59e68d163efcdf286f.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"DsnGOeEVxC"}],"key":"NQiDLQlpjE"