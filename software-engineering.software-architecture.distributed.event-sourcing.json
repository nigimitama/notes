lance = 0\n        self.events = []\n    \n    def deposit(self, amount):\n        event = {\n            \"type\": \"MoneyDeposited\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def withdraw(self, amount):\n        event = {\n            \"type\": \"MoneyWithdrawn\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def _apply_event(self, event):\n        if event[\"type\"] == \"MoneyDeposited\":\n            self.balance += event[\"amount\"]\n        elif event[\"type\"] == \"MoneyWithdrawn\":\n            self.balance -= event[\"amount\"]\n    \n    def rebuild_from_events(self, events):\n        for event in events:\n            self._apply_event(event)","position":{"start":{"line":6,"column":1},"end":{"line":40,"column":1}},"key":"LXKoz8dsHv"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"inlineCode","value":"BankAccount","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"iL77WYQsSl"},{"type":"text","value":" の ","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"YX2sFTEXqT"},{"type":"inlineCode","value":"balance","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"KYrq82ey9g"},{"type":"text","value":" は保存されるデータではなく、","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"mzq2lv3hLo"},{"type":"inlineCode","value":"events","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"hsek1UYdSZ"},{"type":"text","value":" を先頭から適用した結果として導出される値になる。","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"meTJSJG4fj"}],"key":"E0PIaqV2Ee"}],"key":"XQjmuilw4B"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"スナップショット","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GLiRXMh3x1"}],"identifier":"id","label":"スナップショット","html_id":"id-1","implicit":true,"key":"urJ5adGrIM"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"イベント数が多くなると、毎回全イベントを再生するコストが無視できなくなる。そこで一定間隔（例：100イベントごと）で\n現在の状態を","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IYbf1D5fUd"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"スナップショット","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"hwhVA7LInb"}],"key":"QhBSHEyIXj"},{"type":"text","value":"として保存し、復元時は「直近のスナップショット＋それ以降のイベント」だけを再生する。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gNnn3jKy50"}],"key":"LAXXGZqwZ7"},{"type":"code","lang":"python","value":"class BankAccountWithSnapshot(BankAccount):\n    def to_snapshot(self):\n        return {\"account_id\": self.account_id, \"balance\": self.balance, \"version\": len(self.events)}\n\n    @classmethod\n    def from_snapshot(cls, snapshot, events_after_snapshot):\n        account = cls(snapshot[\"account_id\"])\n        account.balance = snapshot[\"balance\"]\n        for event in events_after_snapshot:\n            account._apply_event(event)\n        return account","position":{"start":{"line":6,"column":1},"end":{"line":18,"column":1}},"key":"ynXBRvnuCh"}],"key":"Zq4h1htd7M"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"プロジェクション（Projection）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MNk3sZxp5U"}],"identifier":"id-projection","labe