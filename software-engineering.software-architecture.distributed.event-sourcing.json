lance = 0\n        self.events = []\n    \n    def deposit(self, amount):\n        event = {\n            \"type\": \"MoneyDeposited\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def withdraw(self, amount):\n        event = {\n            \"type\": \"MoneyWithdrawn\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def _apply_event(self, event):\n        if event[\"type\"] == \"MoneyDeposited\":\n            self.balance += event[\"amount\"]\n        elif event[\"type\"] == \"MoneyWithdrawn\":\n            self.balance -= event[\"amount\"]\n    \n    def rebuild_from_events(self, events):\n        for event in events:\n            self._apply_event(event)","position":{"start":{"line":6,"column":1},"end":{"line":40,"column":1}},"key":"RDjf5grGGD"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"inlineCode","value":"BankAccount","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"PXO0iAVUVl"},{"type":"text","value":" の ","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"QVm7HYABgh"},{"type":"inlineCode","value":"balance","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"lD2xkOX6EL"},{"type":"text","value":" は保存されるデータではなく、","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"O6uCHVZL6v"},{"type":"inlineCode","value":"events","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"iD9x7r9ySl"},{"type":"text","value":" を先頭から適用した結果として導出される値になる。","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"MyjO9Xtof1"}],"key":"zeO710qp4H"}],"key":"s6yZ5sR5Ki"},{"type":"block","kind":"notebook-content","children":[