lance = 0\n        self.events = []\n    \n    def deposit(self, amount):\n        event = {\n            \"type\": \"MoneyDeposited\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def withdraw(self, amount):\n        event = {\n            \"type\": \"MoneyWithdrawn\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def _apply_event(self, event):\n        if event[\"type\"] == \"MoneyDeposited\":\n            self.balance += event[\"amount\"]\n        elif event[\"type\"] == \"MoneyWithdrawn\":\n            self.balance -= event[\"amount\"]\n    \n    def rebuild_from_events(self, events):\n        for event in events:\n            self._apply_event(event)","position":{"start":{"line":6,"column":1},"end":{"line":40,"column":1}},"key":"kfEI1okmvn"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"inlineCode","value":"BankAccount","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"q7iIsns5SA"},{"type":"text","value":" の ","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"B1m1GHYQyz"},{"type":"inlineCode","value":"balance","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"nAwmVfmiMU"},{"type":"text","value":" は保存されるデータではなく、","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"xooZAJz1c9"},{"type":"inlineCode","value":"events","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"mPcdUGcKBm"},{"type":"text","value":" を先頭から適用した結果として導出される値になる。","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"HoRwXc5kw7"}],"key":"L3q4G7Wi1N"}],"key":"VbMFjuHmgB"},{"type":"block","kind":"notebook-content","children":[