ode","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nker = np.array([\n    [2, 0, 1],\n    [0, 1, 2],\n    [1, 0, 2],\n])\n\nH, W = img.shape\nK = ker.shape[0]\n\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"ABa9mRrP6n"},{"type":"outputs","id":"la-ul-p-FgL3_exgmsDE0","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":33,"metadata":{},"data":{"text/plain":{"content":"array([[15., 16.],\n       [ 6., 15.]])","content_type":"text/plain"}}},"children":[],"key":"N3MatH74lP"}],"key":"H1256wGg1X"}],"key":"M1WhTdZjew"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"パディング","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yO11o0rxLM"}],"identifier":"id","label":"パディング","html_id":"id-3","implicit":true,"key":"Xnc50jjSf3"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"畳み込みを行う際に、入力データの周囲に固定のデータ（例えば0など）を埋めることがある。これを ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pAWhFh0TC7"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"パディング（padding）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"rvQxNkeahh"}],"key":"TYYGdPU49K"},{"type":"text","value":" という。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"x9Nz1UqZob"}],"key":"pEw6OusUWG"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"パディングにより畳み込み後の行列のサイズを調整できる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"CZBw38Bwv2"}],"key":"MRSQm3ZB6q"}],"key":"yF7xMAkvUJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# padding\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nH, W = img.shape\nimg_pad = np.zeros((H+2, W+2))\nimg_pad[1:-1, 1:-1] = img\nimg_pad","key":"UiYUdXPcK2"},{"type":"outputs","id":"193WPVhU22rSzlZHmUczL","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":41,"metadata":{},"data":{"text/plain":{"content":"array([[0., 0., 0., 0., 0., 0.],\n       [0., 1., 2., 3., 0., 0.],\n       [0., 0., 1., 2., 3., 0.],\n       [0., 3., 0., 1., 2., 0.],\n       [0., 2., 3., 0., 1., 0.],\n       [0., 0., 0., 0., 0., 0.]])","content_type":"text/plain"}}},"children":[],"key":"oSBbOFSIvx"}],"key":"ezUhNjL7nP"}],"key":"IJmigBjvXx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 畳み込み後も 4 x 4 を維持\nimg = img_pad\nH, W = img.shape\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"M7VgrxXNyl"},{"type":"outputs","id":"pIyRTCRRWzWnTOE2oshyg","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":45,"metadata":{},"data":{"text/plain":{"content":"array([[ 7., 12., 10.,  2.],\n       [ 4., 15., 16., 10.],\n       [10.,  6., 15.,  6.],\n       [ 8., 10.,  4.,  3.]])","content_type":"text/plain"}}},"children":[],"key":"H2aZHCW3IA"}],"key":"LCebEl09fb"}],"key":"jmxNhdSgba"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"プーリング層","position":{"start":{"line":1,"column"