GRHli"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"strong","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"畳み込み（convolution）層","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"UGO6suPdJG"}],"key":"d3dxj65TxC"},{"type":"text","value":" は形状を維持する","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"RRyyosAoss"}],"key":"pbvT6vVQjI"}],"key":"aM9gvkECiX"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"s1DPujS2pp"}],"identifier":"id","label":"計算","html_id":"id-1","implicit":true,"key":"ZEVNkJJBGq"}],"key":"BliTAfl44g"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"畳み込み層","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Mf5iwABEC1"}],"identifier":"id","label":"畳み込み層","html_id":"id-2","implicit":true,"key":"oNFTDmJuLf"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"チャネルごとに、","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fCw5mXsEgv"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"カーネル（フィルター）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Y83o7ggM7H"}],"key":"ZPHJVYZQDc"},{"type":"text","value":" と呼ばれる行列を画像の行列と要素ごとに積をとり、総和をとる","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dyxhEyJ76p"}],"key":"CVMr1UVnVX"}],"key":"Uujt00TxJy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nker = np.array([\n    [2, 0, 1],\n    [0, 1, 2],\n    [1, 0, 2],\n])\n\nH, W = img.shape\nK = ker.shape[0]\n\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"ndlSv3QB1I"},{"type":"outputs","id":"ptFq96h0na_17qWom9PXw","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":33,"metadata":{},"data":{"text/plain":{"content":"array([[15., 16.],\n       [ 6., 15.]])","content_type":"text/plain"}}},"children":[],"key":"Hs5qK4e5BJ"}],"key":"XQqICJYHNf"}],"key":"hsp5Qyr7t2"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"パディング","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"UMEqaYUJqx"}],"identifier":"id","label":"パディング","html_id":"id-3","implicit":true,"key":"zl0iXLxYli"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"畳み込みを行う際に、入力データの周囲に固定のデータ（例えば0など）を埋めることがある。これを ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"SrbROylmxA"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"パディング（padding）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Fj0bCyT7hR"}],"key":"zOyGNzbgz2"},{"type":"text","value":" という。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Q3tVCwffwk"}],"key":"XaoGk2sgRc"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"パディングにより畳み込み後の行列のサイズを調整できる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"ZM7rIhr4YJ"}],"key":"joILMTw4lF"}],"key":"tor4P8xBWr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# padding\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nH, W = img.shape\nimg_pad = np.zeros((H+2, W+2))\nimg_pad[1:-1, 1:-1] = img\nimg_pad","key":"FoaVuymmXG"},{"type":"outputs","id":"Q17hl5nTCdvh_TfW1xI4H","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":41,"metadata":{},"data":{"text/plain":{"content":"array([[0., 0., 0., 0., 0., 0.],\n       [0., 1., 2., 3., 0., 0.],\n       [0., 0., 1., 2., 3., 0.],\n       [0., 3., 0., 1., 2., 0.],\n       [0., 2., 3., 0., 1., 0.],\n       [0., 0., 0., 0., 0., 0.]])","content_type":"text/plain"}}},"children":[],"key":"nVclwD02Lz"}],"key":"CPOkpF9sYs"}],"key":"C9rTWKsrDP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 畳み込み後も 4 x 4 を維持\nimg = img_pad\nH, W = img.shape\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"un9rkQkC0a"},{"type":"outputs","id":"3eKF9msjxKQMjJdhG80d_","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":45,"metadata":{},"data":{"text/plain":{"content":"array([[ 7., 12., 10.,  2.],\n       [ 4., 15., 16., 10.],\n       [10.,  6., 15.,  6.],\n       [ 8., 10.,  4.,  3.]])","content_type":"text/plain"}}},"children":[],"key":"pQHkMaqFJj"}],"key":"BSgbFkhPcg"}],"key":"McYezvQUZq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"プーリング層","position":{"start":{"line":1,"column"