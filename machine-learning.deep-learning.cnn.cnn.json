ode","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nker = np.array([\n    [2, 0, 1],\n    [0, 1, 2],\n    [1, 0, 2],\n])\n\nH, W = img.shape\nK = ker.shape[0]\n\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"kVZNNl7Ope"},{"type":"outputs","id":"039xwJXeAkziRTdICg4iQ","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":33,"metadata":{},"data":{"text/plain":{"content":"array([[15., 16.],\n       [ 6., 15.]])","content_type":"text/plain"}}},"children":[],"key":"IOn8CHB8U3"}],"key":"LAdHNO4Om7"}],"key":"wrEI8EgO5I"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"パディング","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IouYxW5zDR"}],"identifier":"id","label":"パディング","html_id":"id-3","implicit":true,"key":"ElKq6irT3l"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"畳み込みを行う際に、入力データの周囲に固定のデータ（例えば0など）を埋めることがある。これを ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"B6fhcSP23Z"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"パディング（padding）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fhRprQlQui"}],"key":"RRyQyOJeXZ"},{"type":"text","value":" という。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"OngJxv6aBR"}],"key":"XeueDsNFHZ"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"パディングにより畳み込み後の行列のサイズを調整できる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"c8fZJiuHqW"}],"key":"viQBpi5LZ6"}],"key":"UcqoedH5kI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# padding\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nH, W = img.shape\nimg_pad = np.zeros((H+2, W+2))\nimg_pad[1:-1, 1:-1] = img\nimg_pad","key":"Ur9fIcNd1x"},{"type":"outputs","id":"4eygJh78lDwOXK1iOqMrG","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":41,"metadata":{},"data":{"text/plain":{"content":"array([[0., 0., 0., 0., 0., 0.],\n       [0., 1., 2., 3., 0., 0.],\n       [0., 0., 1., 2., 3., 0.],\n       [0., 3., 0., 1., 2., 0.],\n       [0., 2., 3., 0., 1., 0.],\n       [0., 0., 0., 0., 0., 0.]])","content_type":"text/plain"}}},"children":[],"key":"NWZ0LjGubp"}],"key":"Is5kxMl4Rv"}],"key":"nMPwAKO81c"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 畳み込み後も 4 x 4 を維持\nimg = img_pad\nH, W = img.shape\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"CwyKSVm8MT"},{"type":"outputs","id":"k5qWTpJb_cEHQIiRtqR7h","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":45,"metadata":{},"data":{"text/plain":{"content":"array([[ 7., 12., 10.,  2.],\n       [ 4., 15., 16., 10.],\n       [10.,  6., 15.,  6.],\n       [ 8., 10.,  4.,  3.]])","content_type":"text/plain"}}},"children":[],"key":"jOHPlmVmEC"}],"key":"rIYhl9DGOq"}],"key":"w7qpyHCDcw"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"プーリング層","position":{"start":{"line":1,"column"