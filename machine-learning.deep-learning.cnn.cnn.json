ode","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nker = np.array([\n    [2, 0, 1],\n    [0, 1, 2],\n    [1, 0, 2],\n])\n\nH, W = img.shape\nK = ker.shape[0]\n\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"UxDhhBoeKl"},{"type":"outputs","id":"Zq7_Rn5SzFGfpOSk4HeTe","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":33,"metadata":{},"data":{"text/plain":{"content":"array([[15., 16.],\n       [ 6., 15.]])","content_type":"text/plain"}}},"children":[],"key":"BlrcljXbT0"}],"key":"DZ4dkRTpGk"}],"key":"kqc50qYazd"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"パディング","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Tppux9IMJM"}],"identifier":"id","label":"パディング","html_id":"id-3","implicit":true,"key":"TR8hVfq9dt"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"畳み込みを行う際に、入力データの周囲に固定のデータ（例えば0など）を埋めることがある。これを ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ftBzPPBY4j"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"パディング（padding）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"SgAaWoqkUc"}],"key":"zgHychV65p"},{"type":"text","value":" という。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"PH4XJOeMgU"}],"key":"EYcVxOAKP1"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"パディングにより畳み込み後の行列のサイズを調整できる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"KBfxYOdewH"}],"key":"OApvqq0aia"}],"key":"RALDCwVZnU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# padding\nimg = np.array([\n    [1, 2, 3, 0],\n    [0, 1, 2, 3],\n    [3, 0, 1, 2],\n    [2, 3, 0, 1],\n])\n\nH, W = img.shape\nimg_pad = np.zeros((H+2, W+2))\nimg_pad[1:-1, 1:-1] = img\nimg_pad","key":"StMtem6K0S"},{"type":"outputs","id":"QNfImNcwAeIkh8Nz2qFO9","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":41,"metadata":{},"data":{"text/plain":{"content":"array([[0., 0., 0., 0., 0., 0.],\n       [0., 1., 2., 3., 0., 0.],\n       [0., 0., 1., 2., 3., 0.],\n       [0., 3., 0., 1., 2., 0.],\n       [0., 2., 3., 0., 1., 0.],\n       [0., 0., 0., 0., 0., 0.]])","content_type":"text/plain"}}},"children":[],"key":"KsSCbxLqUg"}],"key":"dhtsKEaFyJ"}],"key":"CdvqUARqN8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 畳み込み後も 4 x 4 を維持\nimg = img_pad\nH, W = img.shape\nconv = np.zeros((H - K + 1, W - K + 1))\nfor i in range(H - K + 1):\n    for j in range(W - K + 1):\n        conv[i, j] = (img[i:i+K, j:j+K] * ker).sum()\nconv","key":"O20AS8Zxmt"},{"type":"outputs","id":"mvRIwV8ogsbIqlvWNIgTX","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":45,"metadata":{},"data":{"text/plain":{"content":"array([[ 7., 12., 10.,  2.],\n       [ 4., 15., 16., 10.],\n       [10.,  6., 15.,  6.],\n       [ 8., 10.,  4.,  3.]])","content_type":"text/plain"}}},"children":[],"key":"ER5ROG0ktk"}],"key":"Y4KZM8JeNW"}],"key":"bPE9bg25MK"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"プーリング層","position":{"start":{"line":1,"column"