ensemble.IsolationForest.html","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"IsolationForest — scikit-learn documentation","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GxOpGNVCRU"}],"urlSource":"https://scikit-learn.org/stable/modules/generated/sklearn.ensemble.IsolationForest.html","key":"Fbz37FbE28"}],"key":"B3KFq7V9L5"}],"key":"X7P35SX7XG"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.ensemble import IsolationForest\nimport numpy as np\nimport matplotlib.pyplot as plt\n\n# データ生成（正常点と異常点）\nrng = np.random.RandomState(42)\nX_normal = 0.3 * rng.randn(100, 2)\nX_normal = np.r_[X_normal + 2, X_normal - 2]\nX_outliers = rng.uniform(low=-4, high=4, size=(20, 2))\nX = np.r_[X_normal, X_outliers]\n\n# モデル構築\nclf = IsolationForest(contamination=0.1, random_state=42)\nclf.fit(X)\n\n# 予測とスコア\ny_pred = clf.predict(X)\nscores = clf.decision_function(X)\n\n# 可視化\nplt.figure(figsize=(8, 6))\nplt.scatter(X[:, 0], X[:, 1], c=y_pred, cmap='coolwarm', s=20)\nplt.title(\"Isolation Forest: Normal vs Anomaly\")\nplt.xlabel(\"Feature 1\")\nplt.ylabel(\"Feature 2\")\nplt.colorbar(label=\"Prediction (+1: normal, -1: anomaly)\")\nplt.grid(True)\nplt.show()","visibility":"show","key":"YXcLAggSRP"},{"type":"outputs","id":"ODD3-CWXAicvmOrx7KiiU","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"b638eda66113969e3b91de65828cfd28","path":"/notes/build/b638eda66113969e3b91de65828cfd28.png"},"text/plain":{"content":"<Figure size 800x600 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"wMK8XiAPkS"}],"visibility":"show","key":"eUj5GbpQTS"}],"visibility":"show","key":"Fe35vQKDS5"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"e