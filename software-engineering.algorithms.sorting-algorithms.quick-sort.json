}},"children":[{"type":"strong","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Hoare分割法","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"myTZ2G0xGY"}],"key":"RtOFloj4Un"},{"type":"text","value":": 両端から走査。実際には交換回数が少なく速い。","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ZWMHaHRj0u"}],"key":"wnngCtsRU4"}],"key":"cDhPkZ9NQL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def quick_sort(arr: list) -> list:\n    \"\"\"シンプルな実装（Lomuto 分割、新規リスト版）\"\"\"\n    if len(arr) <= 1:\n        return arr\n    pivot = arr[len(arr) // 2]  # 中央値をピボットに\n    left  = [x for x in arr if x < pivot]\n    mid   = [x for x in arr if x == pivot]\n    right = [x for x in arr if x > pivot]\n    return quick_sort(left) + mid + quick_sort(right)","key":"LBAX9lCaFG"},{"type":"outputs","id":"7QwO70c8d3klR11WC8wB0","children":[],"key":"lCTY77eRoH"}],"key":"t9AG2mBseV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import random\n\ndata = [10, 7, 8, 9, 1, 5]\nprint(\"入力:\", data)\nprint(\"出力:\", quick_sort(data))\n\nrandom.seed(3)\nlarge = random.sample(range(10000), 100)\nassert quick_sort(large) == sorted(large)\nprint(\"ランダム100件: OK\")","key":"eO1TJ4edHX"},{"type":"outputs","id":"ZYTp-uQz_u9TvRbcIqnYJ","children":[],"key":"MrPl0jBACH"}],"key":"xbQHhEbt7t"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"in-place 実装（Lomuto 分割法）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"X5kwUGOOKa"}],"identifier":"in-place-lomuto","label":"in-place 実装（Lomuto 分割法）","html_id":"in-place-lomuto","implicit":true,"key":"j3BeDEaD3p"}],"key":"K1AFFWu5Ai"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def quick_sort_inplace(arr: list) -> list:\n    a = arr.copy()\n    _qs(a, 0, len(a) - 1)\n    return a\n\ndef _qs(a: list, lo: int, hi: int) -> None:\n    if lo >= hi:\n        return\n    p = _partition(a, lo, hi)\n    _qs(a, lo, p - 1)\n    _qs(a, p + 1, hi)\n\ndef _partition(a: list, lo: int, hi: int) -> int:\n    # 末尾・先頭・中央の中央値をピボットに（median-of-3）\n    mid = (lo + hi) // 2\n    candidates = [(a[lo], lo), (a[mid], mid), (a[hi], hi)]\n    candidates.sort()\n    _, pivot_idx = candidates[1]\n    a[pivot_idx], a[hi] = a[hi], a[pivot_idx]\n    pivot = a[hi]\n\n    i = lo - 1\n    for j in range(lo, hi):\n        if a[j] <= pivot:\n            i += 1\n            a[i], a[j] = a[j], a[i]\n    a[i + 1], a[hi] = a[hi], a[i + 1]\n    return i + 1\n\ndata = [10, 7, 8, 9, 1, 5]\nprint(quick_sort_inplace(data))\nassert quick_sort_inplace(data) == sorted(data)","key":"LqjeVn6nCS"},{"type":"outputs","id":"Pw0xCISTDX27-8e0tfZL-","children":[],"key":"SAiqNxO48x"}],"key":"m5hEwGsjnv"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"最悪ケース（ナイーブ実装での注意）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HXG59WdDaK"}],"identifier":"id","label":"最悪ケース（ナイーブ実装での注意）","html_id":"id-1","implicit":true,"key":"jqLWoaESzp"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"常に最大・最小をピボットに選ぶと、分割が ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oSOjPVBfmd"},{"type":"inlineMath","value":"n-1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>n</mi><mo>−</mo><mn>1</mn></mrow><annotation encoding=\"application/x-tex\">n-1