"l4XGxOY43L"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import random\n\ndef quick_sort_random(arr: list) -> list:\n    \"\"\"ランダムピボットによるクイックソート\"\"\"\n    if len(arr) <= 1:\n        return arr\n    pivot = random.choice(arr)\n    left  = [x for x in arr if x < pivot]\n    mid   = [x for x in arr if x == pivot]\n    right = [x for x in arr if x > pivot]\n    return quick_sort_random(left) + mid + quick_sort_random(right)\n\n# 既ソート済みデータでも高速\nsorted_data = list(range(200))\nrandom.seed(42)\nassert quick_sort_random(sorted_data) == sorted_data\nprint(\"既ソート済み200件: OK\")","key":"Wgu6F3sSyL"},{"type":"outputs","id":"Gq64UkJ9DbsRV6Jr8VTEX","children":[],"key":"nTuhICKK6v"}],"key":"dDP7eW10u9"}],"key":"TkRdzhP138"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"マージソート","url":"/software-engineering/algorithms/sorting-algorithms/merge-sort","group":"ソフトウェア工学"},"next":{"title":"ヒープソート","url":"/software-engineering/algorithms/sorting-algorithms/heap-sort","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}