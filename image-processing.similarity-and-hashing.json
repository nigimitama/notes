esize((hash_size, hash_size), ANTIALIAS)\n    # find average pixel value; 'pixels' is an array of the pixel values, ranging from 0 (black) to 255 (white)\n    pixels = np.asarray(image)\n    avg = np.mean(pixels)\n    # 平均よりおおいかどうかで0/1にする\n    is_high = pixels > avg\n    return is_high\n","key":"ixSc6vH0nY"},{"type":"outputs","id":"E_YaaI38hcCzInmV3Kkj2","children":[],"key":"gvIBzru4uz"}],"key":"pTQ3eMrDea"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"別の画像と判定","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KvhhdZoevo"}],"key":"gjbWAWRTGh"}],"key":"gtR9ZpkkIn"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"cat1 = Image.open(\"./sample_images/cat1.jpg\")\ncat2 = Image.open(\"./sample_images/cat2.jpg\")\n\nplt.figure(figsize=(8, 6))\nplt.subplot(1, 2, 1)\nplt.imshow(cat1)\nplt.title(\"cat1.jpg\")\nplt.subplot(1, 2, 2)\nplt.imshow(cat2)\nplt.title(\"cat2.jpg\")\nplt.show()","visibility":"hide","key":"KccmrGfePl"},{"type":"outputs","id":"KnGIuV-LU0uctqr9m6myf","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"051fd6ee28d07d22f4b2bca033a80c69","path":"/notes/build/051fd6ee28d07d22f4b2bca033a80c69.png"},"text/plain":{"content":"<Figure size 800x600 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"REQVCYQhgV"}],"visibility":"show","key":"r5LmEy6R60"}],"visibility":"show","key":"r8yJGMIlhg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"is_high1 = average_hash(cat1)\nis_high2 = average_hash(cat2)\n\nn_diff = np.count_nonzero(is_high1 != is_high2)\nprint(\"不一致ピクセル数 :\", n_diff)\n\nn_same = np.count_nonzero(is_high1 == is_high2)\nprint(f\"一致度 : {n_same / is_hig