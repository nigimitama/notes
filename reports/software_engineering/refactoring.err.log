# --- Before: 1つのループで2つの集計をしている ---
def summary(people):
    total_age = 0
    total_salary = 0
    for p in people:
        total_age += p.age
        total_salary += p.salary
    return total_age, total_salary


# --- After: ループを分離すると、それぞれを関数として抽出できる ---
def summary(people):
    total_age = sum(p.age for p in people)
    total_salary = sum(p.salary for p in people)
    return total_age, total_salary


