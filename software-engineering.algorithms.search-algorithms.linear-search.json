n range(N): # 全部順番にみていく\n        if arr[i] == target: # targetを発見したらindexを返す\n            return i\n    return -1 # 見つからなかった場合","key":"zlig2j61JD"},{"type":"outputs","id":"uetjeDREdI6bUjqUTovLT","children":[],"key":"uSbv6uTJA1"}],"key":"czLmAxRPIT"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"linear_search(arr=[1, 5, 3, 2, 4], target=3)","visibility":"show","key":"fAf8GVwmeV"},{"type":"outputs","id":"6ZR-J4pUJUB0y5qgX7UO6","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":23,"metadata":{},"data":{"text/plain":{"content":"2","content_type":"text/plain"}}},"children":[],"key":"HvXE6g1LFS"}],"visibility":"show","key":"wuoWf9EwSP"}],"visibility":"show","key":"ebdKM5cjDn"}],"key":"upAvrAOp6B"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"探索アルゴリズム","url":"/software-engineering/algorithms/search-algorithms","group":"ソフトウェア工学"},"next":{"title":"二分探索","url":"/software-engineering/algorithms/search-algorithms/binary-search","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}