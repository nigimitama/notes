    raise IndexError('heap is empty')\n        self._swap(0, len(self._data) - 1)\n        value = self._data.pop()\n        self._sift_down(0)\n        return value\n\n    def _sift_up(self, i):\n        while i > 0:\n            parent = (i - 1) // 2\n            if self._data[i] < self._data[parent]:\n                self._swap(i, parent)\n                i = parent\n            else:\n                break\n\n    def _sift_down(self, i):\n        n = len(self._data)\n        while True:\n            smallest = i\n            left, right = 2 * i + 1, 2 * i + 2\n            if left < n and self._data[left] < self._data[smallest]:\n                smallest = left\n            if right < n and self._data[right] < self._data[smallest]:\n                smallest = right\n            if smallest == i:\n                break\n            self._swap(i, smallest)\n            i = smallest\n\n    def _swap(self, i, j):\n        self._data[i], self._data[j] = self._data[j], self._data[i]","key":"OWlmpnrznY"},{"type":"outputs","id":"JGhUvgQFJ-W_ATvpBlVN2","children":[],"key":"hPhNEaLlHk"}],"key":"leMlDzCrCA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"heap = MinHeap()\nfor x in [5, 3, 8, 1, 4]:\n    heap.push(x)\n\nprint('peek:', heap.peek())       # 1\nprint('pop:', heap.pop())         # 1\nprint('pop:', heap.pop())         # 3\nprint('pop:', heap.pop())         # 4\nprint('内部配列:', heap._data)","key":"lNHkm6v7h7"},{"type":"outputs","id":"ZOPbOiV4-N7yOXCHS-pwP","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"peek: 1\npop: 1\npop: 3\npop: 4\n内部配列: [5, 8]\n"},"children":[],"key":"YxBhNfsIaX"}],"key":"KG38rRMYN7"}],"key":"V1xDG9VUmX"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"heapify — ","position":{"start":{"line":1,"column"