:"HcwIGQYJh1"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"空間計算量: ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"wB46ZPuvH7"},{"type":"inlineMath","value":"O(1)","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mn>1</mn><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(1)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord\">1</span><span class=\"mclose\">)</span></span></span></span>","key":"X5qqEddUeo"},{"type":"text","value":"（in-place）","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"yjkKsMI3MQ"}],"key":"xcj0cBBb8Q"}],"key":"qJmfHIDA7g"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"安定ソートではない","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"AD4DSID65j"}],"key":"I3wTLkbc9d"}],"key":"HIEYwqlA1i"}],"key":"xYDaOnfdNe"}],"key":"E86R4UhS0z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def heap_sort(arr):\n    n = len(arr)\n\n    def sift_down(i, end):\n        while True:\n            largest = i\n            left, right = 2 * i + 1, 2 * i + 2\n            if left < end and arr[left] > arr[largest]:\n                largest = left\n            if right < end and arr[right] > arr[largest]:\n                largest = right\n            if largest == i:\n                break\n            arr[i], arr[largest] = arr[largest], arr[i]\n            i = largest\n\n    # 最大ヒープを構築\n    for i in range((n - 2) // 2, -1, -1):\n        sift_down(i, n)\n\n    # 根（最大値）を末尾と交換しながらソート\n    for end in range(n - 1, 0, -1):\n        arr[0], arr[end] = arr[end], arr[0]\n        sift_down(0, end)\n\n    return arr\n\n\ndata = [5, 3, 8, 1, 4, 2, 7]\nprint(heap_sort(data))","key":"HUsN0G8ZAc"},{"type":"outputs","id":"NN1mWAcY5SpatktnzApYq","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[1, 2, 3, 4, 5, 7, 8]\n"},"children":[],"key":"fNQr6hdabL"}],"key":"e3flh7Equw"}],"key":"RMA6TAEPe6"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"活用例","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"P6dltGCfQ8"}],"identifier":"id","label":"活用例","html_id":"id-3","implicit":true,"key":"d1XTwm6aFN"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"優先度付きキュー","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"hd3ENRRi6Z"}],"key":"b5groQmLsR"},{"type":"text","value":": タスクスケジューリング、イベント駆動シミュレーション","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"aFJfZeOJM7"}],"key":"vZUZjN8AH4"}],"key":"z3w3FM8XUv"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":4,"colum