en=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"rKADBekpYR"},{"type":"text","value":" でヒープを構築できる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"TbP3DMYlBY"}],"key":"njPRq7loyT"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"要素を1つずつ ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"qS4inEI9tH"},{"type":"inlineCode","value":"push","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"zM1RuZMtNE"},{"type":"text","value":" する ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"nH4m9qzbol"},{"type":"inlineMath","value":"O(n \\log n)","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>n</mi><mi>log</mi><mo>⁡</mo><mi>n</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(n \\log n)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mop\">lo<span style=\"margin-right:0.01389em;\">g</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"E2fYLG9hJk"},{"type":"text","value":" より効率的。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"R5wwxutAlm"}],"key":"emPvNXGIQo"}],"key":"XGAEOUCRkN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class MinHeap(MinHeap):\n    @classmethod\n    def heapify(cls, array):\n        h = cls()\n        h._data = list(array)\n        n = len(h._data)\n        # 最後の内部ノードから根に向かって sift_down\n        for i in range((n - 2) // 2, -1, -1):\n            h._sift_down(i)\n        return h\n\n\nh = MinHeap.heapify([5, 3, 8, 1, 4, 2, 7])\nprint('内部配列:', h._data)\nresult = []\nwhile h:\n    result.append(h.pop())\nprint('ソート結果:', result)","key":"hDHKSdh0UZ"},{"type":"outputs","id":"Iby6p2GwpR7Eem8mqPKeK","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"内部配列: [1, 3, 2, 5, 4, 8, 7]\nソート結果: [1, 2, 3, 4, 5, 7, 8]\n"},"children":[],"key":"mEInoGi9a4"}],"key":"ge5XLaPrZT"}],"key":"ENOmhcadF5"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Python の ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"h9HH9c5BH3"},{"type":"inlineCode","value":"heapq","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"sf3QmYjeDE"},{"type":"text","value":" モジュール","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SATg5Wf52C"}],"identifier":"python-heapq","label":"Python の heapq モジュール","html_id":"python-heapq","implicit":true,"key":"KlMYcBwibs"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Python 標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yNSoAL0c1p"},{"type":"inlineCode","value":"heapq","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zT2KjZdmZk"},{"type":"text","value":" は最小ヒープを提供する。リストをヒープとして操作する関数群。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"i2EwS7K4WU"}],"key":"ghZTo2eqCi"}],"key":"vffJ0naPOD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import heapq\n\ndata = [5, 3, 8, 1, 4]\nheapq.heapify(data)        # in-place でヒープ化 O(n)\nprint('heapify後:', data)\n\nheapq.heappush(data, 0)\nprint('push(0)後:', data)\n\nprint('pop:', heapq.heappop(data))   # 0\nprint('pop:', heapq.heappop(data))   # 1","key":"TeXXlSkB90"},{"type":"outputs","id":"7svQ7tGv7oPZjb2DsZ_oD","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"heapify後: [1, 3, 8, 5, 4]\npush(0)後: [0, 3, 1, 5, 4, 8]\npop: 0\npop: 1\n"},"children":[],"key":"zGnf0DqHyf"}],"key":"eCYx7KW11v"}],"key":"TN91mOqc67"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import heapq\n\ndata = [5, 3, 8, 1, 4]\n\n# push と pop を同時に行う（ヒープサイズ不変）\nheapq.heapify(data)\nprint('heappushpop(0):', heapq.heappushpop(data, 0))   # 0（新要素が最小なのでそのまま返る）\nprint('heappushpop(9):', heapq.heappushpop(data, 9))   # 1\n\n# n個の最小/最大値を取得\ndata = [5, 3, 8, 1, 4, 2, 7]\nprint('nsmallest(3):', heapq.nsmallest(3, data))   # [1, 2, 3]\nprint('nlargest(3):', heapq.nlargest(3, data))     # [8, 7, 5]","key":"u7XMbY2JkM"},{"type":"outputs","id":"ib3x_ScpYsusZ79Jc0cCe","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"heappushpop(0): 0\nheappushpop(9): 1\nnsmallest(3): [1, 2, 3]\nnlargest(3): [8, 7, 5]\n"},"children":[],"key":"q9Fia8sfoe"}],"key":"uQypzPkqYu"}],"key":"L9RmJ2RG0p"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ヒープソート","position":{"start":{"line":1,"column":1},"end":{"line":1,"c