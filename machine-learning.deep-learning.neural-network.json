{"version":3,"kind":"Notebook","sha256":"11405e0c73f1f4905206312bf4f90c486350ca5663a5172040db0f2b99b5556f","slug":"machine-learning.deep-learning.neural-network","location":"/machine_learning/deep_learning/neural_network.ipynb","dependencies":[],"frontmatter":{"title":"Feed-Forward Neural Network","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":2}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/deep_learning/neural_network.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/deep_learning/neural_network.ipynb","exports":[{"format":"ipynb","filename":"neural_network.ipynb","url":"/notes/build/neural_network-b23379edd0ab0d829d1f1879d9f44d15.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\n\n# n = 10\n# np.ramdom.seed(0)\n# x1 = np.random.uniform(0, 1, size=n)\n# x2 = np.random.uniform(0, 1, size=n)\n\ndef xor(x1, x2):\n    return 1 * ((x1 + x2) == 1)\n\nx1 = np.array([0, 1, 0, 1])\nx2 = np.array([0, 0, 1, 1])\ny = [xor(x1_, x2_) for x1_, x2_ in zip(x1, x2)]\n\nfor y_i in np.unique(y):\n    idx = y == y_i\n    plt.scatter(x1[idx], x2[idx], label=f\"y = {y_i}\")\nplt.legend()","key":"tqQrWgEfCS"},{"type":"outputs","id":"cf_Orx3j2kDRLzjfi5LV_","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{"needs_background":"light"},"data":{"image/png":{"content_type":"image/png","hash":"41d5b843f58c25e691e14fbcbcaee42f","path":"/notes/build/41d5b843f58c25e691e14fbcbcaee42f.png"},"text/plain":{"content":"<Figure size 432x288 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"K35YnQuqfQ"}],"key":"uptUAdxUCg"}],"key":"jz4lvBwXJF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"X = np.array([x1, x2]).T\nX","key":"Rgay3QtGc9"},{"type":"outputs","id":"jQvTzGvDCTr3_hevi9rU-","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":15,"metadata":{},"data":{"text/plain":{"content":"array([[0, 0],\n       [1, 0],\n       [0, 1],\n       [1, 1]])","content_type":"text/plain"}}},"children":[],"key":"yqeQsxqfH4"}],"key":"PMHE5KHiaM"}],"key":"ggfP0AS7dM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"vaCEG0WLUU"},{"type":"outputs","id":"BMvHzBRZdQ8p7oEI0SRSd","children":[],"key":"K9ifQYsgJL"}],"key":"YPX3MBMdj7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def step_function(x):\n    return np.array(x > 0)\n\ndef sigmoid(x):\n    return 1 / (1 + np.exp(-x))\n\ndef relu(x):\n    return np.maximum(0, x)\n\nx = np.arange(-2, 2, .1)\nplt.plot(x, step_function(x), label=\"step\")\nplt.plot(x, sigmoid(x), label=\"sigmoid\")\nplt.plot(x, relu(x), label=\"relu\")","key":"tQghNnRFEV"},{"type":"outputs","id":"xKXWYeFI4Qf8VFqpf5kE6","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{"needs_background":"light"},"data":{"image/png":{"content_type":"image/png","hash":"6189f6c1baa00241c27f7b8fe4bd4ca0","path":"/notes/build/6189f6c1baa00241c27f7b8fe4bd4ca0.png"},"text/plain":{"content":"<Figure size 432x288 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"J5Lpuptc8H"}],"key":"L6ZK1zdTKt"}],"key":"yaAJA103r8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"W = np.array([[1, 3, 5], [2, 4, 6]])\n\nX @ W","key":"X8K6yOa4Vc"},{"type":"outputs","id":"TQNDD6_BPqoCkPZRMxcdO","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":28,"metadata":{},"data":{"text/plain":{"content":"array([[ 0,  0,  0],\n       [ 1,  3,  5],\n       [ 2,  4,  6],\n       [ 3,  7, 11]])","content_type":"text/plain"}}},"children":[],"key":"SU03Y048Fq"}],"key":"cWjnmhJT0p"}],"key":"hufjn31Adv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def identity_function(x):\n    return x\n\ndef init_network():\n    network = {}\n    network['W1'] = np.array([[0.1, 0.3, 0.5], [0.2, 0.4, 0.6]])\n    network['b1'] = np.array([0.1, 0.2, 0.3])\n    network['W2'] = np.array([[0.1, 0.4], [0.2, 0.5], [0.3, 0.6]])\n    network['b2'] = np.array([0.1, 0.2])\n    network['W3'] = np.array([[0.1, 0.3], [0.2, 0.4]])\n    network['b3'] = np.array([0.1, 0.2])\n    return network\n\ndef forward(network, x):\n    W1, W2, W3 = network['W1'], network['W2'], network['W3']\n    b1, b2, b3 = network['b1'], network['b2'], network['b3']\n    a1 = np.dot(x, W1) + b1\n    z1 = sigmoid(a1)\n    a2 = np.dot(z1, W2) + b2\n    z2 = sigmoid(a2)\n    a3 = np.dot(z2, W3) + b3\n    y = identity_function(a3)\n    return y\n\nnetwork = init_network()\nx = np.array([1.0, 0.5])\ny = forward(network, x)\nprint(y) # [ 0.31682708 0.69627909]\n","key":"Hipo6dlU9U"},{"type":"outputs","id":"y9-pEhLTG_qbSZH6x8qXG","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[0.31682708 0.69627909]\n"},"children":[],"key":"J2XBFuuwp5"}],"key":"e7Z7aMrEbJ"}],"key":"ejhLqicgi9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"W1, W2, W3 = network['W1'], network['W2'], network['W3']\nb1, b2, b3 = network['b1'], network['b2'], network['b3']\na1 = np.dot(x, W1) + b1\nz1 = sigmoid(a1)\na2 = np.dot(z1, W2) + b2\nz2 = sigmoid(a2)\na3 = np.dot(z2, W3) + b3\ny = identity_function(a3)","key":"NcGznOaRlN"},{"type":"outputs","id":"3fIho2C_ceK3Gqx5V4u3x","children":[],"key":"Dx6NS0qvUD"}],"key":"Wio7tjO5Jj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"a1 = x @ W1 + b1\nz1 = sigmoid(a1)\nz1","key":"WeOo6PGj1N"},{"type":"outputs","id":"fvnNb8VeCN_FYk_puKYia","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":52,"metadata":{},"data":{"text/plain":{"content":"array([0.57444252, 0.66818777, 0.75026011])","content_type":"text/plain"}}},"children":[],"key":"E0eLvKg6hB"}],"key":"Mh5lWS5FcI"}],"key":"qCIfdlzWXw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Holyoak, K. J. (1987). Parallel distributed processing: explorations in the microstructure of cognition. Science, 236, 992-997.","key":"Ba3qkZ0uSk"},{"type":"outputs","id":"5rUIEM6VzVsFsw1VoAZhi","children":[],"key":"ZYGNZzioj5"}],"key":"xymX5ZS5zC"}],"key":"zx2kFr7mHR"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"RoLAとReLoLA","url":"/machine-learning/deep-learning/rola","group":"機械学習"},"next":{"title":"DeepLearningと表形式データ","url":"/machine-learning/deep-learning/dl-and-tabular-data","group":"機械学習"}}},"domain":"http://localhost:3000"}