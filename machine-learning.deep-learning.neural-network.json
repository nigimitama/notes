{"version":3,"kind":"Notebook","sha256":"11405e0c73f1f4905206312bf4f90c486350ca5663a5172040db0f2b99b5556f","slug":"machine-learning.deep-learning.neural-network","location":"/machine_learning/deep_learning/neural_network.ipynb","dependencies":[],"frontmatter":{"title":"Feed-Forward Neural Network","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":2}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/deep_learning/neural_network.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/deep_learning/neural_network.ipynb","exports":[{"format":"ipynb","filename":"neural_network.ipynb","url":"/notes/build/neural_network-ac8eeb30beabd5c368c801e19165331e.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\n\n# n = 10\n# np.ramdom.seed(0)\n# x1 = np.random.uniform(0, 1, size=n)\n# x2 = np.random.uniform(0, 1, size=n)\n\ndef xor(x1, x2):\n    return 1 * ((x1 + x2) == 1)\n\nx1 = np.array([0, 1, 0, 1])\nx2 = np.array([0, 0, 1, 1])\ny = [xor(x1_, x2_) for x1_, x2_ in zip(x1, x2)]\n\nfor y_i in np.unique(y):\n    idx = y == y_i\n    plt.scatter(x1[idx], x2[idx], label=f\"y = {y_i}\")\nplt.legend()","key":"jYL7vJWxsC"},{"type":"outputs","id":"z4G8LcSwaQ_aAP6CcSHcZ","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{"needs_background":"light"},"data":{"image/png":{"content_type":"image/png","hash":"41d5b843f58c25e691e14fbcbcaee42f","path":"/notes/build/41d5b843f58c25e691e14fbcbcaee42f.png"},"text/plain":{"content":"<Figure size 432x288 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"YTd1XN6zUn"}],"key":"JGX1RrJHzQ"}],"key":"HVSdzYg3Gp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"X = np.array([x1, x2]).T\nX","key":"HdvZXLbi8Q"},{"type":"outputs","id":"0iMwraEr_6_RpGdij7yjr","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":15,"metadata":{},"data":{"text/plain":{"content":"array([[0, 0],\n       [1, 0],\n       [0, 1],\n       [1, 1]])","content_type":"text/plain"}}},"children":[],"key":"qupiNy6Fsn"}],"key":"D6evKhB88T"}],"key":"hUm2xQi9UA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"WPxFnzTxUT"},{"type":"outputs","id":"ouk1iUQUirgCzzsTINLVR","children":[],"key":"dq8o6UMcqr"}],"key":"aRAegct2HP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def step_function(x):\n    return np.array(x > 0)\n\ndef sigmoid(x):\n    return 1 / (1 + np.exp(-x))\n\ndef relu(x):\n    return np.maximum(0, x)\n\nx = np.arange(-2, 2, .1)\nplt.plot(x, step_function(x), label=\"step\")\nplt.plot(x, sigmoid(x), label=\"sigmoid\")\nplt.plot(x, relu(x), label=\"relu\")","key":"ZLMLNt5Gir"},{"type":"outputs","id":"XepWFzq1gBy-AmKsQKHBS","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{"needs_background":"light"},"data":{"image/png":{"content_type":"image/png","hash":"6189f6c1baa00241c27f7b8fe4bd4ca0","path":"/notes/build/6189f6c1baa00241c27f7b8fe4bd4ca0.png"},"text/plain":{"content":"<Figure size 432x288 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"zzJKSQew4g"}],"key":"KYUy8DRRcZ"}],"key":"YzjSBitpUh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"W = np.array([[1, 3, 5], [2, 4, 6]])\n\nX @ W","key":"Xgaj1jvd8C"},{"type":"outputs","id":"7zldwWIWAl1tCybPSLIH_","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":28,"metadata":{},"data":{"text/plain":{"content":"array([[ 0,  0,  0],\n       [ 1,  3,  5],\n       [ 2,  4,  6],\n       [ 3,  7, 11]])","content_type":"text/plain"}}},"children":[],"key":"ezNP1OSwpw"}],"key":"hgISI6iTAy"}],"key":"fdAXA3boZy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def identity_function(x):\n    return x\n\ndef init_network():\n    network = {}\n    network['W1'] = np.array([[0.1, 0.3, 0.5], [0.2, 0.4, 0.6]])\n    network['b1'] = np.array([0.1, 0.2, 0.3])\n    network['W2'] = np.array([[0.1, 0.4], [0.2, 0.5], [0.3, 0.6]])\n    network['b2'] = np.array([0.1, 0.2])\n    network['W3'] = np.array([[0.1, 0.3], [0.2, 0.4]])\n    network['b3'] = np.array([0.1, 0.2])\n    return network\n\ndef forward(network, x):\n    W1, W2, W3 = network['W1'], network['W2'], network['W3']\n    b1, b2, b3 = network['b1'], network['b2'], network['b3']\n    a1 = np.dot(x, W1) + b1\n    z1 = sigmoid(a1)\n    a2 = np.dot(z1, W2) + b2\n    z2 = sigmoid(a2)\n    a3 = np.dot(z2, W3) + b3\n    y = identity_function(a3)\n    return y\n\nnetwork = init_network()\nx = np.array([1.0, 0.5])\ny = forward(network, x)\nprint(y) # [ 0.31682708 0.69627909]\n","key":"zNMLMJkOZm"},{"type":"outputs","id":"Nd38ehgA0sPfixNCfQ9FC","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[0.31682708 0.69627909]\n"},"children":[],"key":"BEbsB60g2r"}],"key":"CJQsoczAT9"}],"key":"gPlLfGHhDn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"W1, W2, W3 = network['W1'], network['W2'], network['W3']\nb1, b2, b3 = network['b1'], network['b2'], network['b3']\na1 = np.dot(x, W1) + b1\nz1 = sigmoid(a1)\na2 = np.dot(z1, W2) + b2\nz2 = sigmoid(a2)\na3 = np.dot(z2, W3) + b3\ny = identity_function(a3)","key":"rgQPULTbMj"},{"type":"outputs","id":"Sp9ChZ81R8TyOGvFydO7S","children":[],"key":"SCmwSAwQlI"}],"key":"eOSjp2vjbm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"a1 = x @ W1 + b1\nz1 = sigmoid(a1)\nz1","key":"TqjPBjdjMm"},{"type":"outputs","id":"mtkD4fCjeGxyhUBxMJVAW","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":52,"metadata":{},"data":{"text/plain":{"content":"array([0.57444252, 0.66818777, 0.75026011])","content_type":"text/plain"}}},"children":[],"key":"BRSzYumtBx"}],"key":"MnSnAzCx9o"}],"key":"K8o2ylOEbP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Holyoak, K. J. (1987). Parallel distributed processing: explorations in the microstructure of cognition. Science, 236, 992-997.","key":"zzAe3uMNvA"},{"type":"outputs","id":"8G6O5m0hZYD9Dh7YLcRG0","children":[],"key":"pLW5dXkdhl"}],"key":"iB7NXrgiEe"}],"key":"DWRnZJ7To3"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"RoLAとReLoLA","url":"/machine-learning/deep-learning/rola","group":"機械学習"},"next":{"title":"DeepLearningと表形式データ","url":"/machine-learning/deep-learning/dl-and-tabular-data","group":"機械学習"}}},"domain":"http://localhost:3000"}