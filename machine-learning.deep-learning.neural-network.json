{"version":3,"kind":"Notebook","sha256":"11405e0c73f1f4905206312bf4f90c486350ca5663a5172040db0f2b99b5556f","slug":"machine-learning.deep-learning.neural-network","location":"/machine_learning/deep_learning/neural_network.ipynb","dependencies":[],"frontmatter":{"title":"Feed-Forward Neural Network","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":2}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/deep_learning/neural_network.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/deep_learning/neural_network.ipynb","exports":[{"format":"ipynb","filename":"neural_network.ipynb","url":"/notes/build/neural_network-c62c5908578897f40d5b153a87956d1e.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\n\n# n = 10\n# np.ramdom.seed(0)\n# x1 = np.random.uniform(0, 1, size=n)\n# x2 = np.random.uniform(0, 1, size=n)\n\ndef xor(x1, x2):\n    return 1 * ((x1 + x2) == 1)\n\nx1 = np.array([0, 1, 0, 1])\nx2 = np.array([0, 0, 1, 1])\ny = [xor(x1_, x2_) for x1_, x2_ in zip(x1, x2)]\n\nfor y_i in np.unique(y):\n    idx = y == y_i\n    plt.scatter(x1[idx], x2[idx], label=f\"y = {y_i}\")\nplt.legend()","key":"AEliMjL3ql"},{"type":"outputs","id":"XqXQisEiLgZS__Ep6l9Yk","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{"needs_background":"light"},"data":{"image/png":{"content_type":"image/png","hash":"41d5b843f58c25e691e14fbcbcaee42f","path":"/notes/build/41d5b843f58c25e691e14fbcbcaee42f.png"},"text/plain":{"content":"<Figure size 432x288 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"UIVIEWO9FT"}],"key":"GSmipohzOz"}],"key":"NiBPWgi6OD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"X = np.array([x1, x2]).T\nX","key":"MPTiiVuSL0"},{"type":"outputs","id":"wnNgpsmnIOuiBTUonRpz4","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":15,"metadata":{},"data":{"text/plain":{"content":"array([[0, 0],\n       [1, 0],\n       [0, 1],\n       [1, 1]])","content_type":"text/plain"}}},"children":[],"key":"s5VwyCj0If"}],"key":"spVyuy5m1U"}],"key":"rXOd7bzIkk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"f4Sq3fcAaJ"},{"type":"outputs","id":"8riu6_c9sf395E6yHjruP","children":[],"key":"DBffu8yr9B"}],"key":"lU1XfasAd3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def step_function(x):\n    return np.array(x > 0)\n\ndef sigmoid(x):\n    return 1 / (1 + np.exp(-x))\n\ndef relu(x):\n    return np.maximum(0, x)\n\nx = np.arange(-2, 2, .1)\nplt.plot(x, step_function(x), label=\"step\")\nplt.plot(x, sigmoid(x), label=\"sigmoid\")\nplt.plot(x, relu(x), label=\"relu\")","key":"vESyHYQ1u8"},{"type":"outputs","id":"QP62FLTmyJXFHBKJ97_YB","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{"needs_background":"light"},"data":{"image/png":{"content_type":"image/png","hash":"6189f6c1baa00241c27f7b8fe4bd4ca0","path":"/notes/build/6189f6c1baa00241c27f7b8fe4bd4ca0.png"},"text/plain":{"content":"<Figure size 432x288 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"uWP97y9cRr"}],"key":"JhT52rN5U7"}],"key":"OcWODWePuf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"W = np.array([[1, 3, 5], [2, 4, 6]])\n\nX @ W","key":"WetN4eZbky"},{"type":"outputs","id":"SMRL9zws8xNMsEOj-LxDg","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":28,"metadata":{},"data":{"text/plain":{"content":"array([[ 0,  0,  0],\n       [ 1,  3,  5],\n       [ 2,  4,  6],\n       [ 3,  7, 11]])","content_type":"text/plain"}}},"children":[],"key":"rtZYZZdSIJ"}],"key":"gBt2qySw7Y"}],"key":"V0w2YaV7Bg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def identity_function(x):\n    return x\n\ndef init_network():\n    network = {}\n    network['W1'] = np.array([[0.1, 0.3, 0.5], [0.2, 0.4, 0.6]])\n    network['b1'] = np.array([0.1, 0.2, 0.3])\n    network['W2'] = np.array([[0.1, 0.4], [0.2, 0.5], [0.3, 0.6]])\n    network['b2'] = np.array([0.1, 0.2])\n    network['W3'] = np.array([[0.1, 0.3], [0.2, 0.4]])\n    network['b3'] = np.array([0.1, 0.2])\n    return network\n\ndef forward(network, x):\n    W1, W2, W3 = network['W1'], network['W2'], network['W3']\n    b1, b2, b3 = network['b1'], network['b2'], network['b3']\n    a1 = np.dot(x, W1) + b1\n    z1 = sigmoid(a1)\n    a2 = np.dot(z1, W2) + b2\n    z2 = sigmoid(a2)\n    a3 = np.dot(z2, W3) + b3\n    y = identity_function(a3)\n    return y\n\nnetwork = init_network()\nx = np.array([1.0, 0.5])\ny = forward(network, x)\nprint(y) # [ 0.31682708 0.69627909]\n","key":"uZuT7vxchE"},{"type":"outputs","id":"7crqZYnK-hgMOo_3z9ykG","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[0.31682708 0.69627909]\n"},"children":[],"key":"gPuJfEXrKp"}],"key":"LljaGrmytx"}],"key":"iUeKtRsbq5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"W1, W2, W3 = network['W1'], network['W2'], network['W3']\nb1, b2, b3 = network['b1'], network['b2'], network['b3']\na1 = np.dot(x, W1) + b1\nz1 = sigmoid(a1)\na2 = np.dot(z1, W2) + b2\nz2 = sigmoid(a2)\na3 = np.dot(z2, W3) + b3\ny = identity_function(a3)","key":"uUt2fO5AcB"},{"type":"outputs","id":"kNr2zoSBwVZ2pl6WaQgKj","children":[],"key":"tHuho3JjeC"}],"key":"S8wYZCRgxn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"a1 = x @ W1 + b1\nz1 = sigmoid(a1)\nz1","key":"GqgiXNfxi8"},{"type":"outputs","id":"iotwk6p_val5rZK0svfV8","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":52,"metadata":{},"data":{"text/plain":{"content":"array([0.57444252, 0.66818777, 0.75026011])","content_type":"text/plain"}}},"children":[],"key":"kUZiq3xKat"}],"key":"Tm5s47xR7k"}],"key":"RwoR4Yb66m"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Holyoak, K. J. (1987). Parallel distributed processing: explorations in the microstructure of cognition. Science, 236, 992-997.","key":"yffeBg22Rg"},{"type":"outputs","id":"21uc3nCAlxv2mv7-OP57N","children":[],"key":"Bfn4Q87jCN"}],"key":"zY3K8Nz0wG"}],"key":"k9WQPRe4mE"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"RoLAとReLoLA","url":"/machine-learning/deep-learning/rola","group":"機械学習"},"next":{"title":"DeepLearningと表形式データ","url":"/machine-learning/deep-learning/dl-and-tabular-data","group":"機械学習"}}},"domain":"http://localhost:3000"}