append(0)\n    while len(todo) > 0:\n        target_node: int = todo.pop()\n        print(f\"searching a node '{target_node}'\")\n        for adj_node in adjacent_nodes[target_node]:\n            if not searched[adj_node]:\n                print(f\"{adj_node} is found and enqueued to todo\")\n                todo.append(adj_node)\n                searched[adj_node] = True\n\n\n# 隣接リスト表現 (adjacency-list representation)したグラフ\nedges: List[list] = [\n    [0, 1],  # 0 - 1 の辺\n    [0, 2],\n    [1, 3]\n]\ndfs(edges)","key":"Ht51rYCtzf"},{"type":"outputs","id":"3oeNEI5Z_uWtwtdeMi1YZ","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"searching a node '0'\n1 is found and enqueued to todo\n2 is found and enqueued to todo\nsearching a node '2'\nsearching a node '1'\n3 is found and enqueued to todo\nsearching a node '3'\n"},"children":[],"key":"i5N5zw33vS"}],"key":"C5LoPaUPTC"}],"key":"xIRkUDBLPJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"jBZEMDyLxL"},{"type":"outputs","id":"rZtEcRDvB5McPJz6lRWfs","children":[],"key":"eknZrxlBRC"}],"key":"M43k1YZ5bz"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ダイクストラ法","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ttRs7SFP4g"}],"identifier":"id","label":"ダイクストラ法","html_id":"id","implicit":true,"key":"xUTC1vQ3ho"}],"key":"ch0BSViCJn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"QJx4m2iQKk"},{"type":"outputs","id":"upJgm0B7XJ2iNbiPYNknS","children":[],"key":"HKBIgy4xNO"}],"key":"MlS2B0xGyx"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量","