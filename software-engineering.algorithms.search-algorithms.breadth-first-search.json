append(0)\n    while len(todo) > 0:\n        target_node: int = todo.pop()\n        print(f\"searching a node '{target_node}'\")\n        for adj_node in adjacent_nodes[target_node]:\n            if not searched[adj_node]:\n                print(f\"{adj_node} is found and enqueued to todo\")\n                todo.append(adj_node)\n                searched[adj_node] = True\n\n\n# 隣接リスト表現 (adjacency-list representation)したグラフ\nedges: List[list] = [\n    [0, 1],  # 0 - 1 の辺\n    [0, 2],\n    [1, 3]\n]\ndfs(edges)","key":"NPZvuE2KRS"},{"type":"outputs","id":"yN-DNP2TOxU3UHeIvHuhM","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"searching a node '0'\n1 is found and enqueued to todo\n2 is found and enqueued to todo\nsearching a node '2'\nsearching a node '1'\n3 is found and enqueued to todo\nsearching a node '3'\n"},"children":[],"key":"UyiJrVRUsR"}],"key":"VFJEhSbHP7"}],"key":"toqJRYIZKx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"wuY6saXjxn"},{"type":"outputs","id":"YIO6VJdC_c4i7r5k_0ye4","children":[],"key":"fZ0CxHvbn3"}],"key":"QhoUR2FOot"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ダイクストラ法","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GSDKc3sGe3"}],"identifier":"id","label":"ダイクストラ法","html_id":"id","implicit":true,"key":"zQqn5kBPu0"}],"key":"ChG6H6tAkF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"mcpY6ZlD2D"},{"type":"outputs","id":"9FDTxqPfI0loZ9CSRx6j3","children":[],"key":"mKAmpcMDTH"}],"key":"nyfRdZs8IX"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量","