e\n\n\n# 隣接リスト表現 (adjacency-list representation)したグラフ\nedges: List[list] = [\n    [0, 1],  # 0 - 1 の辺\n    [0, 2],\n    [1, 3]\n]\nbfs(edges)","key":"RAqiBogeJI"},{"type":"outputs","id":"Xw7Uch6kwAWFQfALks-cp","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"searching a node '0'\n1 is found and enqueued to todo\n2 is found and enqueued to todo\nsearching a node '1'\n3 is found and enqueued to todo\nsearching a node '2'\nsearching a node '3'\n"},"children":[],"key":"ynBEkryEHo"}],"key":"SiHYzueegJ"}],"key":"zil6NhaPkL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"最良優先探索（best-first search）","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"kywI8ApPbO"}],"identifier":"id-best-first-search","label":"最良優先探索（best-first search）","html_id":"id-best-first-search","implicit":true,"key":"DI472T3Vwl"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"幅優先探索を拡張し、最も望ましいノードを選択するようにしたもの","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"FarxXK79df"}],"key":"QezqWOcLrK"}],"key":"JtzDDG8HTi"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://ja.wikipedia.org/wiki/%E6%9C%80%E8%89%AF%E5%84%AA%E5%85%88%E6%8E%A2%E7%B4%A2","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"最良優先探索 - Wikipedia","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"rHzrjOJfcz"}],"urlSource":"https://ja.wikipedia.org/wik