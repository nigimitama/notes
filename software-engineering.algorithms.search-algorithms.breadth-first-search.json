append(0)\n    while len(todo) > 0:\n        target_node: int = todo.pop()\n        print(f\"searching a node '{target_node}'\")\n        for adj_node in adjacent_nodes[target_node]:\n            if not searched[adj_node]:\n                print(f\"{adj_node} is found and enqueued to todo\")\n                todo.append(adj_node)\n                searched[adj_node] = True\n\n\n# 隣接リスト表現 (adjacency-list representation)したグラフ\nedges: List[list] = [\n    [0, 1],  # 0 - 1 の辺\n    [0, 2],\n    [1, 3]\n]\ndfs(edges)","key":"i6KHF0mOZx"},{"type":"outputs","id":"PasiiphgjKWNK21Bd4Dt3","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"searching a node '0'\n1 is found and enqueued to todo\n2 is found and enqueued to todo\nsearching a node '2'\nsearching a node '1'\n3 is found and enqueued to todo\nsearching a node '3'\n"},"children":[],"key":"uZsLAVhcN0"}],"key":"dWfgISB1zE"}],"key":"SPB4QIysMg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"pC0u9kj3MM"},{"type":"outputs","id":"NwXn6I5E3cJdXWRVQf662","children":[],"key":"CtNrzFRtvN"}],"key":"uVTISV3rVT"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ダイクストラ法","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"x55gqcq8lZ"}],"identifier":"id","label":"ダイクストラ法","html_id":"id","implicit":true,"key":"KkMB8g1Jc9"}],"key":"uOP0xc6Mjf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"SkOSxxyTay"},{"type":"outputs","id":"RYJ7BUdjzLD9CpbVNGCry","children":[],"key":"RuFYr1HWpp"}],"key":"rASQwRdXJp"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量","