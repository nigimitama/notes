leqF6"}],"identifier":"id","label":"活用例：ダイクストラ法","html_id":"id-3","implicit":true,"key":"Re1iT3Ss60"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"優先度付きキューは最短経路アルゴリズム（ダイクストラ法）で頻繁に使われる。コストの小さいノードから順に探索することで効率よく最短距離を求められる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KkFipDzyou"}],"key":"p2xjAO6xfG"}],"key":"WhTwf9FwIs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import heapq\n\ndef dijkstra(graph, start):\n    dist = {node: float('inf') for node in graph}\n    dist[start] = 0\n    heap = [(0, start)]  # (コスト, ノード)\n\n    while heap:\n        cost, u = heapq.heappop(heap)\n        if cost > dist[u]:\n            continue\n        for v, weight in graph[u]:\n            new_cost = cost + weight\n            if new_cost < dist[v]:\n                dist[v] = new_cost\n                heapq.heappush(heap, (new_cost, v))\n\n    return dist\n\ngraph = {\n    'A': [('B', 1), ('C', 4)],\n    'B': [('C', 2), ('D', 5)],\n    'C': [('D', 1)],\n    'D': [],\n}\n\ndijkstra(graph, 'A')","key":"Bm2laOv9cC"},{"type":"outputs","id":"bnNNkDA9rxjN7tqyz4xhh","children":[],"key":"AMYEk0X06I"}],"key":"DNWbzo4NsP"}],"key":"KxnvxfVcvO"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"キュー","url":"/software-engineering/algorithms/data-structures/queue","group":"ソフトウェア工学"},"next":{"title":"ヒープ","url":"/software-engineering/algorithms/data-structures/heap","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}