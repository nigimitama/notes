現在処理中の桁の重み\n    while max_val // exp > 0:\n        a = _counting_sort_by_digit(a, exp, base)\n        exp *= base\n    return a\n\ndef _counting_sort_by_digit(arr: list[int], exp: int, base: int) -> list[int]:\n    n = len(arr)\n    output = [0] * n\n    count = [0] * base\n\n    for x in arr:\n        digit = (x // exp) % base\n        count[digit] += 1\n\n    for i in range(1, base):\n        count[i] += count[i - 1]\n\n    for x in reversed(arr):\n        digit = (x // exp) % base\n        count[digit] -= 1\n        output[count[digit]] = x\n\n    return output","key":"ST0GpVe2tT"},{"type":"outputs","id":"-JKYUyAbJgajYkRHVrjRt","children":[],"key":"W0sUeEqmwX"}],"key":"SGIUNVPCL5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import random\n\ndata = [170, 45, 75, 90, 802, 24, 2, 66]\nprint(\"入力:\", data)\nprint(\"出力:\", radix_sort(data))\n\n# 大きな値域でも有効\nrandom.seed(6)\nlarge = [random.randint(0, 10**9) for _ in range(500)]\nassert radix_sort(large) == sorted(large)\nprint(\"ランダム500件 (値域0-10^9): OK\")\n\n# 基数 256 で 32bit 整数\nlarge2 = [random.randint(0, 2**32 - 1) for _ in range(500)]\nassert radix_sort(large2, base=256) == sorted(large2)\nprint(\"32bit整数 500件 (基数256): OK\")","key":"DHKBPGQiBu"},{"type":"outputs","id":"x0OmuaPM87Z2tzJPwhqSi","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"入力: [170, 45, 75, 90, 802, 24, 2, 66]\n出力: [2, 24, 45, 66, 75, 90, 170, 802]\nランダム500件 (値域0-10^9): OK\n32bit整数 500件 (基数256): OK\n"},"children":[],"key":"AOdZaJ1noR"}],"key":"MADHXKCgPm"}],"key":"R6nI2HO1pI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"比較ソートとの計算量比較","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z2Jk8xyqUh"}],"identifier":"id","label":"比較ソートとの計算量比較","html_id":"id","implicit":true,"key":