[{"type":"code","lang":"python","executable":true,"value":"class HashTableChaining:\n    def __init__(self, size=11):\n        self.size = size\n        self.table = [[] for _ in range(size)]\n\n    def _hash(self, key):\n        return hash(key) % self.size\n\n    def insert(self, key, value):\n        idx = self._hash(key)\n        for i, (k, _) in enumerate(self.table[idx]):\n            if k == key:\n                self.table[idx][i] = (key, value)  # 上書き\n                return\n        self.table[idx].append((key, value))\n\n    def search(self, key):\n        idx = self._hash(key)\n        for k, v in self.table[idx]:\n            if k == key:\n                return v\n        raise KeyError(key)\n\n    def delete(self, key):\n        idx = self._hash(key)\n        self.table[idx] = [(k, v) for k, v in self.table[idx] if k != key]\n\n    def __repr__(self):\n        return \"\\n\".join(f\"[{i}]: {chain}\" for i, chain in enumerate(self.table) if chain)","key":"mWZ1IqElT2"},{"type":"outputs","id":"32nfZ_3MjRsrCLgDBfBub","children":[],"key":"U0kQp2J8Oz"}],"key":"aLxkUX11lC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ht = HashTableChaining()\nht.insert(\"apple\", 100)\nht.insert(\"banana\", 200)\nht.insert(\"cherry\", 300)\nht.insert(\"apple\", 150)  # 上書き\n\nprint(\"apple  ->\", ht.search(\"apple\"))\nprint(\"banana ->\", ht.search(\"banana\"))\n\nht.delete(\"banana\")\nprint(\"\\nbanana削除後のテーブル:\")\nprint(ht)","key":"XatrLT5Omm"},{"type":"outputs","id":"3khLzEn1fxOx2XxpxOzMr","children":[],"key":"uRuqkXbBeA"}],"key":"jQxG81Q6hB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"オープンアドレス法（線形探索）による実装","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EfUBBobL5F"}],"identifier":"id","label":"オープンアドレス法（線形探索）による実装","html_id":"id-3",