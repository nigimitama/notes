{"version":3,"kind":"Notebook","sha256":"a092a1b20d46ac4963ecf96f9cc5d4c80da877300be4b774003ce6add83171a3","slug":"software-engineering.design.design-patterns.creational-patterns","location":"/software_engineering/design/design_patterns/creational_patterns.ipynb","dependencies":[],"frontmatter":{"title":"生成に関するパターン（Creational Patterns）","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":3}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","exports":[{"format":"ipynb","filename":"creational_patterns.ipynb","url":"/notes/build/creational_patterns-d84d06cf585205eadac35195a848f30f.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成方法を柔軟にし、生成ロジックと利用ロジックを分離するパターン群。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JahxFKma28"}],"key":"J1HvXKvfXF"}],"key":"vCL78makie"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Singleton（シングルトン）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XxyiCJyzoF"}],"identifier":"singleton","label":"Singleton（シングルトン）","html_id":"singleton","implicit":true,"key":"kD5o0TT4ng"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"インスタンスが1つしか存在しないようにする。インスタンスをグローバル変数のように扱う。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Q2OWxp8Q7G"}],"key":"S1dGXIJslq"}],"key":"MDt03tWY8C"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from datetime import datetime\n\nclass Singleton:\n    _instance = None\n\n    def __new__(cls, *args, **kwargs):\n        if cls._instance is None:\n            cls._instance = super(Singleton, cls).__new__(cls)\n        return cls._instance\n\nclass MyClass(Singleton):\n    def __init__(self, value):\n        self.value = value\n\nm1 = MyClass(\"first\")\nprint(f\"{m1.value=}\")\n\n# m2を変えるとm1も変わる\nm2 = MyClass(\"second\")\nprint(f\"{m1.value=}, {m2.value=}\")","visibility":"show","key":"MAcbK0sA67"},{"type":"outputs","id":"bX3B6xEsTO8uS_MUAYeAB","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"m1.value='first'\nm1.value='second', m2.value='second'\n"},"children":[],"key":"oui49rk98q"}],"visibility":"show","key":"QjU89wK8Mk"}],"visibility":"show","key":"nzl2gIda6t"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Factory Method","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"j2u6phWf8L"}],"identifier":"factory-method","label":"Factory Method","html_id":"factory-method","implicit":true,"key":"r7GkuEXOkT"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成処理をサブクラスに任せる（newを隠す）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Udpw3kngUC"}],"key":"LZ6istqj0U"}],"key":"jNltSK4ZU7"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Animal:\n    def speak(self): pass\n\nclass Dog(Animal):\n    def speak(self): return \"Woof!\"\n\nclass Cat(Animal):\n    def speak(self): return \"Meow!\"\n\n\ndef animal_factory(kind: str) -> Animal:\n    if kind == \"dog\":\n        return Dog()\n    elif kind == \"cat\":\n        return Cat()\n\na = animal_factory(\"dog\")\nprint(a.speak())","visibility":"show","key":"tey0okue4H"},{"type":"outputs","id":"2abQwC6GOH6zi_6oX-Zdn","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Woof!\n"},"children":[],"key":"DPe4f6RGAr"}],"visibility":"show","key":"c2ks4gCMxH"}],"visibility":"show","key":"Hiza1KLVEC"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Builder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MVUR6UpDkG"}],"identifier":"builder","label":"Builder","html_id":"builder","implicit":true,"key":"aGU1QRjj9S"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"多数のパラメータを持つ複雑なオブジェクトを、生成過程を分けて段階的に組み立てるパターン。コンストラクタ引数が\n増えすぎる「テレスコーピング・コンストラクタ」問題を避けられる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"nnTlQokBEn"}],"key":"YGrsRCqjsI"},{"type":"code","lang":"python","value":"class Pizza:\n    def __init__(self):\n        self.toppings = []\n        self.size = \"M\"\n\nclass PizzaBuilder:\n    def __init__(self):\n        self.pizza = Pizza()\n\n    def set_size(self, size):\n        self.pizza.size = size\n        return self\n\n    def add_topping(self, topping):\n        self.pizza.toppings.append(topping)\n        return self\n\n    def build(self):\n        return self.pizza\n\npizza = PizzaBuilder().set_size(\"L\").add_topping(\"cheese\").add_topping(\"olive\").build()","position":{"start":{"line":6,"column":1},"end":{"line":28,"column":1}},"key":"eEgoaAIP5b"}],"key":"GgXuDl1HzV"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Prototype","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NjYXl3LoOT"}],"identifier":"prototype","label":"Prototype","html_id":"prototype","implicit":true,"key":"NR1o5fKe0V"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"既存のインスタンスを複製（clone）することで新しいオブジェクトを作るパターン。生成コストが高いオブジェクトや、\n初期状態を維持したままバリエーションを作りたい場合に使う。Pythonでは標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"c0jtlTLhtV"},{"type":"inlineCode","value":"copy.deepcopy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yhzw4qGPQu"},{"type":"text","value":" がそのまま使える。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vZT9ftObpn"}],"key":"SdFh4j2jdf"},{"type":"code","lang":"python","value":"import copy\n\nclass Sheep:\n    def __init__(self, name):\n        self.name = name\n\noriginal = Sheep(\"Dolly\")\nclone = copy.deepcopy(original)\nclone.name = \"Dolly Jr.\"","position":{"start":{"line":6,"column":1},"end":{"line":16,"column":1}},"key":"b2wnqdx7cg"}],"key":"zWwlMZRLdW"}],"key":"LmOpvQEysz"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"依存性注入（Dependency Injection）","url":"/software-engineering/design/design-patterns/dependency-injection","group":"ソフトウェア工学"},"next":{"title":"構造に関するパターン（Structural Patterns）","url":"/software-engineering/design/design-patterns/structural-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}