:3,"column":1}},"children":[{"type":"text","value":"インスタンスが1つしか存在しないようにする。インスタンスをグローバル変数のように扱う。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"RNMUHLA3lv"}],"key":"gRDWz4U0cY"}],"key":"SUuMzLxHU0"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from datetime import datetime\n\nclass Singleton:\n    _instance = None\n\n    def __new__(cls, *args, **kwargs):\n        if cls._instance is None:\n            cls._instance = super(Singleton, cls).__new__(cls)\n        return cls._instance\n\nclass MyClass(Singleton):\n    def __init__(self, value):\n        self.value = value\n\nm1 = MyClass(\"first\")\nprint(f\"{m1.value=}\")\n\n# m2を変えるとm1も変わる\nm2 = MyClass(\"second\")\nprint(f\"{m1.value=}, {m2.value=}\")","visibility":"show","key":"FUo2ORbTwN"},{"type":"outputs","id":"aFhTABfOVnkjWrLyyx40B","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"m1.value='first'\nm1.value='second', m2.value='second'\n"},"children":[],"key":"vCmt1K8Plu"}],"visibility":"show","key":"qJAPOVBPoZ"}],"visibility":"show","key":"F7YGDqu3Gd"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Factory Method","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CoDNex01nC"}],"identifier":"factory-method","label":"Factory Method","html_id":"factory-method","implicit":true,"key":"QtMBb68SSG"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成処理をサブクラスに任せる（newを隠す）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xZm0pDPifQ"}],"key":"IdKIv29s32"}],"key":"bE7vCYGhGI"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Animal:\n    def speak(self): pass\n\nclass Dog(Animal):\n    def speak(self): return \"Woof!\"\n\nclass Cat(Animal):\n    def speak(self): return \"Meow!\"\n\n\ndef animal_factory(kind: str) -> Animal:\n    if kind == \"dog\":\n        return Dog()\n    elif kind == \"cat\":\n        return Cat()\n\na = animal_factory(\"dog\")\nprint(a.speak())","visibility":"show","key":"mbtlzOiF2l"},{"type":"outputs","id":"bENgpH-IFjeLv_ccM0IRG","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Woof!\n"},"children":[],"key":"DkLi1W8ZoS"}],"visibility":"show","key":"kjYWwywH9U"}],"visibility":"show","key":"o0kOPnY5Vw"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Builder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oHxAkLQz14"}],"identifier":"builder","label":"Builder","html_id":"builder","implicit":true,"key":"pWfvVxuPTC"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"多数のパラメータを持つ複雑なオブジェクトを、生成過程を分けて段階的に組み立てるパターン。コンストラクタ引数が増えすぎる「テレスコーピング・コンストラクタ」問題を避けられる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gbNP6SXAR2"}],"key":"MNyNCVsWph"}],"key":"ATLM8R0zLM"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Pizza:\n    def __init__(self):\n        self.toppings = []\n        self.size = \"M\"\n\nclass PizzaBuilder:\n    def __init__(self):\n        self.pizza = Pizza()\n\n    def set_size(self, size):\n        self.pizza.size = size\n        return self\n\n    def add_topping(self, topping):\n        self.pizza.toppings.append(topping)\n        return self\n\n    def build(self):\n        return self.pizza\n\npizza = PizzaBuilder().set_size(\"L\").add_topping(\"cheese\").add_topping(\"olive\").build()","visibility":"show","key":"lBmSyOhrtF"},{"type":"outputs","id":"lan2O8zm4HZsj3MD-VGQB","children":[],"visibility":"show","key":"Vj15oeLEv2"}],"visibility":"show","key":"lV52fSNnsk"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Prototype","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uloX67bMht"}],"identifier":"prototype","label":"Prototype","html_id":"prototype","implicit":true,"key":"Yfx6il2iaF"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"既存のインスタンスを複製（clone）することで新しいオブジェクトを作るパターン。生成コストが高いオブジェクトや、\n初期状態を維持したままバリエーションを作りたい場合に使う。Pythonでは標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dWSBE6FV7Z"},{"type":"inlineCode","value":"copy.deepcopy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Yr9hVhNRET"},{"type":"text","value":" がそのまま使える。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QvbIjGdiMo"}],"key":"sPLnbKt7An"}],"key":"iHtrWTqnBc"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import copy\n\nclass Sheep:\n    def __init__(self, name):\n        self.name = name\n\noriginal = Sheep(\"Dolly\")\nclone = copy.deepcopy(original)\nclone.name = \"Dolly Jr.\"\noriginal.name","visibility":"show","key":"SRD2ysVWG3"},{"type":"outputs","id":"zCQ1dPMK9pliqzeJfC3nq","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"'Dolly'","content_type":"text/plain"}}},"children":[],"key":"nHxbQBQpg9"}],"visibility":"show","key":"CJH6lO6hbv"}],"visibility":"show","key":"ckWZDzXLtS"}],"key":"hXTvGdJk45"},"references":{"ci