{"version":3,"kind":"Notebook","sha256":"a092a1b20d46ac4963ecf96f9cc5d4c80da877300be4b774003ce6add83171a3","slug":"software-engineering.design.design-patterns.creational-patterns","location":"/software_engineering/design/design_patterns/creational_patterns.ipynb","dependencies":[],"frontmatter":{"title":"生成に関するパターン（Creational Patterns）","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":3}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","exports":[{"format":"ipynb","filename":"creational_patterns.ipynb","url":"/notes/build/creational_patterns-22268dec1224a351726a21b52587d0eb.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成方法を柔軟にし、生成ロジックと利用ロジックを分離するパターン群。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yBEiItpVUP"}],"key":"gLV8ur2USU"}],"key":"cvBBWEzCKz"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Singleton（シングルトン）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XB8dxFWdoy"}],"identifier":"singleton","label":"Singleton（シングルトン）","html_id":"singleton","implicit":true,"key":"Etl6X9uc0D"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"インスタンスが1つしか存在しないようにする。インスタンスをグローバル変数のように扱う。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Zns20EpYYc"}],"key":"aXfoFkIuTE"}],"key":"gR6tkTAQf6"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from datetime import datetime\n\nclass Singleton:\n    _instance = None\n\n    def __new__(cls, *args, **kwargs):\n        if cls._instance is None:\n            cls._instance = super(Singleton, cls).__new__(cls)\n        return cls._instance\n\nclass MyClass(Singleton):\n    def __init__(self, value):\n        self.value = value\n\nm1 = MyClass(\"first\")\nprint(f\"{m1.value=}\")\n\n# m2を変えるとm1も変わる\nm2 = MyClass(\"second\")\nprint(f\"{m1.value=}, {m2.value=}\")","visibility":"show","key":"L0uNdxSWRy"},{"type":"outputs","id":"o42cA5vgIsx-VUhqcZdn-","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"m1.value='first'\nm1.value='second', m2.value='second'\n"},"children":[],"key":"pO04KEmYz4"}],"visibility":"show","key":"Vg9TkIy1Eb"}],"visibility":"show","key":"psHEBbqZPL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Factory Method","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"G3YICfRVsg"}],"identifier":"factory-method","label":"Factory Method","html_id":"factory-method","implicit":true,"key":"bkgmmVKQLu"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成処理をサブクラスに任せる（newを隠す）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"uiHL4GqE7U"}],"key":"gx3I9D8JS1"}],"key":"AFOn0rY5cH"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Animal:\n    def speak(self): pass\n\nclass Dog(Animal):\n    def speak(self): return \"Woof!\"\n\nclass Cat(Animal):\n    def speak(self): return \"Meow!\"\n\n\ndef animal_factory(kind: str) -> Animal:\n    if kind == \"dog\":\n        return Dog()\n    elif kind == \"cat\":\n        return Cat()\n\na = animal_factory(\"dog\")\nprint(a.speak())","visibility":"show","key":"DfmZ6Trg4R"},{"type":"outputs","id":"emYkT72x6W5pvxLByt7Za","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Woof!\n"},"children":[],"key":"QuUGAEF6e0"}],"visibility":"show","key":"mz8jhuVC09"}],"visibility":"show","key":"Yn1W6CSWrT"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Builder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MwupCfaFx9"}],"identifier":"builder","label":"Builder","html_id":"builder","implicit":true,"key":"w29rmxMsmF"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"多数のパラメータを持つ複雑なオブジェクトを、生成過程を分けて段階的に組み立てるパターン。コンストラクタ引数が\n増えすぎる「テレスコーピング・コンストラクタ」問題を避けられる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lcu0K2R35I"}],"key":"zpWzU7tUQr"},{"type":"code","lang":"python","value":"class Pizza:\n    def __init__(self):\n        self.toppings = []\n        self.size = \"M\"\n\nclass PizzaBuilder:\n    def __init__(self):\n        self.pizza = Pizza()\n\n    def set_size(self, size):\n        self.pizza.size = size\n        return self\n\n    def add_topping(self, topping):\n        self.pizza.toppings.append(topping)\n        return self\n\n    def build(self):\n        return self.pizza\n\npizza = PizzaBuilder().set_size(\"L\").add_topping(\"cheese\").add_topping(\"olive\").build()","position":{"start":{"line":6,"column":1},"end":{"line":28,"column":1}},"key":"qnVjwiqp2Z"}],"key":"gOwqUBdW9d"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Prototype","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"g0N1B4yKsY"}],"identifier":"prototype","label":"Prototype","html_id":"prototype","implicit":true,"key":"JLhEqTW1ro"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"既存のインスタンスを複製（clone）することで新しいオブジェクトを作るパターン。生成コストが高いオブジェクトや、\n初期状態を維持したままバリエーションを作りたい場合に使う。Pythonでは標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"F75iCDuP1U"},{"type":"inlineCode","value":"copy.deepcopy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xmyKGjWLvw"},{"type":"text","value":" がそのまま使える。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zj42P1kdnM"}],"key":"d0UMVhqb1c"},{"type":"code","lang":"python","value":"import copy\n\nclass Sheep:\n    def __init__(self, name):\n        self.name = name\n\noriginal = Sheep(\"Dolly\")\nclone = copy.deepcopy(original)\nclone.name = \"Dolly Jr.\"","position":{"start":{"line":6,"column":1},"end":{"line":16,"column":1}},"key":"A4QiE3Zo9h"}],"key":"xy2xhBE1FO"}],"key":"vTIHsDhHQh"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"依存性注入（Dependency Injection）","url":"/software-engineering/design/design-patterns/dependency-injection","group":"ソフトウェア工学"},"next":{"title":"構造に関するパターン（Structural Patterns）","url":"/software-engineering/design/design-patterns/structural-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}