{"version":3,"kind":"Notebook","sha256":"c03ec767bebc9bbb03d7af57c1d6bba7befaad1d867b5e64d1b33d9a0d8c946b","slug":"software-engineering.design.design-patterns.creational-patterns","location":"/software_engineering/design/design_patterns/creational_patterns.ipynb","dependencies":[],"frontmatter":{"title":"生成に関するパターン（Creational Patterns）","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":3}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","exports":[{"format":"ipynb","filename":"creational_patterns.ipynb","url":"/notes/build/creational_patterns-e09cd52a0f69e463e2f3b1486ee31c2a.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成方法を柔軟にし、生成ロジックと利用ロジックを分離するパターン群。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"TXAhSyrXGb"}],"key":"H3pkY3K9s0"}],"key":"Qf4M7pXk9I"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Singleton（シングルトン）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pI1L9SgXmA"}],"identifier":"singleton","label":"Singleton（シングルトン）","html_id":"singleton","implicit":true,"key":"YOEk2e0VF7"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"インスタンスが1つしか存在しないようにする。インスタンスをグローバル変数のように扱う。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YE3jjpaNdg"}],"key":"kafUGfukET"}],"key":"dutz1UFyn5"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from datetime import datetime\n\nclass Singleton:\n    _instance = None\n\n    def __new__(cls, *args, **kwargs):\n        if cls._instance is None:\n            cls._instance = super(Singleton, cls).__new__(cls)\n        return cls._instance\n\nclass MyClass(Singleton):\n    def __init__(self, value):\n        self.value = value\n\nm1 = MyClass(\"first\")\nprint(f\"{m1.value=}\")\n\n# m2を変えるとm1も変わる\nm2 = MyClass(\"second\")\nprint(f\"{m1.value=}, {m2.value=}\")","visibility":"show","key":"oJBjiHFpkF"},{"type":"outputs","id":"IYqWCrgRacwtL-7BwcI0H","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"m1.value='first'\nm1.value='second', m2.value='second'\n"},"children":[],"key":"CP235XL8rq"}],"visibility":"show","key":"AtM72hGzZz"}],"visibility":"show","key":"BrhHRoLgTU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Factory Method","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cpYXYufkEO"}],"identifier":"factory-method","label":"Factory Method","html_id":"factory-method","implicit":true,"key":"pGK30ut0Za"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成処理をサブクラスに任せる（newを隠す）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QgSoqEJroz"}],"key":"SYkP35U94L"}],"key":"DYGW0am2DN"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Animal:\n    def speak(self): pass\n\nclass Dog(Animal):\n    def speak(self): return \"Woof!\"\n\nclass Cat(Animal):\n    def speak(self): return \"Meow!\"\n\n\ndef animal_factory(kind: str) -> Animal:\n    if kind == \"dog\":\n        return Dog()\n    elif kind == \"cat\":\n        return Cat()\n\na = animal_factory(\"dog\")\nprint(a.speak())","visibility":"show","key":"g4GBPX1NUo"},{"type":"outputs","id":"6I8nSzyPe_VkH2xGPJ40x","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Woof!\n"},"children":[],"key":"ZJvDmt34p6"}],"visibility":"show","key":"eYd6fhHWR7"}],"visibility":"show","key":"Bs7v8K1Hux"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Builder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MlLeuJ9L21"}],"identifier":"builder","label":"Builder","html_id":"builder","implicit":true,"key":"YTGvkg2fA0"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"多数のパラメータを持つ複雑なオブジェクトを、生成過程を分けて段階的に組み立てるパターン。コンストラクタ引数が増えすぎる「テレスコーピング・コンストラクタ」問題を避けられる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"DyCvqOtuTa"}],"key":"IYCd7WlNt3"}],"key":"vEAvc3jzfo"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Pizza:\n    def __init__(self):\n        self.toppings = []\n        self.size = \"M\"\n\nclass PizzaBuilder:\n    def __init__(self):\n        self.pizza = Pizza()\n\n    def set_size(self, size):\n        self.pizza.size = size\n        return self\n\n    def add_topping(self, topping):\n        self.pizza.toppings.append(topping)\n        return self\n\n    def build(self):\n        return self.pizza\n\npizza = PizzaBuilder().set_size(\"L\").add_topping(\"cheese\").add_topping(\"olive\").build()","visibility":"show","key":"G9cfMYIuKS"},{"type":"outputs","id":"3pXUKKcGhj1chddb5-Pzc","children":[],"visibility":"show","key":"IjoB9ENXRb"}],"visibility":"show","key":"o1Vqn7iu1l"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Prototype","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Bc6L5VmTy5"}],"identifier":"prototype","label":"Prototype","html_id":"prototype","implicit":true,"key":"h2LlmLMQiF"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"既存のインスタンスを複製（clone）することで新しいオブジェクトを作るパターン。生成コストが高いオブジェクトや、\n初期状態を維持したままバリエーションを作りたい場合に使う。Pythonでは標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JL7qFotC3V"},{"type":"inlineCode","value":"copy.deepcopy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YQF2Zk9Ouq"},{"type":"text","value":" がそのまま使える。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Jhbs4AAQXh"}],"key":"EtbP7jE5Nn"}],"key":"URavmNExRe"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import copy\n\nclass Sheep:\n    def __init__(self, name):\n        self.name = name\n\noriginal = Sheep(\"Dolly\")\nclone = copy.deepcopy(original)\nclone.name = \"Dolly Jr.\"\noriginal.name","visibility":"show","key":"V5gnzzyvrj"},{"type":"outputs","id":"ezuZ2_DI_I9_9Cy2i82y-","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"'Dolly'","content_type":"text/plain"}}},"children":[],"key":"DXAHsHiZmt"}],"visibility":"show","key":"ofD5soz2Qd"}],"visibility":"show","key":"bxwplGbSn3"}],"key":"KiMsKI8FT3"},"references":{"ci