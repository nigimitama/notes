{"version":3,"kind":"Notebook","sha256":"a092a1b20d46ac4963ecf96f9cc5d4c80da877300be4b774003ce6add83171a3","slug":"software-engineering.design.design-patterns.creational-patterns","location":"/software_engineering/design/design_patterns/creational_patterns.ipynb","dependencies":[],"frontmatter":{"title":"生成に関するパターン（Creational Patterns）","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":3}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/software_engineering/design/design_patterns/creational_patterns.ipynb","exports":[{"format":"ipynb","filename":"creational_patterns.ipynb","url":"/notes/build/creational_patterns-46c7d0e0fce9b91019f07275307360f4.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成方法を柔軟にし、生成ロジックと利用ロジックを分離するパターン群。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"FZUpHIVSU8"}],"key":"hemLaqkYUE"}],"key":"aGZDLlWxDq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Singleton（シングルトン）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nDmU5KSexD"}],"identifier":"singleton","label":"Singleton（シングルトン）","html_id":"singleton","implicit":true,"key":"xcPgcXq460"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"インスタンスが1つしか存在しないようにする。インスタンスをグローバル変数のように扱う。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JvGuMAYiXv"}],"key":"kQuJxqCCLe"}],"key":"LLMGSTvd3O"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from datetime import datetime\n\nclass Singleton:\n    _instance = None\n\n    def __new__(cls, *args, **kwargs):\n        if cls._instance is None:\n            cls._instance = super(Singleton, cls).__new__(cls)\n        return cls._instance\n\nclass MyClass(Singleton):\n    def __init__(self, value):\n        self.value = value\n\nm1 = MyClass(\"first\")\nprint(f\"{m1.value=}\")\n\n# m2を変えるとm1も変わる\nm2 = MyClass(\"second\")\nprint(f\"{m1.value=}, {m2.value=}\")","visibility":"show","key":"SG13RXStff"},{"type":"outputs","id":"Rcvx0KnQVpW6VVnw6QHme","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"m1.value='first'\nm1.value='second', m2.value='second'\n"},"children":[],"key":"P4s62GsMJi"}],"visibility":"show","key":"DzhoUTMUip"}],"visibility":"show","key":"nmwCgLn3Px"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Factory Method","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"upzaWu1kr2"}],"identifier":"factory-method","label":"Factory Method","html_id":"factory-method","implicit":true,"key":"wij2IDQijr"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オブジェクトの生成処理をサブクラスに任せる（newを隠す）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Rlx79qOrnA"}],"key":"QhSeRa8RWO"}],"key":"AZgb3Sc4NE"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Animal:\n    def speak(self): pass\n\nclass Dog(Animal):\n    def speak(self): return \"Woof!\"\n\nclass Cat(Animal):\n    def speak(self): return \"Meow!\"\n\n\ndef animal_factory(kind: str) -> Animal:\n    if kind == \"dog\":\n        return Dog()\n    elif kind == \"cat\":\n        return Cat()\n\na = animal_factory(\"dog\")\nprint(a.speak())","visibility":"show","key":"ElBxEIIeIL"},{"type":"outputs","id":"8P47RJSoNAd4V-StgBhTx","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Woof!\n"},"children":[],"key":"G0xxagcjyf"}],"visibility":"show","key":"YPH9r5JMDT"}],"visibility":"show","key":"ADVvAPmmVm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Builder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"t0MnlC9lMh"}],"identifier":"builder","label":"Builder","html_id":"builder","implicit":true,"key":"b06ysJmIVZ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"多数のパラメータを持つ複雑なオブジェクトを、生成過程を分けて段階的に組み立てるパターン。コンストラクタ引数が\n増えすぎる「テレスコーピング・コンストラクタ」問題を避けられる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"R1N4uy5de4"}],"key":"w2B3Ac8KIs"},{"type":"code","lang":"python","value":"class Pizza:\n    def __init__(self):\n        self.toppings = []\n        self.size = \"M\"\n\nclass PizzaBuilder:\n    def __init__(self):\n        self.pizza = Pizza()\n\n    def set_size(self, size):\n        self.pizza.size = size\n        return self\n\n    def add_topping(self, topping):\n        self.pizza.toppings.append(topping)\n        return self\n\n    def build(self):\n        return self.pizza\n\npizza = PizzaBuilder().set_size(\"L\").add_topping(\"cheese\").add_topping(\"olive\").build()","position":{"start":{"line":6,"column":1},"end":{"line":28,"column":1}},"key":"ggyNSbQaOz"}],"key":"JjFq0F7bZt"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Prototype","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Jcp3YUAha2"}],"identifier":"prototype","label":"Prototype","html_id":"prototype","implicit":true,"key":"jWXVvCdafp"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"既存のインスタンスを複製（clone）することで新しいオブジェクトを作るパターン。生成コストが高いオブジェクトや、\n初期状態を維持したままバリエーションを作りたい場合に使う。Pythonでは標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Q70t2yBRld"},{"type":"inlineCode","value":"copy.deepcopy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"f65yvBBqze"},{"type":"text","value":" がそのまま使える。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lCkQH5Sl4Q"}],"key":"gyhhAIBqgi"},{"type":"code","lang":"python","value":"import copy\n\nclass Sheep:\n    def __init__(self, name):\n        self.name = name\n\noriginal = Sheep(\"Dolly\")\nclone = copy.deepcopy(original)\nclone.name = \"Dolly Jr.\"","position":{"start":{"line":6,"column":1},"end":{"line":16,"column":1}},"key":"h2lXowgllr"}],"key":"mCIR6S0YEZ"}],"key":"d8VSw73J8Z"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"依存性注入（Dependency Injection）","url":"/software-engineering/design/design-patterns/dependency-injection","group":"ソフトウェア工学"},"next":{"title":"構造に関するパターン（Structural Patterns）","url":"/software-engineering/design/design-patterns/structural-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}