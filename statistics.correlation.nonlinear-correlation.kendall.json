\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">−</span><span class=\"mord\">1</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1</span><span class=\"mclose\">]</span></span></span></span>","key":"hqk5DxyfIO"}],"key":"MeKDJQuV7t"}],"key":"F2T3IBD7Bs"}],"key":"qLpiAtZBJk"}],"key":"JqwDur7Ghv"},{"type":"block","kind":"notebook-code","data":{"jupyter":{"source_hidden":true},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from scipy.stats import kendalltau\nimport matplotlib.pyplot as plt\nimport numpy as np\n\nfig, axes = plt.subplots(figsize=[10, 2.5], ncols=3)\n\ntrue_r = 0.75\nmu = np.array([0.0, 0.0])\nSigma = np.array([[1.0, true_r], [true_r, 1.0]])\nsamples = np.random.multivariate_normal(mu, Sigma, size=100)\nx = samples[:, 0]\ny = samples[:, 1]\naxes[0].scatter(x, y)\naxes[0].set_title(f\"Kendall's τ = {kendalltau(x, y).statistic:.3f}\")\n\nx = np.linspace(-10, 10, 15)\ny = 1 / (1 + np.exp(-x))\naxes[1].scatter(x, y)\naxes[1].set_title(f\"Kendall's τ = {kendalltau(x, y).statistic:.3f}\")\n\nx = np.linspace(-3.14,3.14, 100)\ny = x**2 + np.random.random(len(x))\naxes[2].scatter(x, y)\naxes[2].set_title(f\"Kendall's τ = {kendalltau(x, y).statistic:.3f}\")\n\n%matplotlib inline","visibility":"hide","key":"XkTaIiByUg"},{"type":"outputs","id":"VR72iNbhAj20mtd9uD5lm","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"d9afcab80e70eed91be05c7a8afa2382","path":"/notes/build/d9afcab80e70eed91be05c7a8afa2382.png"},"text/plain":{"content":"<Figure size 1000x250 with 3 Axes>","content_type":"text/plain"}}},"children":[],"key":"ay2Z54aYCG"}],"visibility":"show","key":"gRV7MQiU9j"}],"visibility":"show","key":"xRMN0Al8F9"}],"key":"lVtqNNeC5B"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title"