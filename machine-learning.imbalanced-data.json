{"version":3,"kind":"Notebook","sha256":"fbed40a24c8016d526fdaee6d07aec5d05a8c4430f9772aada1113591adeba45","slug":"machine-learning.imbalanced-data","location":"/machine_learning/imbalanced_data.ipynb","dependencies":[],"frontmatter":{"title":"不均衡データ","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":1}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/imbalanced_data.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/imbalanced_data.ipynb","exports":[{"format":"ipynb","filename":"imbalanced_data.ipynb","url":"/notes/build/imbalanced_data-348ceadc5067df11a93c77eba144e1eb.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"不均衡データ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wMrBgyO4zx"}],"key":"gU1SHq7BYd"},{"type":"text","value":"（imbalanced data）は目的変数の分布が極端に偏っているためにおこる問題。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"uDdsyeer8R"}],"key":"JPLWd785ym"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"例えば目的変数が","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"kqPSTkKgAx"},{"type":"inlineMath","value":"y\\in \\{0, 1\\}","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi><mo>∈</mo><mo stretchy=\"false\">{</mo><mn>0</mn><mo separator=\"true\">,</mo><mn>1</mn><mo stretchy=\"false\">}</mo></mrow><annotation encoding=\"application/x-tex\">y\\in \\{0, 1\\}</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7335em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">∈</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">{</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1</span><span class=\"mclose\">}</span></span></span></span>","key":"LWIddYx5ZT"},{"type":"text","value":"の二値分類において1が90%あるデータの場合、全てに対して1を予測するだけのアルゴリズムであっても正解率（accuracy）は90%になる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"phA39tz69H"}],"key":"mQWrHA4ft1"}],"key":"MogC7oxoRW"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できるデータであれば不均衡であってもきちんと分類できるが、そうでない場合は不均衡具合に影響を受けてしまう","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WbVcNoNhKL"}],"key":"WwaRUjXgro"}],"key":"IqSSxc9WP9"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できない領域については、サンプリングや誤差関数への重み付けなどにより均衡データに近づけて学習させる方法がある。","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OqGxuPAngf"}],"key":"cpTtzOkInC"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ただし、その場合は均衡データとして学習している（例えば二値分類なら50%/50%）ので、予測の確率値も50%がしきい値となるような高い値が出てくるため、確率をカリブレーション（calibration）して戻す必要がある","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zxYCVDh90S"}],"key":"MdNsscsKWD"}],"key":"LxWXdNGvLi"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport numpy as np\nimport pandas as pd\n\ndef gen_data(scale = 1, p_minority = 0.1, n = 1000):\n    n_minor = int(n * p_minority)\n    n_major = int(n * (1 - p_minority))\n    np.random.seed(0)\n    y = np.append(\n        np.zeros(shape=(n_major,)),\n        np.ones(shape=(n_minor,)),\n    )\n    X = np.append(\n        np.random.normal(loc=(-1, -1), scale=scale, size=(n_major, 2)),\n        np.random.normal(loc=(1, 1), scale=scale, size=(n_minor, 2)),\n        axis=0\n    )\n    return X, y\n\n\ndef plot_data(X, y):\n    fig, ax = plt.subplots()\n    ax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=.7)\n    ax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=.7)\n    ax.set(xlabel=\"x1\", ylabel=\"x2\")\n    ax.legend()\n    fig.show()","visibility":"hide","key":"e3pCpnuRNZ"},{"type":"outputs","id":"YsHwN0moPKudJ7Q7stzvC","children":[],"visibility":"show","key":"uirEziF78r"}],"visibility":"show","key":"HOSdgiAAvS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"上手く分類できないデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tON36TXB57"}],"identifier":"id","label":"上手く分類できないデータの場合","html_id":"id","implicit":true,"key":"p1pX159ynK"}],"key":"svMx70CEBV"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 2, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"CuaI4Ur4OB"},{"type":"outputs","id":"Ppf8Uvmthc6ih5mbDoz72","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"2a9c5911f1345e3312c1d8d8268a0d6e","path":"/notes/build/2a9c5911f1345e3312c1d8d8268a0d6e.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"V04Jldlh73"}],"visibility":"show","key":"r0jk4tBQeQ"}],"visibility":"show","key":"DeGBoWUnGB"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"i1GQcNYEkn"},{"type":"outputs","id":"7kRNEJHGnEiY1eZxzHOI4","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e33081bcd70c97f0bd0eeed33593848e","path":"/notes/build/e33081bcd70c97f0bd0eeed33593848e.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"NJ6DRJQeks"}],"visibility":"show","key":"Y2FN4w3lHp"}],"visibility":"show","key":"NK4Y30qmrP"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.metrics import accuracy_score, balanced_accuracy_score, recall_score, precision_score, f1_score\n\nprint(f\"\"\"\naccuracy: {accuracy_score(y_test, y_pred):.3g}\nbalanced_accuracy: {balanced_accuracy_score(y_test, y_pred):.3g}\nrecall: {recall_score(y_test, y_pred):.3g}\nprecision: {precision_score(y_test, y_pred):.3g}\nf1_score: {f1_score(y_test, y_pred):.3g}\n\"\"\")","visibility":"hide","key":"bZODnaCM4X"},{"type":"outputs","id":"z-G4YJx6ydW6TvBB1B2Lb","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\naccuracy: 0.885\nbalanced_accuracy: 0.557\nrecall: 0.12\nprecision: 0.75\nf1_score: 0.207\n\n"},"children":[],"key":"pjVAh2i4Cm"}],"visibility":"show","key":"G2FiKtxcW7"}],"visibility":"show","key":"FwpWR7wba4"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import japanize_matplotlib\n\nx1_lim = (X[:, 0].min() * 1.1, X[:, 0].max() * 1.1)\nx2_lim = (X[:, 1].min() * 1.1, X[:, 1].max() * 1.1)\n\nX1, X2 = np.mgrid[x1_lim[0]:x1_lim[1]:1000j, x2_lim[0]:x2_lim[1]:1000j]\nX_range= np.append(X1.reshape(-1, 1), X2.reshape(-1, 1), axis=1)\nY = clf.predict(X_range).reshape(X1.shape)\n\nfig, ax = plt.subplots()\nax.contourf(X1, X2, Y, cmap='Paired', alpha=0.4)\n\nax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=0.7)\nax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=0.7)\n# ax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"Decision Boundary of Logistic Regression\")\nax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データで、うまく分類できていない場合\")\nax.legend()\nfig.show()","visibility":"hide","key":"B0opUN06iq"},{"type":"outputs","id":"-d3lZVQR95qHCQGLheFIX","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"91ea2dd073ed78feb0a48c3a505596c6","path":"/notes/build/91ea2dd073ed78feb0a48c3a505596c6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"SprYBPLrpE"}],"visibility":"show","key":"KVSHulXEq9"}],"visibility":"show","key":"HdVGY0WvwB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"分類しやすいデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xnhgNnWKMG"}],"identifier":"id","label":"分類しやすいデータの場合","html_id":"id-1","implicit":true,"key":"MOCMrqLdDG"}],"key":"uQqT6PpBfZ"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 0.6, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"Sf8ivOci1B"},{"type":"outputs","id":"2EsF42qxqSP9I1RL3hU-W","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"584bfbc3d7765424cf83f905ccde8cb6","path":"/notes/build/584bfbc3d7765424cf83f905ccde8cb6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"lOH422v9ny"}],"visibility":"show","key":"zWFZzlqvNM"}],"visibility":"show","key":"ce84FlAU1x"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"sANlGvvYQc"},{"type":"outputs","id":"5geRcGG12d7xvt0h4GGy1","children":[{"type":"output","jupyter_data":{"output_