{"version":3,"kind":"Notebook","sha256":"fbed40a24c8016d526fdaee6d07aec5d05a8c4430f9772aada1113591adeba45","slug":"machine-learning.imbalanced-data","location":"/machine_learning/imbalanced_data.ipynb","dependencies":[],"frontmatter":{"title":"不均衡データ","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":1}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/imbalanced_data.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/imbalanced_data.ipynb","exports":[{"format":"ipynb","filename":"imbalanced_data.ipynb","url":"/notes/build/imbalanced_data-7ac1847d895b6dab92b955aa2bc2e553.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"不均衡データ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"n0gEjZiRMP"}],"key":"UbW5DJxcRU"},{"type":"text","value":"（imbalanced data）は目的変数の分布が極端に偏っているためにおこる問題。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sqf3ZgUBgZ"}],"key":"RuYaWxTmIj"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"例えば目的変数が","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"NCLpKqNIoj"},{"type":"inlineMath","value":"y\\in \\{0, 1\\}","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi><mo>∈</mo><mo stretchy=\"false\">{</mo><mn>0</mn><mo separator=\"true\">,</mo><mn>1</mn><mo stretchy=\"false\">}</mo></mrow><annotation encoding=\"application/x-tex\">y\\in \\{0, 1\\}</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7335em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">∈</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">{</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1</span><span class=\"mclose\">}</span></span></span></span>","key":"ctkNvbM5kI"},{"type":"text","value":"の二値分類において1が90%あるデータの場合、全てに対して1を予測するだけのアルゴリズムであっても正解率（accuracy）は90%になる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"fCDt1JsrGy"}],"key":"SM7uXcdRJl"}],"key":"Ut2IYKQz6L"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できるデータであれば不均衡であってもきちんと分類できるが、そうでない場合は不均衡具合に影響を受けてしまう","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lQ5pEXMTjr"}],"key":"TgUBISnBCs"}],"key":"mSBx6OK6ny"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できない領域については、サンプリングや誤差関数への重み付けなどにより均衡データに近づけて学習させる方法がある。","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"K05oRqPr1H"}],"key":"uZWZM863o3"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ただし、その場合は均衡データとして学習している（例えば二値分類なら50%/50%）ので、予測の確率値も50%がしきい値となるような高い値が出てくるため、確率をカリブレーション（calibration）して戻す必要がある","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Xa06UyMJy7"}],"key":"FFTMplOHbn"}],"key":"yrOmJeqA9C"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport numpy as np\nimport pandas as pd\n\ndef gen_data(scale = 1, p_minority = 0.1, n = 1000):\n    n_minor = int(n * p_minority)\n    n_major = int(n * (1 - p_minority))\n    np.random.seed(0)\n    y = np.append(\n        np.zeros(shape=(n_major,)),\n        np.ones(shape=(n_minor,)),\n    )\n    X = np.append(\n        np.random.normal(loc=(-1, -1), scale=scale, size=(n_major, 2)),\n        np.random.normal(loc=(1, 1), scale=scale, size=(n_minor, 2)),\n        axis=0\n    )\n    return X, y\n\n\ndef plot_data(X, y):\n    fig, ax = plt.subplots()\n    ax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=.7)\n    ax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=.7)\n    ax.set(xlabel=\"x1\", ylabel=\"x2\")\n    ax.legend()\n    fig.show()","visibility":"hide","key":"JxFCzXq6Nv"},{"type":"outputs","id":"W-JgMeFqnnWtdTlK3j5Ih","children":[],"visibility":"show","key":"j5VhZhS5BN"}],"visibility":"show","key":"oWlMZK0bO6"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"上手く分類できないデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qUZHaVeChM"}],"identifier":"id","label":"上手く分類できないデータの場合","html_id":"id","implicit":true,"key":"VVQ2FgEnSM"}],"key":"Y6ZsTQFQxu"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 2, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"GnAFpEalT8"},{"type":"outputs","id":"pSa7IwPvSS7LXqoVAdMBO","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"2a9c5911f1345e3312c1d8d8268a0d6e","path":"/notes/build/2a9c5911f1345e3312c1d8d8268a0d6e.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"jNpT1flg4z"}],"visibility":"show","key":"FYGJNm1Bgt"}],"visibility":"show","key":"PcQqc9IUit"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"GoUGGafGWi"},{"type":"outputs","id":"RTBnnWGFhapNAC5MrYIVu","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e33081bcd70c97f0bd0eeed33593848e","path":"/notes/build/e33081bcd70c97f0bd0eeed33593848e.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"efJmx4o6IY"}],"visibility":"show","key":"Snxm9iJy7v"}],"visibility":"show","key":"MNUt4QnR3Q"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.metrics import accuracy_score, balanced_accuracy_score, recall_score, precision_score, f1_score\n\nprint(f\"\"\"\naccuracy: {accuracy_score(y_test, y_pred):.3g}\nbalanced_accuracy: {balanced_accuracy_score(y_test, y_pred):.3g}\nrecall: {recall_score(y_test, y_pred):.3g}\nprecision: {precision_score(y_test, y_pred):.3g}\nf1_score: {f1_score(y_test, y_pred):.3g}\n\"\"\")","visibility":"hide","key":"un37pn07w6"},{"type":"outputs","id":"pxfWZASYdxBkP59dx1V3P","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\naccuracy: 0.885\nbalanced_accuracy: 0.557\nrecall: 0.12\nprecision: 0.75\nf1_score: 0.207\n\n"},"children":[],"key":"VsPk6t0cRs"}],"visibility":"show","key":"mUGBXxvrv8"}],"visibility":"show","key":"S0OdDl6lGt"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import japanize_matplotlib\n\nx1_lim = (X[:, 0].min() * 1.1, X[:, 0].max() * 1.1)\nx2_lim = (X[:, 1].min() * 1.1, X[:, 1].max() * 1.1)\n\nX1, X2 = np.mgrid[x1_lim[0]:x1_lim[1]:1000j, x2_lim[0]:x2_lim[1]:1000j]\nX_range= np.append(X1.reshape(-1, 1), X2.reshape(-1, 1), axis=1)\nY = clf.predict(X_range).reshape(X1.shape)\n\nfig, ax = plt.subplots()\nax.contourf(X1, X2, Y, cmap='Paired', alpha=0.4)\n\nax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=0.7)\nax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=0.7)\n# ax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"Decision Boundary of Logistic Regression\")\nax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データで、うまく分類できていない場合\")\nax.legend()\nfig.show()","visibility":"hide","key":"mImwHbJkXy"},{"type":"outputs","id":"R9S_00uLq-9az1K9UDbfo","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"91ea2dd073ed78feb0a48c3a505596c6","path":"/notes/build/91ea2dd073ed78feb0a48c3a505596c6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"rlujqoAn1K"}],"visibility":"show","key":"I7HnFZ0ce8"}],"visibility":"show","key":"P1LMgvjWfL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"分類しやすいデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"llIrsMKz3f"}],"identifier":"id","label":"分類しやすいデータの場合","html_id":"id-1","implicit":true,"key":"KlNgD72QDg"}],"key":"T5AvblOxqF"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 0.6, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"C07QzCvex9"},{"type":"outputs","id":"M3IA0U35986qE2_zB_bBu","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"584bfbc3d7765424cf83f905ccde8cb6","path":"/notes/build/584bfbc3d7765424cf83f905ccde8cb6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Br2rbyMkAJ"}],"visibility":"show","key":"NxOF6L7teE"}],"visibility":"show","key":"JnihPDRbBk"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"rZHd7ohUmW"},{"type":"outputs","id":"G2XxDOJgJIaYdUjOGrszj","children":[{"type":"output","jupyter_data":{"output_