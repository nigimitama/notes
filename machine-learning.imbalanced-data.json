{"version":3,"kind":"Notebook","sha256":"fbed40a24c8016d526fdaee6d07aec5d05a8c4430f9772aada1113591adeba45","slug":"machine-learning.imbalanced-data","location":"/machine_learning/imbalanced_data.ipynb","dependencies":[],"frontmatter":{"title":"不均衡データ","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":1}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/imbalanced_data.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/imbalanced_data.ipynb","exports":[{"format":"ipynb","filename":"imbalanced_data.ipynb","url":"/notes/build/imbalanced_data-b967fcffffd2b48ba186e4b7d143c9e9.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"不均衡データ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"t17Rht1VsZ"}],"key":"vWEGnVxHKz"},{"type":"text","value":"（imbalanced data）は目的変数の分布が極端に偏っているためにおこる問題。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zRs6edIQkd"}],"key":"w3NY2pKzY5"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"例えば目的変数が","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"oNPmCxds9M"},{"type":"inlineMath","value":"y\\in \\{0, 1\\}","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi><mo>∈</mo><mo stretchy=\"false\">{</mo><mn>0</mn><mo separator=\"true\">,</mo><mn>1</mn><mo stretchy=\"false\">}</mo></mrow><annotation encoding=\"application/x-tex\">y\\in \\{0, 1\\}</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7335em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">∈</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">{</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1</span><span class=\"mclose\">}</span></span></span></span>","key":"KxvpSSUvMf"},{"type":"text","value":"の二値分類において1が90%あるデータの場合、全てに対して1を予測するだけのアルゴリズムであっても正解率（accuracy）は90%になる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"aLQ76yDAIc"}],"key":"ve3Sq17fNq"}],"key":"pwwQKcpJ4z"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できるデータであれば不均衡であってもきちんと分類できるが、そうでない場合は不均衡具合に影響を受けてしまう","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Lz1RRByILa"}],"key":"YoGKzOAJzx"}],"key":"wj2uV7EKwv"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できない領域については、サンプリングや誤差関数への重み付けなどにより均衡データに近づけて学習させる方法がある。","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SMsnuYFEas"}],"key":"Vfpet4unzy"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ただし、その場合は均衡データとして学習している（例えば二値分類なら50%/50%）ので、予測の確率値も50%がしきい値となるような高い値が出てくるため、確率をカリブレーション（calibration）して戻す必要がある","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fIhb01KkAW"}],"key":"cnhea23lY6"}],"key":"dGjL7YEcAi"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport numpy as np\nimport pandas as pd\n\ndef gen_data(scale = 1, p_minority = 0.1, n = 1000):\n    n_minor = int(n * p_minority)\n    n_major = int(n * (1 - p_minority))\n    np.random.seed(0)\n    y = np.append(\n        np.zeros(shape=(n_major,)),\n        np.ones(shape=(n_minor,)),\n    )\n    X = np.append(\n        np.random.normal(loc=(-1, -1), scale=scale, size=(n_major, 2)),\n        np.random.normal(loc=(1, 1), scale=scale, size=(n_minor, 2)),\n        axis=0\n    )\n    return X, y\n\n\ndef plot_data(X, y):\n    fig, ax = plt.subplots()\n    ax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=.7)\n    ax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=.7)\n    ax.set(xlabel=\"x1\", ylabel=\"x2\")\n    ax.legend()\n    fig.show()","visibility":"hide","key":"ylEVoIEw6Z"},{"type":"outputs","id":"ehXiOCG-YlRp0xeLvp4lW","children":[],"visibility":"show","key":"d0W5k2vRc4"}],"visibility":"show","key":"jt1ZlnpSXM"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"上手く分類できないデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"r58HFXwYKS"}],"identifier":"id","label":"上手く分類できないデータの場合","html_id":"id","implicit":true,"key":"RONFqUE0bf"}],"key":"KkvLKLbbgA"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 2, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"ADVUI2EvZB"},{"type":"outputs","id":"JCs9ev2VDX0IBBTsmAOvE","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"2a9c5911f1345e3312c1d8d8268a0d6e","path":"/notes/build/2a9c5911f1345e3312c1d8d8268a0d6e.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"zr2Rb6uFVd"}],"visibility":"show","key":"XIFz58Hbh2"}],"visibility":"show","key":"PI70nckY7q"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"ruCTjQmq4Z"},{"type":"outputs","id":"CVi7VV4fBCsYGkUCS3O0Y","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e33081bcd70c97f0bd0eeed33593848e","path":"/notes/build/e33081bcd70c97f0bd0eeed33593848e.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"aoO2OZHB08"}],"visibility":"show","key":"jhxBQeJc5M"}],"visibility":"show","key":"IjU8gxXAiD"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.metrics import accuracy_score, balanced_accuracy_score, recall_score, precision_score, f1_score\n\nprint(f\"\"\"\naccuracy: {accuracy_score(y_test, y_pred):.3g}\nbalanced_accuracy: {balanced_accuracy_score(y_test, y_pred):.3g}\nrecall: {recall_score(y_test, y_pred):.3g}\nprecision: {precision_score(y_test, y_pred):.3g}\nf1_score: {f1_score(y_test, y_pred):.3g}\n\"\"\")","visibility":"hide","key":"wIoNzmr6y8"},{"type":"outputs","id":"yfDkIBFIlr2Lq7n2eCZvG","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\naccuracy: 0.885\nbalanced_accuracy: 0.557\nrecall: 0.12\nprecision: 0.75\nf1_score: 0.207\n\n"},"children":[],"key":"bNdW9SHwOi"}],"visibility":"show","key":"KvZCaF2GT4"}],"visibility":"show","key":"FoAACYJAv2"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import japanize_matplotlib\n\nx1_lim = (X[:, 0].min() * 1.1, X[:, 0].max() * 1.1)\nx2_lim = (X[:, 1].min() * 1.1, X[:, 1].max() * 1.1)\n\nX1, X2 = np.mgrid[x1_lim[0]:x1_lim[1]:1000j, x2_lim[0]:x2_lim[1]:1000j]\nX_range= np.append(X1.reshape(-1, 1), X2.reshape(-1, 1), axis=1)\nY = clf.predict(X_range).reshape(X1.shape)\n\nfig, ax = plt.subplots()\nax.contourf(X1, X2, Y, cmap='Paired', alpha=0.4)\n\nax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=0.7)\nax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=0.7)\n# ax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"Decision Boundary of Logistic Regression\")\nax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データで、うまく分類できていない場合\")\nax.legend()\nfig.show()","visibility":"hide","key":"C7u5dUCLgw"},{"type":"outputs","id":"r71ydw1I-yaDFfUeJpig8","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"91ea2dd073ed78feb0a48c3a505596c6","path":"/notes/build/91ea2dd073ed78feb0a48c3a505596c6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"aDJyz00p3Y"}],"visibility":"show","key":"Qat3ddXe5g"}],"visibility":"show","key":"nHzRySH2Lj"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"分類しやすいデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"FIEI9zEXWK"}],"identifier":"id","label":"分類しやすいデータの場合","html_id":"id-1","implicit":true,"key":"CI7JTziWQQ"}],"key":"Ua409olV2O"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 0.6, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"wsdRVAAMrU"},{"type":"outputs","id":"MI7n8mQLovFeQ-KH0lsZ3","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"584bfbc3d7765424cf83f905ccde8cb6","path":"/notes/build/584bfbc3d7765424cf83f905ccde8cb6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Hmj6Xrath8"}],"visibility":"show","key":"lW9qQPrc8W"}],"visibility":"show","key":"BAalrpXr8l"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"BoBZJi8RiB"},{"type":"outputs","id":"ESbDeJTTnPjWnuGOEgXGh","children":[{"type":"output","jupyter_data":{"output_