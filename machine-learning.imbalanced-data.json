ion Boundary of Logistic Regression\")\nax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データだがうまく分類できている場合\")\n# ax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データで、うまく分類できていない場合\")\nax.legend()\nfig.show()","visibility":"hide","key":"AprG68FLH6"},{"type":"outputs","id":"gCcWOR8uVX6ClGKkvLHG8","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"029037115cfe2eaf70d42cbcdd401087","path":"/notes/build/029037115cfe2eaf70d42cbcdd401087.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Lk5jwPNApf"}],"visibility":"show","key":"HCkGtzvPqy"}],"visibility":"show","key":"eAGLtu7Dg0"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oxdmvI7OhI"}],"identifier":"id","label":"参考","html_id":"id-2","implicit":true,"key":"rGmYok1I4x"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://www.ai-gakkai.or.jp/resource/my-bookmark/my-bookmark_vol37-no3/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"【記事更新】私のブックマーク「不均衡データ分類」 – 人工知能学会 (The Japanese Society for Artificial Intelligence)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"tqbiU1aP6s"}],"urlSource":"https://www.ai-gakkai.or.jp/resource/my-bookmark/my-bookmark_vol37-no3/","key":"rz2wWgOlxe"}],"key":"c8Cugdgw1q"}],"key":"lEHsuzOfQc"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"lin