ion Boundary of Logistic Regression\")\nax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データだがうまく分類できている場合\")\n# ax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データで、うまく分類できていない場合\")\nax.legend()\nfig.show()","visibility":"hide","key":"tgx7RNUAtR"},{"type":"outputs","id":"IFgq3pxBQp0FbZpy91Wlo","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"029037115cfe2eaf70d42cbcdd401087","path":"/notes/build/029037115cfe2eaf70d42cbcdd401087.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"iOsk2zXqFH"}],"visibility":"show","key":"wtNwRNnkZR"}],"visibility":"show","key":"IgSzn3kz30"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lSj0TvP7vy"}],"identifier":"id","label":"参考","html_id":"id-2","implicit":true,"key":"PYeMO86h89"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://www.ai-gakkai.or.jp/resource/my-bookmark/my-bookmark_vol37-no3/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"【記事更新】私のブックマーク「不均衡データ分類」 – 人工知能学会 (The Japanese Society for Artificial Intelligence)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"D9gZe7yr9O"}],"urlSource":"https://www.ai-gakkai.or.jp/resource/my-bookmark/my-bookmark_vol37-no3/","key":"C7teZ9S59W"}],"key":"o3N2xMD2cE"}],"key":"hwyAvcCjpC"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"lin