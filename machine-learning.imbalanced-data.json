{"version":3,"kind":"Notebook","sha256":"fbed40a24c8016d526fdaee6d07aec5d05a8c4430f9772aada1113591adeba45","slug":"machine-learning.imbalanced-data","location":"/machine_learning/imbalanced_data.ipynb","dependencies":[],"frontmatter":{"title":"不均衡データ","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":1}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/machine_learning/imbalanced_data.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/machine_learning/imbalanced_data.ipynb","exports":[{"format":"ipynb","filename":"imbalanced_data.ipynb","url":"/notes/build/imbalanced_data-8935a7b6ad4f3ba6a81cf03a0efad569.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"不均衡データ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xiBRmlFzuk"}],"key":"dTH5mZd3QM"},{"type":"text","value":"（imbalanced data）は目的変数の分布が極端に偏っているためにおこる問題。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sz2q6iowZ5"}],"key":"NAXXJYYWyp"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"例えば目的変数が","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Q6FuNF3N35"},{"type":"inlineMath","value":"y\\in \\{0, 1\\}","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi><mo>∈</mo><mo stretchy=\"false\">{</mo><mn>0</mn><mo separator=\"true\">,</mo><mn>1</mn><mo stretchy=\"false\">}</mo></mrow><annotation encoding=\"application/x-tex\">y\\in \\{0, 1\\}</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.7335em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">∈</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">{</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">1</span><span class=\"mclose\">}</span></span></span></span>","key":"YhD3zVACnP"},{"type":"text","value":"の二値分類において1が90%あるデータの場合、全てに対して1を予測するだけのアルゴリズムであっても正解率（accuracy）は90%になる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"HauMk4MHd6"}],"key":"xpBOLAfS0P"}],"key":"PIjmT4sNyA"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できるデータであれば不均衡であってもきちんと分類できるが、そうでない場合は不均衡具合に影響を受けてしまう","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QwU8GSz0vi"}],"key":"T4r0J6naN2"}],"key":"gPs45itzJB"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"きちんと分類できない領域については、サンプリングや誤差関数への重み付けなどにより均衡データに近づけて学習させる方法がある。","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hFFjCX75Rn"}],"key":"uDLRrycEgI"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ただし、その場合は均衡データとして学習している（例えば二値分類なら50%/50%）ので、予測の確率値も50%がしきい値となるような高い値が出てくるため、確率をカリブレーション（calibration）して戻す必要がある","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"D2BWIILbcQ"}],"key":"vNO4fFJtv0"}],"key":"MT5UAPsuJN"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport numpy as np\nimport pandas as pd\n\ndef gen_data(scale = 1, p_minority = 0.1, n = 1000):\n    n_minor = int(n * p_minority)\n    n_major = int(n * (1 - p_minority))\n    np.random.seed(0)\n    y = np.append(\n        np.zeros(shape=(n_major,)),\n        np.ones(shape=(n_minor,)),\n    )\n    X = np.append(\n        np.random.normal(loc=(-1, -1), scale=scale, size=(n_major, 2)),\n        np.random.normal(loc=(1, 1), scale=scale, size=(n_minor, 2)),\n        axis=0\n    )\n    return X, y\n\n\ndef plot_data(X, y):\n    fig, ax = plt.subplots()\n    ax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=.7)\n    ax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=.7)\n    ax.set(xlabel=\"x1\", ylabel=\"x2\")\n    ax.legend()\n    fig.show()","visibility":"hide","key":"Fpbj9qDsY5"},{"type":"outputs","id":"03C46iEZuLgopzcVDuqL-","children":[],"visibility":"show","key":"dmxUE7wbJ9"}],"visibility":"show","key":"dAYx1v9wPq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"上手く分類できないデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ca4NwRp2Ie"}],"identifier":"id","label":"上手く分類できないデータの場合","html_id":"id","implicit":true,"key":"AaVJaRz2yy"}],"key":"Xllw4VAyPe"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 2, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"GitPTFLlP3"},{"type":"outputs","id":"AtvMZTff_zgQPFyHUi3XH","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"2a9c5911f1345e3312c1d8d8268a0d6e","path":"/notes/build/2a9c5911f1345e3312c1d8d8268a0d6e.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"tsr9rdYqnC"}],"visibility":"show","key":"nNv7SrkcWe"}],"visibility":"show","key":"uy5oGJs3tY"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"gTUPAP7C5q"},{"type":"outputs","id":"yOtXkllsXmXMmirNY6pyc","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e33081bcd70c97f0bd0eeed33593848e","path":"/notes/build/e33081bcd70c97f0bd0eeed33593848e.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"ttD3fneinZ"}],"visibility":"show","key":"viWA9LfH1w"}],"visibility":"show","key":"wXEtJI1YCc"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.metrics import accuracy_score, balanced_accuracy_score, recall_score, precision_score, f1_score\n\nprint(f\"\"\"\naccuracy: {accuracy_score(y_test, y_pred):.3g}\nbalanced_accuracy: {balanced_accuracy_score(y_test, y_pred):.3g}\nrecall: {recall_score(y_test, y_pred):.3g}\nprecision: {precision_score(y_test, y_pred):.3g}\nf1_score: {f1_score(y_test, y_pred):.3g}\n\"\"\")","visibility":"hide","key":"IqBOYTz97C"},{"type":"outputs","id":"6-g8cgSCxs9AqClclzqnR","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\naccuracy: 0.885\nbalanced_accuracy: 0.557\nrecall: 0.12\nprecision: 0.75\nf1_score: 0.207\n\n"},"children":[],"key":"QaMYpWznTH"}],"visibility":"show","key":"RlhOhyeu1N"}],"visibility":"show","key":"cjWywwApiQ"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import japanize_matplotlib\n\nx1_lim = (X[:, 0].min() * 1.1, X[:, 0].max() * 1.1)\nx2_lim = (X[:, 1].min() * 1.1, X[:, 1].max() * 1.1)\n\nX1, X2 = np.mgrid[x1_lim[0]:x1_lim[1]:1000j, x2_lim[0]:x2_lim[1]:1000j]\nX_range= np.append(X1.reshape(-1, 1), X2.reshape(-1, 1), axis=1)\nY = clf.predict(X_range).reshape(X1.shape)\n\nfig, ax = plt.subplots()\nax.contourf(X1, X2, Y, cmap='Paired', alpha=0.4)\n\nax.scatter(X[y == 0, 0], X[y == 0, 1], label=\"y == 0\", alpha=0.7)\nax.scatter(X[y == 1, 0], X[y == 1, 1], label=\"y == 1\", alpha=0.7)\n# ax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"Decision Boundary of Logistic Regression\")\nax.set(xlabel=\"x1\", ylabel=\"x2\", title=\"不均衡データで、うまく分類できていない場合\")\nax.legend()\nfig.show()","visibility":"hide","key":"zASAfC3eh4"},{"type":"outputs","id":"0blNXG4WReRxXYJT8_JkL","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"91ea2dd073ed78feb0a48c3a505596c6","path":"/notes/build/91ea2dd073ed78feb0a48c3a505596c6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"wpiCGPme5a"}],"visibility":"show","key":"fTz95Dn38S"}],"visibility":"show","key":"wvvy32CjZo"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"分類しやすいデータの場合","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bvcQbGpmD6"}],"identifier":"id","label":"分類しやすいデータの場合","html_id":"id-1","implicit":true,"key":"DrukRRZjEB"}],"key":"hGBULDo12P"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"X, y = gen_data(scale = 0.6, p_minority = 0.1)\nplot_data(X, y)","visibility":"hide","key":"CoBUwsCcSG"},{"type":"outputs","id":"TP9ZxSRVK-fplpX1ccRA4","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"584bfbc3d7765424cf83f905ccde8cb6","path":"/notes/build/584bfbc3d7765424cf83f905ccde8cb6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"l2E5420s3G"}],"visibility":"show","key":"qcWEdBM7EK"}],"visibility":"show","key":"NEoyz4ynzl"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n\nfrom sklearn.linear_model import LogisticRegression\nclf = LogisticRegression().fit(X_train, y_train)\ny_pred = clf.predict(X_test)\n\nfrom sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\ncm = confusion_matrix(y_test, y_pred, labels=clf.classes_)\ndisp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=clf.classes_)\ndisp.plot()\nplt.show()","visibility":"hide","key":"gQ2FImt36V"},{"type":"outputs","id":"5NyrSRZ5c5lxHthrI0EYV","children":[{"type":"output","jupyter_data":{"output_