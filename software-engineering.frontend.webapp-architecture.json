ing","depth":4,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"1. デフォルトの動作を防ぐ","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"s2CfPqc7MP"}],"identifier":"id-1","label":"1. デフォルトの動作を防ぐ","html_id":"id-1-1","implicit":true,"key":"eb3B22wakj"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"PESPA の核となる側面は、ルーティングとフォームに関してブラウザーとほぼ同じように動作すること。","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"XZyaf9pIVN"}],"key":"MdnOqFmnfO"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"それにより、MPAの（シンプルな）メンタルモデルを実現できる。","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"a39IOI6YJ5"}],"key":"uNNRPez0yK"},{"type":"heading","depth":4,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"2. コードの重複","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"LQRRfH38WI"}],"identifier":"id-2","label":"2. コードの重複","html_id":"id-2","implicit":true,"key":"yGNSi3mnzA"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"クライアントとサーバー間でコードを共有し、ブラウザーの動作をエミュレートする適切な抽象化を行うことで、コードの重複が回避され、また自分で記述しなければならないコードの量が大幅に削減される。","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"qFe2pQTZQ0"}],"key":"qV7R7q9zY3"},{"type":"heading","depth":4,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"3. コード構成がシンプル","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"sVDhuQhHOc"}],"identifier":"id-3","label":"3. コード構成がシンプル","html_id":"id-3","implicit":true,"key":"PWPKYO9m1D"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":2