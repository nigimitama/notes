tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"from scipy.stats import spearmanr\nimport matplotlib.pyplot as plt\nimport numpy as np\n\nfig, axes = plt.subplots(figsize=[10, 2.5], ncols=3)\n\ntrue_r = 0.75\nmu = np.array([0.0, 0.0])\nSigma = np.array([[1.0, true_r], [true_r, 1.0]])\nsamples = np.random.multivariate_normal(mu, Sigma, size=100)\nx = samples[:, 0]\ny = samples[:, 1]\naxes[0].scatter(x, y)\naxes[0].set_title(f\"Spearman's ρ = {spearmanr(x, y).statistic:.3f}\")\n\nx = np.linspace(-10, 10, 15)\ny = 1 / (1 + np.exp(-x))\naxes[1].scatter(x, y)\naxes[1].set_title(f\"Spearman's ρ = {spearmanr(x, y).statistic:.3f}\")\n\nx = np.linspace(-3.14,3.14, 100)\ny = x**2 + np.random.random(len(x))\naxes[2].scatter(x, y)\naxes[2].set_title(f\"Spearman's ρ = {spearmanr(x, y).statistic:.3f}\")\n\n%matplotlib inline","visibility":"hide","key":"Wt4FBVZ33t"},{"type":"outputs","id":"gZzGeidl0fD27q4Tz8IKF","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"bb956112c03a452154bbec87e8f833ac","path":"/notes/build/bb956112c03a452154bbec87e8f833ac.png"},"text/plain":{"content":"<Figure size 1000x250 with 3 Axes>","content_type":"text/plain"}}},"children":[],"key":"aNK9H4nEi2"}],"visibility":"show","key":"TPLASovpq4"}],"visibility":"show","key":"ru1PHmu0zp"}],"key":"tBkZz1ZOh1"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"非線形データの相関係数","url":"/statistics/correlation/nonlinear-correlation","group":"統計学"},"next":{"title":"Kendall の順位相関係数（Kendall’s τ）","url":"/statistics/correlation/nonlinear-correlation/kendall","group":"統計学"}}},"domain":"http://localhost:3000"}