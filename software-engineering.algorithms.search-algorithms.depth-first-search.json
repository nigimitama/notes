n></span></span>","key":"ZchaxMcNb6"},{"type":"text","value":" 。各ノードを高々1回訪問し、各エッジを高々1~2回訪問するため","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"gxPg3edtSp"}],"key":"AFYYPAiYJi"}],"key":"FSrO0yzE6Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def dfs(graph: dict[int, list[int]], start: int):\n    visited = set()  # 訪問済みの頂点を記録する\n\n    def _dfs(v):\n        visited.add(v)\n        print(f\"到達したnode: {v}, {visited=}\")\n\n        for next_v in graph[v]:\n            if next_v not in visited:\n                _dfs(next_v)\n\n    _dfs(start)\n\n\ngraph = {\n    0: [1, 2],\n    1: [0, 3, 4],\n    2: [0],\n    3: [1],\n    4: [1]\n}\ndfs(graph, 0)","key":"YP9BzTMro1"},{"type":"outputs","id":"hTmswXr856fhSsCRVBiTx","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"到達したnode: 0, visited={0}\n到達したnode: 1, visited={0, 1}\n到達したnode: 3, visited={0, 1, 3}\n到達したnode: 4, visited={0, 1, 3, 4}\n到達したnode: 2, visited={0, 1, 2, 3, 4}\n"},"children":[],"key":"mVh2t81Hqi"}],"key":"ZVNXbUBY9t"}],"key":"VQugTjhPIl"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"グラフのDFS（再帰なし）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yEBnjXTMMY"}],"identifier":"id-dfs","label":"グラフのDFS（再帰なし）","html_id":"id-dfs-1","implicit":true,"key":"IZ3nUVUYjc"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"stackを使うことで再帰関数を使わない実装もできる","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sa1wWmeXnH"}],"key":"ftPhdwv2Qq"}],"key":"Dbged54FIo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def dfs_iterative(graph, start):\n    visited = set()\n    stack = [start]\n\n    while stack:\n        v = stack.pop()\n\n        if v in visited:\n            continue\n\n        visited.add(v)\n        print(f\"到達したnode: {v}, {visited=}\")\n\n        for next_v in graph[v]:\n            if next_v not in visited:\n                stack.append(next_v)\n\ngraph = {\n    0: [1, 2], # 各頂点とつながる頂点たち\n    1: [0, 3, 4],\n    2: [0],\n    3: [1],\n    4: [1]\n}\ndfs_iterative(graph, 0)","key":"SvLCwdV2oL"},{"type":"outputs","id":"vQUdsn8OQHBCm8Pbu652w","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"到達したnode: 0, visited={0}\n到達したnode: 2, visited={0, 2}\n到達したnode: 1, visited={0, 1, 2}\n到達したnode: 4, visited={0, 1, 2, 4}\n到達したnode: 3, visited={0, 1, 2, 3, 4}\n"},"children":[],"key":"XG85a4DcRG"}],"key":"Hk7dMAyhkP"}],"key":"SXRbjtfs37"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from typing import List\n\n\ndef get_adjacent_nodes(edges: List[list]) -> List[list]:\n    \"\"\"各nodeと隣接したnodeのリストを作る\"\"\"\n    nodes = set(sum(edges, []))\n    adjacent_nodes = []\n    for node in nodes:\n        adjacent_node = []\n        for edge in edges:\n            if node in edge:\n                e = [e for e in edge if e != node][0]\n                adjacent_node.append(e)\n        adjacent_nodes.append(adjacent_node)\n    return adjacent_nodes\n\n\ndef dfs(edges: List[list]):\n    \"\"\"深さ優先探索（depth-first search）\"\"\"\n    adjacent_nodes = get_adjacent_nodes(edges)\n    n_edge: int = len(set(sum(edges,[])))\n    # その頂点を検知済みかどうかを表す配列\n    searched: List[bool] = [False] * n_edge\n    # 検知したがまだ訪問済みでない頂点の集合 (保留中の頂点の集合)\n    todo: List[int] = []\n    # root nodeをtodoに入れる\n    searched[0] = True\n    todo.append(0)\n    while len(todo) > 0:\n        target_node: int = todo.pop()\n        print(f\"searching a node '{target_node}'\")\n        for adj_node in adjacent_nodes[target_node]:\n            if not searched[adj_node]:\n                print(f\"{adj_node} is found and enqueued to todo\")\n                todo.append(adj_node)\n                searched[adj_node] = True\n\n\n# 隣接リスト表現 (adjacency-list representation)したグラフ\nedges: List[list] = [\n    [0, 1],  # 0 - 1 の辺\n    [0, 2],\n    [1, 3]\n]\ndfs(edges)","key":"T94XMD68lv"},{"type":"outputs","id":"LZCcoNoDVAA0iqedi69UY","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"searching a node '0'\n1 is found and enqueued to todo\n2 is found and enqueued to todo\nsearching a node '2'\nsearching a node '1'\n3 is found and enqueued to todo\nsearching a node '3'\n"},"children":[],"key":"jM6x1vOiUs"}],"key":"EXOdFXtQRe"}],"key":"uTSZDgRyqm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2次元グリッドでのDFS","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AU3YQmu9XV"}],"identifier":"id-2-dfs","label":"2次元グリッドでのDFS","html_id":"id-2-dfs","implicit":true,"key":"i4uexVMBVc"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"縦","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Yh02K93QY8"},{"type":"inlineMath","value":"H","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>H</mi></mrow><annotation encoding=\"application/x-tex\">H</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.08125em;\">H</span></span></span></span>","key":"J43BYUXYaf"},{"type":"text","value":"、横","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Bou0goKLrG"},{"type":"inlineMath","value":"W","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>W</mi></mrow><annotation encoding=\"application/x-tex\">W</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.13889em;\">W</span></span></span></span>","key":"Ana4Czy2dt"},{"type":"text","value":"のグリッドで、各マスを高々1回訪問するなら計算量は","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Gyg4IObXHP"},{"type":"inlineMath","value":"O(HW)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>H</mi><mi>W</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(HW)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\" style=\"margin-right:0.08125em;\">H</span><span class=\"mord mathnormal\" style=\"margin-right:0.13889em;\">W</span><span class=\"mclose\">)</span></span></span></span>","key":"IvR5IoTkNC"}],"key":"NOcF6SzyHX"}],"key":"BaR6E4sJjN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def dfs_grid(grid, start_i, start_j):\n    h = len(grid)\n    w = len(grid[0])\n\n    visited = [[False] * w for _ in range(h)]\n\n    def _dfs(i, j):\n        visited[i][j] = True\n        print(i, j)\n\n        # 隣接するマス（上下左右）を全部探索する\n        for di, dj in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n            ni = i + di  # 新しい座標\n            nj = j + dj\n\n            # 範囲外ならスキップ\n            if not (0 <= ni < h and 0 <= nj < w):\n                continue\n\n            # 壁ならスキップ\n            if grid[ni][nj] == \"#\":\n                continue\n\n            # 訪問済みならスキップ\n            if visited[ni][nj]:\n                continue\n\n            _dfs(ni, nj)\n\n    _dfs(start_i, start_j)","key":"ozFIDdXMQX"},{"type":"outputs","id":"FggP6fAHP3tR2seQICyeN","children":[],"key":"kliLBMtuPC"}],"key":"RtrxLyNXqn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"grid = [\n    \"...\",\n    \".#.\",\n    \"...\"\n]\n# .: 通れるマス\n# #: 通れないマス（壁）\ndfs_grid(grid, start_i=0, start_j=0)","key":"rxEHPs9XVd"},{"type":"outputs","id":"ReXyStGtmVRIAA9seZoxd","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"0 0\n1 0\n2 0\n2 1\n2 2\n1 2\n0 2\n0 1\n"},"children":[],"key":"b6ZHKopms0"}],"key":"cv5bHRyrQi"}],"key":"MBfA9o5MOi"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2次元グリッドでのDFS + バックトラックあり","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"drQgfFr295"}],"identifier":"id-2-dfs","label":"2次元グリッドでのDFS + バックトラックあり","html_id":"id-2-dfs-1","implicit":true,"key":"tJFsxVgCaU"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"通常のDFSでは一度探索した経路は再訪問しない（探索を目的とするので）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ij6fHmRJGz"}],"key":"iy1PLz6rXE"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"しかし、様々な経路をたどって最大の利得を得る問題などでは「一旦戻って別の経路を見る」という形で再訪問を許容することもある。その場合はバックトラックを入れる。","positi