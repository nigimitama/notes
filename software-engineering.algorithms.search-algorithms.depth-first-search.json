n></span></span>","key":"lVHhLLjlmo"},{"type":"text","value":" 。各ノードを高々1回訪問し、各エッジを高々1~2回訪問するため","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"nYKTDG0i6h"}],"key":"jFl4U6JQSC"}],"key":"un1ba5hmjn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def dfs(graph: dict[int, list[int]], start: int):\n    visited = set()  # 訪問済みの頂点を記録する\n\n    def _dfs(v):\n        visited.add(v)\n        print(f\"到達したnode: {v}, {visited=}\")\n\n        for next_v in graph[v]:\n            if next_v not in visited:\n                _dfs(next_v)\n\n    _dfs(start)\n\n\ngraph = {\n    0: [1, 2],\n    1: [0, 3, 4],\n    2: [0],\n    3: [1],\n    4: [1]\n}\ndfs(graph, 0)","key":"R5dcWi0Sm7"},{"type":"outputs","id":"VvYm_gFPFcRKxI7-x9dNY","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"到達したnode: 0, visited={0}\n到達したnode: 1, visited={0, 1}\n到達したnode: 3, visited={0, 1, 3}\n到達したnode: 4, visited={0, 1, 3, 4}\n到達したnode: 2, visited={0, 1, 2, 3, 4}\n"},"children":[],"key":"PvU2Rtx9lZ"}],"key":"avxrOZUcno"}],"key":"anITTN7DYv"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"グラフのDFS（再帰なし）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DOgsNG20xi"}],"identifier":"id-dfs","label":"グラフのDFS（再帰なし）","html_id":"id-dfs-1","implicit":true,"key":"jB96ORnVlb"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"stackを使うことで再帰関数を使わない実装もできる","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NsB19QIYhX"}],"key":"hc3mZTo6ec"}],"key":"tYtVijdh7q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def dfs_iterative(graph, start):\n    visited = set()\n    stack = [start]\n\n    while stack:\n        v = stack.pop()\n\n        if v in visited:\n            continue\n\n        visited.add(v)\n        print(f\"到達したnode: {v}, {visited=}\")\n\n        for next_v in graph[v]:\n            if next_v not in visited:\n                stack.append(next_v)\n\ngraph = {\n    0: [1, 2], # 各頂点とつながる頂点たち\n    1: [0, 3, 4],\n    2: [0],\n    3: [1],\n    4: [1]\n}\ndfs_iterative(graph, 0)","key":"WQq4UwFer4"},{"type":"outputs","id":"ZMbeU1J-e9jwxxA8GOIYE","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"到達したnode: 0, visited={0}\n到達したnode: 2, visited={0, 2}\n到達したnode: 1, visited={0, 1, 2}\n到達したnode: 4, visited={0, 1, 2, 4}\n到達したnode: 3, visited={0, 1, 2, 3, 4}\n"},"children":[],"key":"vge6ZjzyCQ"}],"key":"pa6Q608LrO"}],"key":"R3JERCfqfV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from typing import List\n\n\ndef get_adjacent_nodes(edges: List[list]) -> List[list]:\n    \"\"\"各nodeと隣接したnodeのリストを作る\"\"\"\n    nodes = set(sum(edges, []))\n    adjacent_nodes = []\n    for node in nodes:\n        adjacent_node = []\n        for edge in edges:\n            if node in edge:\n                e = [e for e in edge if e != node][0]\n                adjacent_node.append(e)\n        adjacent_nodes.append(adjacent_node)\n    return adjacent_nodes\n\n\ndef dfs(edges: List[list]):\n    \"\"\"深さ優先探索（depth-first search）\"\"\"\n    adjacent_nodes = get_adjacent_nodes(edges)\n    n_edge: int = len(set(sum(edges,[])))\n    # その頂点を検知済みかどうかを表す配列\n    searched: List[bool] = [False] * n_edge\n    # 検知したがまだ訪問済みでない頂点の集合 (保留中の頂点の集合)\n    todo: List[int] = []\n    # root nodeをtodoに入れる\n    searched[0] = True\n    todo.append(0)\n    while len(todo) > 0:\n        target_node: int = todo.pop()\n        print(f\"searching a node '{target_node}'\")\n        for adj_node in adjacent_nodes[target_node]:\n            if not searched[adj_node]:\n                print(f\"{adj_node} is found and enqueued to todo\")\n                todo.append(adj_node)\n                searched[adj_node] = True\n\n\n# 隣接リスト表現 (adjacency-list representation)したグラフ\nedges: List[list] = [\n    [0, 1],  # 0 - 1 の辺\n    [0, 2],\n    [1, 3]\n]\ndfs(edges)","key":"Y6fpfbXmzQ"},{"type":"outputs","id":"4VqQrpwguMv6xzXVRm6Pq","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"searching a node '0'\n1 is found and enqueued to todo\n2 is found and enqueued to todo\nsearching a node '2'\nsearching a node '1'\n3 is found and enqueued to todo\nsearching a node '3'\n"},"children":[],"key":"KhxpG6bcJd"}],"key":"uxuqT3z7dW"}],"key":"owdFDF5H9q"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2次元グリッドでのDFS","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"facnB3NENY"}],"identifier":"id-2-dfs","label":"2次元グリッドでのDFS","html_id":"id-2-dfs","implicit":true,"key":"ivgcs6xNp0"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"縦","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GDxRZ4LvJ8"},{"type":"inlineMath","value":"H","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>H</mi></mrow><annotation encoding=\"application/x-tex\">H</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.08125em;\">H</span></span></span></span>","key":"GEl7Besikh"},{"type":"text","value":"、横","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Q0