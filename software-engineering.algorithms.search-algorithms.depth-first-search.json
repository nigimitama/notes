       for di, dj in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n            ni = i + di  # 新しい座標\n            nj = j + dj\n\n            # 範囲外ならスキップ\n            if not (0 <= ni < h and 0 <= nj < w):\n                continue\n\n            # 壁ならスキップ\n            if grid[ni][nj] == \"#\":\n                continue\n\n            # 訪問済みならスキップ\n            if visited[ni][nj]:\n                continue\n\n            _dfs(ni, nj)\n\n    _dfs(start_i, start_j)","key":"ybTRAr3Pkb"},{"type":"outputs","id":"odnJAyGF7WHmOqVewIqAu","children":[],"key":"qyf4j9nCG7"}],"key":"mhIreDqE4i"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"grid = [\n    \"...\",\n    \".#.\",\n    \"...\"\n]\n# .: 通れるマス\n# #: 通れないマス（壁）\ndfs_grid(grid, start_i=0, start_j=0)","key":"CphavnQAt9"},{"type":"outputs","id":"5Sqh2e8arBHqCv2-64sLN","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"0 0\n1 0\n2 0\n2 1\n2 2\n1 2\n0 2\n0 1\n"},"children":[],"key":"Oy3PsiOAaE"}],"key":"nqD27e7pWv"}],"key":"fJZppm0HqH"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2次元グリッドでのDFS + バックトラックあり","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aTMZRQIoPN"}],"identifier":"id-2-dfs","label":"2次元グリッドでのDFS + バックトラックあり","html_id":"id-2-dfs-1","implicit":true,"key":"iI3kZvrwRp"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"通常のDFSでは一度探索した経路は再訪問しない（探索を目的とするので）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ULIvZdYM2i"}],"key":"zqkGoPvr5x"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"しかし、様々な経路をたどって最大の利得を得る問題などでは「一旦戻って別の経路を見る」という形で再訪問を許容することもある。その場合はバックトラックを入れる。","positi