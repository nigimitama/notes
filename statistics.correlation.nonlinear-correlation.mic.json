<mi>I</mi><mo stretchy=\"false\">(</mo><mi>X</mi><mo separator=\"true\">;</mo><mi>Y</mi><mo stretchy=\"false\">)</mo><mo>=</mo><mn>0</mn></mrow><annotation encoding=\"application/x-tex\">I(X;Y)=0</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">I</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"mpunct\">;</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.22222em;\">Y</span><span class=\"mclose\">)</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">0</span></span></span></span>","key":"FR0ufFSbI2"},{"type":"text","value":" なら ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"hkXSEPIxwR"},{"type":"strong","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"独立","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"PZBX5SpOlD"}],"key":"KJ6D7zGAat"}],"key":"xFSLK5qjaZ"}],"key":"cDiewz0PED"},{"type":"listItem","spread":true,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"線形・非線形を問わずあらゆる依存を検出","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"EGunprTajZ"}],"key":"PqmDN9lksr"}],"key":"ELureDJ5wT"},{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"ただし値域が固定されておらず、相関係数のように簡単には解釈できない","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"D4ILd0MNp5"}],"key":"CNghLJTh8e"}],"key":"zRnykGF1MX"},{"type":"listItem","spread":true,"position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"推定には KDE, kNN などが必要","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"pq1nHG6n4I"}],"key":"Z3os30qzTO"}],"key":"GBPnIJC2Ps"}],"key":"emHdMb5v3D"}],"key":"lVQwIWGAwj"},{"type":"block","kind":"notebook-code","data":{"jupyter":{"source_hidden":true},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nfrom sklearn.metrics import mutual_info_score # 離散型確率変数の相互情報量\n\ndef discretized_mi(x, y, bins=20):\n    # 連続変数を離散化して簡易的に相互情報量を求める\n    # x, y を bins 個の等幅ビンに離散化\n    x_binned = np.digitize(x, np.histogram_bin_edges(x, bins=bins))\n    y_binned = np.digitize(y, np.histogram_bin_edges(y, bins=bins))\n    \n    # 離散化した値で MI を計算\n    return mutual_info_score(x_binned, y_binned)\n\nimport matplotlib.pyplot as plt\nfig, axes = plt.subplots(figsize=[10, 2.5], ncols=3)\n\ntrue_r = 0\nmu = np.array([0.0, 0.0])\nSigma = np.array([[1.0, true_r], [true_r, 1.0]])\nsamples = np.random.multivariate_normal(mu, Sigma, size=100)\nx = samples[:, 0]\ny = samples[:, 1]\naxes[0].scatter(x, y)\naxes[0].set_title(f\"Mutual Info = {discretized_mi(x, y):.3f}\")\n\nx = np.linspace(-10, 10, 15)\ny = 1 / (1 + np.exp(-x))\naxes[1].scatter(x, y)\naxes[1].set_title(f\"Mutual Info = {discretized_mi(x, y):.3f}\")\n\nx = np.linspace(-3.14,3.14, 100)\ny = x**2 + np.random.random(len(x))\naxes[2].scatter(x, y)\naxes[2].set_title(f\"Mutual Info = {discretized_mi(x, y):.3f}\")\n\n%matplotlib inline","visibility":"hide","key":"tyiGg64RgG"},{"type":"outputs","id":"Ii6t9id13Tv_pv8hLB9is","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"baac8a60bd1b1c89d9c6424a67931e3e","path":"/notes/build/baac8a60bd1b1c89d9c6424a67931e3e.png"},"text/plain":{"content":"<Figure size 1000x250 with 3 Axes>","content_type":"text/plain"}}},"children":[],"key":"OJePJw1i8M"}],"visibility":"show","key":"B3apozFVPn"}],"visibility":"show","key":"BIOt1R5dS1"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"MIC（Maximal Information Coefficient）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"dNRPfe4lS8"}],"identifier":"mic-maximal-information-coefficient","label":"MIC（Maximal Information Coefficient）","html_id":"mic-maximal-information-coefficient","implicit":true,"key":"RT00dkbKNB"},{"type":"heading","depth":3,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"概念的な定義","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"iLeIfuejys"}],"identifier":"id","label":"概念的な定義","html_id":"id-2","implicit":true,"key":"PuAgQigAZa"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"散布図をさまざまな格子分割 ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"tuGtAdN628"},{"type":"inlineMath","value":"(x,y)","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">(</mo><mi>x</mi><mo separator=\"true\">,</mo><mi>y</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">(x,y)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">(</span><span class=\"mord ma