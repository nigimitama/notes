e":"inlineMath","value":"y","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi></mrow><annotation encoding=\"application/x-tex\">y</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.625em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span></span></span></span>","key":"MXqthPEAqG"},{"type":"text","value":"を予測する関数","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UE8Lrf6FbF"},{"type":"inlineMath","value":"f(x)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>f</mi><mo stretchy=\"false\">(</mo><mi>x</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">f(x)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.10764em;\">f</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">x</span><span class=\"mclose\">)</span></span></span></span>","key":"aKOONs078p"},{"type":"text","value":"を確率変数と見立てて、予測の不確実性を含めて複数の関数","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bNag4tIKTm"},{"type":"inlineMath","value":"f(x)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>f</mi><mo stretchy=\"false\">(</mo><mi>x</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">f(x)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.10764em;\">f</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">x</span><span class=\"mclose\">)</span></span></span></span>","key":"ikSM5jpUiR"},{"type":"text","value":"を学習するモデル","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ef1yRYK8ig"}],"key":"Nyp68daVms"}],"key":"EOdtcJQnSt"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"例","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wPsXCMZiKh"}],"identifier":"id","label":"例","html_id":"id","implicit":true,"key":"yj9vUG6cYm"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"link","url":"https://scikit-learn.org/stable/modules/gaussian_process.html","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"1.7. Gaussian Processes — scikit-learn 1.7.1 documentation","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jNQ24QMduw"}],"urlSource":"https://scikit-learn.org/stable/modules/gaussian_process.html","key":"bwiYsu5IEm"}],"key":"xabBw9PghH"}],"key":"QgsRnbmbIt"},{"type":"block","kind":"notebook-code","data":{"jupyter":{"source_hidden":true},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# ガウス過程回帰（Gaussian Process Regression, GPR）の例\n\n# 1) データを生成\n# from sklearn.datasets import make_regression\n# X, y = make_regression(n_samples=80, n_features=1, noise=12.0, random_state=42)\nimport numpy as np\nX = np.linspace(start=0, stop=10, num=1_000).reshape(-1, 1)\ny = np.squeeze(X * np.sin(X))\n\n\nrng = np.random.RandomState(0)\ntraining_indices = rng.choice(np.arange(y.size), size=6, replace=False)\nX_train, y_train = X[training_indices], y[training_indices]\n\n# 2) ガウス過程のカーネル設定\n# カーネルは Constant * RBF + WhiteKernel（典型的な選択）\nfrom sklearn.gaussian_process.kernels import RBF, WhiteKernel, ConstantKernel as C\nkernel = C(1.0, (1e-3, 1e3)) * RBF(length_scale=1.0, length_scale_bounds=(1e-2, 1e3)) \\\n         + WhiteKernel(noise_level=1.0, noise_level_bounds=(1e-5, 1e1))\n\n# 3) モデル学習\nfrom sklearn.gaussian_process import GaussianProcessRegressor\ngp = GaussianProcessRegressor(kernel=kernel, normalize_y=True, random_state=42)\ngp.fit(X_train, y_train)\n\n# 4) 予測（きれいな曲線を出すため細かいグリッド上で）\nimport matplotlib.pyplot as plt\nX_test = np.linspace(X.min() - 1.0, X.max() + 1.0, 400).reshape(-1, 1)\ny_mean, y_std = gp.predict(X_test, return_std=True)\ny_upper = y_mean + 1.96 * y_std  # 95%信頼帯\ny_lower = y_mean - 1.96 * y_std\n\n# 5) プロット\nmean_prediction, std_prediction = gp.predict(X, return_std=True)\nplt.plot(X, y, label=r\"$f(x) = x \\sin(x)$\", linestyle=\"dotted\")\nplt.scatter(X_train, y_train, label=\"Observations\")\nplt.plot(X, mean_prediction, label=\"Mean prediction\")\nplt.fill_between(\n    X.ravel(),\n    mean_prediction - 1.96 * std_prediction,\n    mean_prediction + 1.96 * std_prediction,\n    alpha=0.5,\n    label=r\"95% confidence interval\",\n)\nplt.legend()\nplt.xlabel(\"$x$\")\nplt.ylabel(\"$f(x)$\")\n_ = plt.title(\"Gaussian process regression on noise-free dataset\")\n","visibility":"hide","key":"mSRTMTFZt4"},{"type":"outputs","id":"DXPLacW1c2tkYlxnpGD--","children":[{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"/usr/local/lib/python3.10/site-packages/sklearn/gaussian_process/kernels.py:440: ConvergenceWarning: The optimal value found for dimension 0 of parameter k2__noise_level is close to the specified lower bound 1e-05. Decreasing the bound and calling fit again may find a better value.\n  warnings.warn(\n"},"children":[],"key":"IT7ZuQ0ng0"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"d1843e4b80741d561e393ab1d0ddbde9","path":"/notes/build/d1843e4b80741d561e393ab1d0ddbde9.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"JqcIg28VdH"}],"visibility":"show","key":"o2FY6wBmbz"}],"visibility":"show","key":"cYCfmdNWER"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"F1nuAd0C1M"}],"identifier":"id","label":"参考","html_id":"id-1","implicit":true,"key":"T4couzAae4"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://www.jstage.jst.go.jp/article/isciesci/62/10/62_390/_pdf","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"赤穂昭太郎. (2018). ガウス過程回帰の基礎. システム/制御/情報, 62(10), 390-395.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oiiOCNw5qU"}],"urlSource":"https://www.jstage.jst.go.jp/article/isciesci/62/10/62_390/_pdf","key":"FJH9BkILT3"}],"key":"SR4o7RvQf3"}],"key":"N5CActewgh"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"敬文金森. (2018). Pythonで学ぶ統計的機械学習. 株式会社 オーム社.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"aQ3VDD8ghk"}],"key":"YVYdb7qAb6"}],"key":"h5Rl2s27Cc"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://arxiv.org/abs/1807.02582","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"[1807.02582] Gaussian Processes and Kernel Methods: A Review on Connections and Equivalences","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"tevS059dcl"}],"urlSource":"https://arxiv.org/abs/1807.02582","key":"zdefUKIe9L"}],"key":"fjnrPNuGxi"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"評判の高い解説論文","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"J2fzGzvSrl"}],"key":"d6QdEuGapw"}],"key":"IIOBv6CGYt"}],"key":"U6mV1pkVIU"}],"key":"cdtz3DSVeS"}],"key":"bNkiIAjrTb"}],"key":"nA0dF8FWYl"}],"key":"nGIsi3F5Id"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"条件付き分布予測","url":"/machine-learning/uncertainty/distribution-prediction","group":"機械学習"},"next":{"title":"Adversarial Machine Learning：攻撃と防御","url":"/machine-learning/adversarial-ml","group":"機械学習"}}},"domain":"http://localhost:3000"}