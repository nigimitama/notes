"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"# --- Before: コメントで区切られた長い関数 ---\ndef print_owing(invoice):\n    outstanding = 0\n\n    # バナーの表示\n    print(\"***********************\")\n    print(\"**** Customer Owes ****\")\n    print(\"***********************\")\n\n    # 未払い金額の計算\n    for order in invoice[\"orders\"]:\n        outstanding += order[\"amount\"]\n\n    # 明細の表示\n    print(f\"name: {invoice['customer']}\")\n    print(f\"amount: {outstanding}\")","position":{"start":{"line":1,"column":1},"end":{"line":18,"column":1}},"key":"AE3hcdchNy"},{"type":"code","lang":"python","value":"# --- After: コメントを書きたくなった箇所が抽出の合図 ---\ndef print_owing(invoice):\n    print_banner()\n    outstanding = calculate_outstanding(invoice)\n    print_details(invoice, outstanding)\n\n\ndef print_banner():\n    print(\"***********************\")\n    print(\"**** Customer Owes ****\")\n    print(\"***********************\")\n\n\ndef calculate_outstanding(invoice):\n    return sum(order[\"amount\"] for order in invoice[\"orders\"])\n\n\ndef print_details(invoice, outstanding):\n    print(f\"name: {invoice['customer']}\")\n    print(f\"amount: {outstanding}\")","position":{"start":{"line":20,"column":1},"end":{"line":41,"column":1}},"key":"KhSPc146t2"}],"key":"EkRapKbrUt"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"変数の抽出／名前の変更","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"On61umpc30"}],"identifier":"id","label":"変数の抽出／名前の変更","html_id":"id-4","implicit":true,"key":"YKCpVmFr3T"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"複雑な式に名前を付けて意図を表す。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AySJ40cJOL"}],"key":"LyWyo8pucw"}],"key":"KhhiV3p0wS"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"# --- Before: 式の意味をコメントで説明している ---\ndef price(order):\n    # 価格 = 基本価格 - 数量割引 + 送料\n    return (order.quantity * order.item_price\n            - max(0, order.quantity - 500) * order.item_price * 0.05\n            + min(order.quantity * order.item_price * 0.1, 100))","position":{"start":{"line":1,"column":1},"end":{"line":8,"column":1}},"key":"zHjW6oThey"},{"type":"code","lang":"python","value":"# --- After: 名前がコメントの代わりになる ---\ndef price(order):\n    base_price = order.quantity * order.item_price\n    quantity_discount = max(0, order.quantity - 500) * order.item_price * 0.05\n    shipping = min(base_price * 0.1, 100)\n    return base_price - quantity_discount + shipping","position":{"start":{"line":10,"column":1},"end":{"line":17,"column":1}},"key":"u9eYOm8L8J"}],"key":"JTDjDeOstG"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"関数宣言の変更／パラメータオブジェクトの導入","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"t1b0bSKFAS"}],"identifier":"id","label":"関数宣言の変更／パラメータオブジェクトの導入","html_id":"id-5","implicit":true,"key":"gxzS4AqUp7"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"引数の追加・削除・名前変更。いつも一緒に渡されるデータの群れはオブジェクトにまとめる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pOMPvEDVr6"}],"key":"oGlHZOjePE"}],"key":"by6167ZiqU"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"from dataclasses import dataclass\nfrom datetime import date\n\n\n# --- Before: start_date, end_date がいつも一緒に現れる（データの群れ） ---\ndef amount_invoiced(start_date, end_date): ...\ndef amount_received(start_date, end_date): ...\ndef amount_overdue(start_date, end_date): ...","position":{"start":{"line":1,"column":1},"end":{"line":10,"column":1}},"key":"wwkE9IE67A"},{"type":"code","lang":"python","value":"# --- After: パラメータオブジェクトにまとめる ---\n@dataclass(frozen=True)\nclass DateRange:\n    start: date\n    end: date\n\n    def contains(self, d: date) -> bool:\n        return self.start <= d <= self.end\n\n\ndef amount_invoiced(period: DateRange): ...\ndef amount_received(period: DateRange): ...\ndef amount_overdue(period: DateRange): ...\n\n# クラスになると contains() のような振る舞いの置き場所もできる","position":{"start":{"line":12,"column":1},"end":{"line":28,"column":1}},"key":"sPXhpt11HQ"}],"key":"rbVF1FxeJU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"条件記述の分解／ガード節による入れ子の置き換え","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"M5hKqnEbFD"}],"identifier":"id","label":"条件記述の分解／ガード節による入れ子の置き換え","html_id":"id-6","implicit":true,"key":"UiHR1Xa6Vs"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"複雑な条件式を関数に抽出する。異常系は早期リターンで抜け、正常系のフローを平坦にする。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dvNuSoD39S"}],"key":"i7v6qnmB2b"}],"key":"tifllizHcG"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"# --- Before: 条件も分岐先も式のままで、意図が読み取りにくい ---\ndef pay_amount(employee):\n    if employee.is_separated:\n        result = {\"amount\": 0, \"reason\": \"SEP\"}\n    else:\n        if employee.is_retired:\n            result = {\"amount\": 0, \"reason\": \"RET\"}\n        else:\n            result = compute_normal_pay(employee)  # 本題のロジック\n    return result","position":{"start":{"line":1,"column":1},"end":{"line":12,"column":1}},"key":"nXBmwGHzp5"},{"type":"code","lang":"python","value":"# --- After: ガード節。異常系は早期リターンで抜け、正常系を平坦に ---\ndef pay_amount(employee):\n    if employee.is_separated:\n        return {\"amount\": 0, \"reason\": \"SEP\"}\n    if employee.is_retired:\n        return {\"amount\": 0, \"reason\": \"RET\"}\n    return compute_normal_pay(employee)\n\n\n# --- 条件記述の分解: 条件式そのものにも名前を付ける ---\n# Before\ndef charge(a_date, quantity, plan):\n    if a_date < plan.summer_start or a_date > plan.summer_end:\n        return quantity * plan.winter_rate + plan.winter_service_charge\n    return quantity * plan.summer_rate\n\n# After\ndef charge(a_date, quantity, plan):\n    if is_summer(a_date, plan):\n        return summer_charge(quantity, plan)\n    return winter_charge(quantity, plan)","position":{"start":{"line":14,"column":1},"end":{"line":36,"column":1}},"key":"i4M8RQBB6f"}],"key":"DlJlTlPkHq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ポリモーフィズムによる条件記述の置き換え","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Z41bx9Dir5"}],"identifier":"id","label":"ポリモーフィズムによる条件記述の置き換え","html_id":"id-7","implicit":true,"key":"Qkwwd1qbhP"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"型による switch / if の分岐をクラス階層（またはディスパッチ）に置き換える。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Z5O7jVGsST"}],"key":"YRWL0ZY8de"}],"key":"r6L4QELNju"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"# --- Before: 型で分岐する if の連鎖。種類が増えるたびに全分岐を修正 ---\ndef speed(bird):\n    if bird[\"type\"] == \"EuropeanSwallow\":\n        return 35\n    elif bird[\"type\"] == \"AfricanSwallow\":\n        return 40 - 2 * bird[\"number_of_coconuts\"]\n    elif bird[\"type\"] == \"NorwegianBlueParrot\":\n        return 0 if bird[\"is_nailed\"] else 10 + bird[\"voltage\"] / 10\n    else:\n        raise ValueError(bird[\"type\"])","position":{"start":{"line":1,"column":1},"end":{"line":12,"column":1}},"key":"ypbCHrb2Fw"},{"type":"code","lang":"python","value":"# --- After: 分岐の追加が「クラスの追加」に変わる（既存コードを触らない） ---\nclass EuropeanSwallow:\n    def speed(self):\n        return 35\n\n\nclass AfricanSwallow:\n    def __init__(self, number_of_coconuts):\n        self.number_of_coconuts = number_of_coconuts\n\n    def speed(self):\n        return 40 - 2 * self.number_of_coconuts\n\n\nclass NorwegianBlueParrot:\n    def __init__(self, voltage, is_nailed):\n        self.voltage = voltage\n        self.is_nailed = is_nailed\n\n    def speed(self):\n        return 0 if self.is_nailed else 10 + self.voltage / 10","position":{"start":{"line":14,"column":1},"end":{"line":36,"column":1}},"key":"h27hoUGXHA"}],"key":"cw948pWw1i"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ループの分離／パイプラインによるループの置き換え","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nRfJvw0V7M"}],"identifier":"id","label":"ループの分離／パイプラインによるループの置き換え","html_id":"id-8","implicit":true,"key":"xyUiHZVuU9"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"1つのループで複数のことをしない。内包表記や map / filter への置き換え。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Oq4wLvPV0j"}],"key":"SCmtBOxIxZ"}],"key":"hcI6bP2Rgb"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"# --- Before: 1つのループで2つの集計をしている ---\ndef summary(people):\n    total_age = 0\n    total_salary = 0\n    for p in people:\n        total_age += p.age\n        total_salary += p.salary\n    return total_age, total_salary","position":{"start":{"line":1,"column":1},"end":{"line":10,"column":1}},"key":"LBeiNRaQf7"},{"type":"code","lang":"python","value":"# --- After: ループを分離すると、それぞれを関数として抽出できる ---\ndef summary(people):\n    total_age = sum(p.age for p in people)\n    total_salary = sum(p.salary for p in people)\n    return total_age, total_salary\n\n\n# --- パイプラインによるループの置き換え ---\n# Before\nnames = []\nfor office in offices:\n    if office[\"country\"] == \"Japan\":\n        names.append(office[\"name\"])\n\n# After\nnames = [office[\"name\"] for office in offices if office[\"country\"] == \"Japan\"]","position":{"start":{"line":12,"column":1},"end":{"line":29,"column":1}},"key":"FcHODg8jHA"}],"key":"XaSyMSzwHF"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"問い合わせと更新の分離（コマンド・クエリ分離）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jg6xKoKdCz"}],"identifier":"id","label":"問い合わせと更新の分離（コマンド・クエリ分離）","html_id":"id-9","implicit":true,"key":"UUrEGBPZLP"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"値を返す関数は観察可能な副作用を持たないようにする。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YPfGBrP0Or"}],"key":"qfXMTpTIG6"}],"key":"xApEe7FqfH"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"# --- Before: 値を返しつつ副作用もある（問い合わせのつもりで呼ぶと警報が鳴る） ---\ndef alert_for_miscreant(people):\n    for p in people:\n        if p in (\"Don\", \"John\"):\n            set_off_alarms()\n            return p\n    return \"\"","position":{"start":{"line":1,"column":1},"end":{"line":9,"column":1}},"key":"PT6FGqfRcK"},{"type":"code","lang":"python","value":"# --- After: 問い合わせ（副作用なし）とコマンド（副作用あり）に分ける ---\ndef find_miscreant(people):\n    for p in people:\n        if p in (\"Don\", \"John\"):\n            return p\n    return \"\"\n\n\ndef alert_for_miscreant(people):\n    if find_miscreant(people):\n        set_off_alarms()","position":{"start":{"line":11,"column":1},"end":{"line":23,"column":1}},"key":"bY8Y39n0An"}],"key":"uQtBamSxxV"},{"type":"block","kind":"notebook-content