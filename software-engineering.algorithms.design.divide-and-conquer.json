(arr, target)\n    if idx >= 0:\n        print(f\"{target} は index {idx} に存在する\")\n    else:\n        print(f\"{target} は存在しない\")","key":"spkSGPkIJ0"},{"type":"outputs","id":"MVARs4yp-20u2uU8f0p2o","children":[],"key":"oybOPSFgff"}],"key":"kf98n3saeu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"例4: 最大部分配列問題（カダネ法の分割統治版）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qSms2jIkPR"}],"identifier":"id-4","label":"例4: 最大部分配列問題（カダネ法の分割統治版）","html_id":"id-4","implicit":true,"key":"BoNCPot3ND"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"配列中の連続する部分配列のうち、和が最大のものを求める。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UlnCBd056c"}],"key":"mBEi2tttlz"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"部分配列は以下の3つのいずれかに属する。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"d3K9CtrHfy"}],"key":"S03md03pjm"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"左半分のみに含まれる","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"QNajDof0lu"}],"key":"mlaodX4jmG"}],"key":"OofTKDRwql"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"右半分のみに含まれる","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"Qt9RQP6bOg"}],"key":"ZQMrWCUIIe"}],"key":"pTG2ZxvUTf"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"中央をまたぐ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"ifVeWY36HL"}],"key":"UkeoWRlyEv"}],"key":"oJ1B50P1Eu"}],"key":"UTJ4Id1wAq"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"中央をまたぐ場合の最大和は ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"nPAubnUFan"},{"type":"inlineMath","value":"O(n)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>n</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(n)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"O3Q4ujOZXc"},{"type":"text","value":" で求められる。","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"sFhLTnX5MK"}],"key":"T6j12U366P"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"計算量: ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"crO9YZrbgl"},{"type":"inlineMath","value":"O(n \\log n)","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>n</mi><mi>log</mi><mo>⁡</mo><mi>n</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(n \\log n)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mop\">lo<span style=\"margin-right:0.01389em;\">g</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"iIrUjW4tSn"}],"key":"nZnABzqFi2"}],"key":"MyX3WqTuSe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def max_crossing_sum(arr: list[int], lo: int, mid: int, hi: int) -> int:\n    left_sum = float('-inf')\n    total = 0\n    for i in range(mid, lo - 1, -1):\n        total += arr[i]\n        left_sum = max(left_sum, total)\n\n    right_sum = float('-inf')\n    total = 0\n    for i in range(mid + 1, hi + 1):\n        total += arr[i]\n        right_sum = max(right_sum, total)\n\n    return left_sum + right_sum\n\n\ndef max_subarray(arr: list[int], lo: int = 0, hi: int | None = None) -> int:\n    if hi is None:\n        hi = len(arr) - 1\n\n    if lo == hi:\n        return arr[lo]\n\n    mid = (lo + hi) // 2\n    return max(\n        max_subarray(arr, lo, mid),\n        max_subarray(arr, mid + 1, hi),\n        max_crossing_sum(arr, lo, mid, hi),\n    )\n\n\narr = [-2, 1, -3, 4, -1, 2, 1, -5, 4]\nprint(f\"配列: {arr}\")\nprint(f\"最大部分配列の和: {max_subarray(arr)}\")  # 期待値: 6 ([4,-1,2,1])","key":"zZDYLQRcFT"},{"type":"outputs","id":"OgH76jBai5QlO1KNV6jM_","children":[],"key":"qjHqLVjToN"}],"key":"DdaHdK31gW"}],"key":"l7C26jzWp9"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"動的計画法","url":"/software-engineering/algorithms/design/dynamic-programming","group":"ソフトウェア工学"},"next":{"title":"数学的なアルゴリズム","url":"/software-engineering/algorithms/mathematic-algorithms","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}