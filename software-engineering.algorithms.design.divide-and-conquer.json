(arr, target)\n    if idx >= 0:\n        print(f\"{target} は index {idx} に存在する\")\n    else:\n        print(f\"{target} は存在しない\")","key":"bWcsBuEgLS"},{"type":"outputs","id":"d7D8bkqIm5Sv47ELl1jbK","children":[],"key":"XeZ9Yg3gH8"}],"key":"hvsDUs8IYP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"例4: 最大部分配列問題（カダネ法の分割統治版）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VPy5ySvgfe"}],"identifier":"id-4","label":"例4: 最大部分配列問題（カダネ法の分割統治版）","html_id":"id-4","implicit":true,"key":"ZVMgRMuyxR"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"配列中の連続する部分配列のうち、和が最大のものを求める。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"eO2jA8wuSs"}],"key":"IwbYnDvMkt"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"部分配列は以下の3つのいずれかに属する。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"v7OHSQyPwf"}],"key":"BGBb8q1N8h"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"左半分のみに含まれる","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"vrutr0BYvd"}],"key":"EoB331ft7P"}],"key":"QlLJoy6Z19"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"右半分のみに含まれる","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"z46ks2a4Rt"}],"key":"FgvYgu8bl5"}],"key":"EYakjRApFS"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"中央をまたぐ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"tKiOyZHHIf"}],"key":"XorTSMtOCS"}],"key":"QuCambYAqg"}],"key":"c7UumIC9g1"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"中央をまたぐ場合の最大和は ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"YpSUcNckdD"},{"type":"inlineMath","value":"O(n)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>n</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(n)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"hShxc0WedP"},{"type":"text","value":" で求められる。","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"UhNCOZJPWm"}],"key":"J7hHglqxb8"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"計算量: ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"Na5iG3vV84"},{"type":"inlineMath","value":"O(n \\log n)","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>n</mi><mi>log</mi><mo>⁡</mo><mi>n</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(n \\log n)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mop\">lo<span style=\"margin-right:0.01389em;\">g</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"vv41gJlwAl"}],"key":"ubwGA2yBp1"}],"key":"h7SAVjCLjp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def max_crossing_sum(arr: list[int], lo: int, mid: int, hi: int) -> int:\n    left_sum = float('-inf')\n    total = 0\n    for i in range(mid, lo - 1, -1):\n        total += arr[i]\n        left_sum = max(left_sum, total)\n\n    right_sum = float('-inf')\n    total = 0\n    for i in range(mid + 1, hi + 1):\n        total += arr[i]\n        right_sum = max(right_sum, total)\n\n    return left_sum + right_sum\n\n\ndef max_subarray(arr: list[int], lo: int = 0, hi: int | None = None) -> int:\n    if hi is None:\n        hi = len(arr) - 1\n\n    if lo == hi:\n        return arr[lo]\n\n    mid = (lo + hi) // 2\n    return max(\n        max_subarray(arr, lo, mid),\n        max_subarray(arr, mid + 1, hi),\n        max_crossing_sum(arr, lo, mid, hi),\n    )\n\n\narr = [-2, 1, -3, 4, -1, 2, 1, -5, 4]\nprint(f\"配列: {arr}\")\nprint(f\"最大部分配列の和: {max_subarray(arr)}\")  # 期待値: 6 ([4,-1,2,1])","key":"SyMB6GDzsU"},{"type":"outputs","id":"Owur_38D6EZmRm9M__bGZ","children":[],"key":"fuumScbP5t"}],"key":"gGfrcp0Ckb"}],"key":"OU60fDSd71"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"動的計画法","url":"/software-engineering/algorithms/design/dynamic-programming","group":"ソフトウェア工学"},"next":{"title":"数学的なアルゴリズム","url":"/software-engineering/algorithms/mathematic-algorithms","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}