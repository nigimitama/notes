MD0r7"}],"key":"cGbSXa9fTF"}],"key":"qMgRthzrlM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport torch\nfrom torch import nn\nfrom torch.utils.data import DataLoader, Dataset\nfrom torchvision import datasets, transforms","key":"WoRtI7ydDM"},{"type":"outputs","id":"qSEPlCVo9TqJDs5Lwexhw","children":[],"key":"I5iHlxklpq"}],"key":"qvOmYFBuvW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"device = (\n    \"cuda\"\n    if torch.cuda.is_available()\n    else \"mps\"\n    if torch.backends.mps.is_available()\n    else \"cpu\"\n)\nprint(f\"Using {device} device\")","key":"tt8fUbtTgl"},{"type":"outputs","id":"0WDnwXg6Hz-aJC-nqUw5o","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Using cpu device\n"},"children":[],"key":"BhD9kvRIfJ"}],"key":"EgSNhG9lrl"}],"key":"srYbnL71Vi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class NeuralNetwork(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.flatten = nn.Flatten()\n        self.linear_relu_stack = nn.Sequential(\n            nn.Linear(2, 10),\n            nn.ReLU(),\n            nn.Linear(10, 10),\n            nn.ReLU(),\n            nn.Linear(10, 2),\n        )\n\n    def forward(self, x):\n        x = self.flatten(x)\n        logits = self.linear_relu_stack(x)\n        return logits\n\nmodel = NeuralNetwork().to(device)\nprint(model)","key":"t5bacl2YPB"},{"type":"outputs","id":"b-YrJ-yZQKvoYDbnEiq7v","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"NeuralNetwork(\n  (flatten): Flatten(start_dim=1, end_dim=-1)\n  (linear_relu_stack): Sequential(\n    (0): Linear(in_features=2, out_features=10, bias=True)\n    (1): ReLU()\n    (2): Linear(in_features=10, out_features=10, bias=True)\n    (3): ReLU()\n    (4): Linear(in_features=10, out_features=2, bias=True)\n  )\n)\n"},"children":[],"key":"MKBQ8oZ6Cu"}],"key":"EeAph7Etqm"}],"key":"AqqQw3Hrcl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nfrom sklearn.datasets import make_blobs\n\nclass MyDataset(Dataset):\n    def __init__(self, random_state=0):\n        centers = [(1, 1), (-1, -1)]\n        self.X, self.y = make_blobs(n_samples=10000, n_features=2, centers=centers, cluster_std=[0.5, 0.5], random_state=random_state)\n        # modelの重みはtorch.float32なので合わせる\n        self.X = self.X.astype(np.float32)\n\n    def __len__(self):\n        return self.X.shape[0]\n\n    def __getitem__(self, idx):\n        return self.X[idx, :], self.y[idx]\n\n\ndataset = MyDataset(random_state=0)\ndataloader = DataLoader(dataset, batch_size=1)\n\nfor X, y in dataloader:\n    print(f\"Shape of X [N, C, H, W]: {X.shape}\")\n    print(f\"Shape of y: {y.shape} {y.dtype}\")\n    break","key":"xPDl5oprtA"},{"type":"outputs","id":"jImZT7ny2g5XeLpQJCXbo","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Shape of X [N, C, H, W]: torch.Size([1, 2])\nShape of y: torch.Size([1]) torch.int64\n"},"children":[],"key":"YxwuwHUaQG"}],"key":"NDeZCVqeAe"}],"key":"cTSOonCVrp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots()\n\nfor y in set(dataset.y):\n    idx = dataset.y == y\n    ax.scatter(dataset.X[idx, 0], dataset.X[idx, 1], label=f\"y == {y}\", alpha=0.3)\nax.legend()\nfig.show()","key":"U4qEwYyavb"},{"type":"outputs","id":"kQJgnNxcbuJ-OW-GGRZDR","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"4023b42da3a27a77e17253740ba8a021","path":"/notes/build/4023b42da3a27a77e17253740ba8a021.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"lnikYFrI9s"}],"key":"C4IGWurWzq"}],"key":"yBF1QAUVEx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"learning_rate = 1e-3\nepochs = 5\nloss_fn = nn.CrossEntropyLoss()\noptimizer = torch.optim.SGD(model.parameters(), lr=learning_rate)\n\ndef train(dataloader, model, loss_fn, optimizer):\n    size = len(dataloader.dataset)\n    model.train()\n    for batch, (X, y) in enumerate(dataloader):\n        X, y = X.to(device), y.to(device)\n\n        # Compute prediction error\n        pred = model(X)\n        loss = loss_fn(pred, y)\n\n        # Backpropagation\n        loss.backward()\n        optimizer.step()\n        optimizer.zero_grad()\n\n        if batch % 1000 == 0:\n            loss, current = loss.item(), (batch + 1) * len(X)\n            print(f\"loss: {loss:>7f}  [{current:>5d}/{size:>5d}]\")","key":"hwnz6zBpKU"},{"type":"outputs","id":"2mwuaYufjBgV4wrYYZUXj","children":[],"key":"KtL40XNL2O"}],"key":"t4vHfJIjk3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"train(dataloader, model, loss_fn, optimizer)","key":"T1kH7xAgI6"},{"type":"outputs","id":"HEFzk0RavzmenODWyaviu","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"loss: 1.285138  [    1/10000]\nloss: 0.016027  [ 1001/10000]\nloss: 0.093124  [ 2001/10000]\nloss: 0.030537  [ 3001/10000]\nloss: 0.000748  [ 4001/10000]\nloss: 0.028218  [ 5001/10000]\nloss: 0.044488  [ 6001/10000]\nloss: 0.006413  [ 7001/10000]\nloss: 0.007662  [ 8001/10000]\nloss: 0.000128  [ 9001/10000]\n"},"children":[],"key":"LGaLETY4wp"}],"key":"zTYzGNPVMa"}],"key":"u7mXcSt9rt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def test(dataloader, model, loss_fn):\n    size = len(dataloader.dataset)\n    num_batches = len(dataloader)\n    model.eval()\n    test_loss, correct = 0, 0\n    with torch.no_grad():\n        for X, y in dataloader:\n            X, y = X.to(device), y.to(device)\n            pred = model(X)\n            test_loss += loss_fn(pred, y).item()\n            correct += (pred.argmax(1) == y).type(torch.float).sum().item()\n    test_loss /= num_batches\n    correct /= size\n    print(f\"Test Error: \\n Accuracy: {(100*correct):>0.1f}%, Avg loss: {test_loss:>8f} \\n\")","key":"QE3sDMrKth"},{"type":"outputs","id":"7tlLkgeG6dfwPbogGhxOE","children":[],"key":"kDHeDAw9BJ"}],"key":"jX8w3dGsPD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dataset = MyDataset(random_state=1)\ntest_dataloader = DataLoader(dataset, batch_size=1)\ntest(test_dataloader, model, loss_fn)","key":"vdfL8hJlXY"},{"type":"outputs","id":"MlVC01qDZ841AwaVmNQfr","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Test Error: \n Accuracy: 99.6%, Avg loss: 0.017850 \n\n"},"children":[],"key":"M311EuTZZW"}],"key":"XnyrP0OkrB"}],"key":"xyO3HRKCin"}],"key":"wrUXXnhtYi"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Deep Neural Network","url":"/machine-learning/deep-learning/dnn","group":"機械学習"},"next":{"title":"CNN","url":"/machine-learning/deep-learning/cnn","group":"機械学習"}}},"domain":"http://localhost:3000"}