nt):\n        event = {\n            \"type\": \"MoneyWithdrawn\",\n            \"amount\": amount,\n            \"timestamp\": datetime.now()\n        }\n        self._apply_event(event)\n        self.events.append(event)\n    \n    def _apply_event(self, event):\n        if event[\"type\"] == \"MoneyDeposited\":\n            self.balance += event[\"amount\"]\n        elif event[\"type\"] == \"MoneyWithdrawn\":\n            self.balance -= event[\"amount\"]\n    \n    def rebuild_from_events(self, events):\n        for event in events:\n            self._apply_event(event)","position":{"start":{"line":28,"column":1},"end":{"line":62,"column":1}},"key":"ySgrOoYL7V"},{"type":"heading","depth":3,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"3. CQRS（Command Query Responsibility Segregation）","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"s4gmYxZRfC"}],"identifier":"id-3-cqrs-command-query-responsibility-segregation","label":"3. CQRS（Command Query Responsibility Segregation）","html_id":"id-3-cqrs-command-query-responsibility-segregation","implicit":true,"key":"EdEHcb2TXq"},{"type":"paragraph","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"コマンド（書き込み）とクエリ（読み込み）のモデルを分離。","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"XCc5VkDnhE"}],"key":"yE5t25vQij"},{"type":"paragraph","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"詳細は別ページ参照。","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"UUVmw3Uu8E"}],"key":"lfGfbE5WvY"}],"key":"Ywvsr1Qc67"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"実装例","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key