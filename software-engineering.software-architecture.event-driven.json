 elif event.event_type == \"OrderShipped\":\n            customer_id = event.data[\"customer_id\"]\n            self._send_email(customer_id, \"Order Shipped\")\n\n# コンシューマー3: 分析\nclass AnalyticsEventHandler:\n    def handle(self, event):\n        # すべてのイベントを分析DBに保存\n        self._save_to_analytics_db(event)","position":{"start":{"line":5,"column":1},"end":{"line":68,"column":1}},"key":"PCDF6SVR1D"}],"key":"fLF5J7Ac7w"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"メリット","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"io4JI55S4z"}],"identifier":"id","label":"メリット","html_id":"id-5","implicit":true,"key":"UM3llfmrSk"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"疎結合","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"LpUNKojvtY"}],"key":"g8StsLDQPe"},{"type":"text","value":": プロデューサーとコンシューマーが互いを知らない","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wOvZ7vIrjQ"}],"key":"rX0J2hVkpu"}],"key":"ZQVUsoknxz"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"スケーラビリティ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"KZ1Aeec7iB"}],"key":"jwf1d2duHN"},{"type":"text","value":": コンシューマーを独立してスケール可能","position":{"start":{"line":4,"column":1},"end":{"li