>=</mo><mi>A</mi><mi>s</mi></mrow><annotation encoding=\"application/x-tex\">x = As</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">x</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\">A</span><span class=\"mord mathnormal\">s</span></span></span></span>","key":"QCDh4DzwUn"},{"type":"text","value":" の尤度を最大化するアプローチも存在する。","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"eJt2QNqBPW"}],"key":"KUsh8U9HTy"}],"key":"puFlgqvN8K"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Pythonでの実装","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Zpha5dC61b"}],"identifier":"python","label":"Pythonでの実装","html_id":"python","implicit":true,"key":"LaaRrtn7sq"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"scikit-learnにはFastICAなどの高速なアルゴリズムが実装されている","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"c1PbSprWFQ"}],"key":"cdUEcLxOfZ"}],"key":"QBU5cjsfPF"},{"type":"block","kind":"notebook-code","data":{"jupyter":{"source_hidden":true},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom sklearn.decomposition import FastICA\n\n# -----------------------\n# 1) 元の独立信号を作る\n# -----------------------\nnp.random.seed(0)\nn_samples = 2000\nt = np.linspace(0, 8, n_samples)\n\ns1 = np.sin(2 * t)                          # 独立信号1: 正弦波\ns2 = np.sign(np.sin(3 * t))                 # 独立信号2: 矩形波（sign）\n\nS = np.c_[s1, s2]\nS /= S.std(axis=0)  # 標準化（ICAの慣習）\n\n# -----------------------\n# 2) 混合行列Aで混合する\n# -----------------------\nA = np.array([[0.5, 0.9],\n              [0.3, 0.7]])   # 任意の mixing matrix\n\nX = S @ A.T  # 観測信号（ミックスされた信号）\n\n# -----------------------\n# 3) FastICA で分離\n# -----------------------\nica = FastICA(n_components=2, random_state=0)\nS_ica = ica.fit_transform(X)  # 推定された独立成分\nA_est = ica.mixing_           # 推定 mixing matrix\nW_est = ica.components_       # unmixing (分離) 行列\n\n# -----------------------\n# 4) 図示\n# -----------------------\nplt.figure(figsize=(6, 4))\n\nplt.subplot(3, 1, 1)\nplt.title(\"Original independent signals (S)\")\nplt.plot(t, S[:, 0], label=\"s1\")\nplt.plot(t, S[:, 1], label=\"s2\")\nplt.legend()\n\nplt.subplot(3, 1, 2)\nplt.title(\"Mixed signals (X)\")\nplt.plot(t, X[:, 0], label=\"x1\")\nplt.plot(t, X[:, 1], label=\"x2\")\nplt.legend()\n\nplt.subplot(3, 1, 3)\nplt.title(\"Recovered signals by FastICA (S_ica)\")\nplt.plot(t, S_ica[:, 0], label=\"ica1\")\nplt.plot(t, S_ica[:, 1], label=\"ica2\")\nplt.legend()\n\nplt.tight_layout()\nplt.show()\n","visibility":"hide","key":"VV0OXaW3mk"},{"type":"outputs","id":"oX8Rl2LY-K8ZDE_3k6iKE","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"ed4779a5b8b0f21a2bd5c60a0f485cf4","path":"/notes/build/ed4779a5b8b0f21a2bd5c60a0f485cf4.png"},"text/plain":{"content":"<Figure size 600x400 with 3 Axes>","content_type":"text/plain"}}},"children":[],"key":"EXCyFkHUIt"}],"visibility":"show","key":"Gmo2PBezEL"}],"visibility":"show","key":"LMNoylUHdM"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Aの推定","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"s4TmMNJDKr"}],"identifier":"a","label":"Aの推定","html_id":"a","implicit":true,"key":"oRrBsMJeMk"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"混合行列","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vY6XFvI4I8"},{"type":"inlineMath","value":"A","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>A</mi></mrow><annotation encoding=\"application/x-tex\">A</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\">A</span></span></span></span>","key":"Mqs5lUqYzV"},{"type":"text","value":"の推定結果","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lPIlWZjFou"}],"key":"wFmvR3MipX"}],"key":"LmvtlEP0VP"},{"type":"block","kind":"notebook-code","data":{"jupyter":{"source_hidden":true},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# ======================\n# 列の最適割当（Permutation 補正）\n# ======================\n# Frobenius 距離のコスト行列を作る\ncost = np.zeros((2, 2))\nfor i in range(2):\n    for j in range(2):\n        # A_est の列 j を A の列 i に合わせたときの誤差\n        cost[i, j] = np.linalg.norm(A[:, i] - A_est[:, j])\n\n# Hungarian algorithm\nfrom scipy.optimize import linear_sum_assignment\nrow_ind, col_ind = linear_sum_assignment(cost)\n\n# 列を並べ替え\nA_est = A_est[:, col_ind]\n\nprint(f\"\"\"\n予測値：\n{A_est.round(2)}\n\n真値：\n{A.round(2)}\n\"\"\")","visibility":"hide","key":"LExV5DDlYn"},{"type":"outputs","id":"uB2ZGj2Qp7uGnMNHTjrmS","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\n予測値：\n[[0.53 0.93]\n [0.32 0.72]]\n\n真値：\n[[0.5 0.9]\n [0.3 0.7]]\n\n"},"children":[],"key":"ybTCdXESXD"}],"visibility":"show","key":"kKw6f3NWza"}],"visibility":"show","key":"JLDPLUVMlR"}],"key":"OyxZgtOoCw"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"主成分分析","url":"/machine-learning/unsupervised-learning/pca","group":"機械学習"},"next":{"title":"t-SNE","url":"/machine-learning/unsupervised-learning/t-sne","group":"機械学習"}}},"domain":"http://localhost:3000"}