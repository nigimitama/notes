y":"nUHg4qJhAE"}],"key":"p0Tij05Tpg"}],"key":"OVY8h6bVQM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def is_power_of_2(n: int) -> bool:\n    return n > 0 and (n & (n - 1)) == 0\n\ndef lsb(n: int) -> int:\n    \"\"\"最下位の立っているビットを取り出す\"\"\"\n    return n & (-n)\n\ndef popcount(n: int) -> int:\n    return bin(n).count('1')\n\n# 2の累乗判定\nfor n in [0, 1, 2, 3, 4, 6, 8, 16]:\n    print(f\"is_power_of_2({n:2d}) = {is_power_of_2(n)}\")\n\nprint()\n\n# LSB\nn = 0b10110  # 22\nprint(f\"n   = {n:05b} ({n})\")\nprint(f\"LSB = {lsb(n):05b} ({lsb(n)})\")\n\nprint()\n\n# ポップカウント\nfor n in [0b0000, 0b1010, 0b1111, 255]:\n    print(f\"popcount({n:08b}) = {popcount(n)}\")","key":"Qb7UtoB1QL"},{"type":"outputs","id":"A6uHRo1J5lIFwTvoc7fB3","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"is_power_of_2( 0) = False\nis_power_of_2( 1) = True\nis_power_of_2( 2) = True\nis_power_of_2( 3) = False\nis_power_of_2( 4) = True\nis_power_of_2( 6) = False\nis_power_of_2( 8) = True\nis_power_of_2(16) = True\n\nn   = 10110 (22)\nLSB = 00010 (2)\n\npopcount(00000000) = 0\npopcount(00001010) = 2\npopcount(00001111) = 4\npopcount(11111111) = 8\n"},"children":[],"key":"bLrjCJFanM"}],"key":"IBlF434Ltk"}],"key":"w656664qTk"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：部分集合の列挙（ビット全探索）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kky9ihMDFm"}],"identifier":"id","label":"応用：部分集合の列挙（ビット全探索）","html_id":"id-4","implicit":true,"key":"iJhSSPJdB3"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"n 個の要素からなる集合の全部分集合を ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NgdFj6OTu7"},{"type":"inlineCode","value":"0","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pPGS3XbwWC"},{"type":"text","value":" から ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"X2IV7qOYDX"},{"type":"inlineCode","value":"2^n - 1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vbwGzzwMqz"},{"type":"text","value":" までのビット列で表現する。各ビットが「その要素を選ぶかどうか」に対応する。計算量は O(2^n)。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yZYIC1IbVM"}],"key":"Cr5isaulkA"}],"key":"Xv7R9vz8Ug"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"items = [\"A\", \"B\", \"C\"]\nn = len(items)\n\nprint(\"全部分集合:\")\nfor mask in range(1 << n):\n    subset = [items[i] for i in range(n) if (mask >> i) & 1]\n    print(f\"  {mask:03b} -> {subset}\")\n\nprint()\n\n# 応用例: 合計がちょうど target になる部分集合を列挙\nvalues = [1, 3, 5, 7]\ntarget = 8\nn = len(values)\n\nprint(f\"values={values}, target={target} になる部分集合:\")\nfor mask in range(1 << n):\n    subset = [values[i] for i in range(n) if (mask >> i) & 1]\n    if sum(subset) == target:\n        print(f\"  {subset}\")","key":"luBO4uBjmM"},{"type":"outputs","id":"qZ7Fc3BXtWsEwk0N1r5iS","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"全部分集合:\n  000 -> []\n  001 -> ['A']\n  010 -> ['B']\n  011 -> ['A', 'B']\n  100 -> ['C']\n  101 -> ['A', 'C']\n  110 -> ['B', 'C']\n  111 -> ['A', 'B', 'C']\n\nvalues=[1, 3, 5, 7], target=8 になる部分集合:\n  [3, 5]\n  [1, 7]\n"},"children":[],"key":"MJwZHJEPpW"}],"key":"VZNZ3acIqg"}],"key":"INwGn3giCs"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：ビット DP","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hdtmFAMQZN"}],"identifier":"id-dp","label":"応用：ビット DP","html_id":"id-dp","implicit":true,"key":"gVaZBkVA2H