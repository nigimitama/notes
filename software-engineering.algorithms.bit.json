y":"PKpjwmDf0p"}],"key":"FaVw638kTU"}],"key":"ltqenuvOLw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def is_power_of_2(n: int) -> bool:\n    return n > 0 and (n & (n - 1)) == 0\n\ndef lsb(n: int) -> int:\n    \"\"\"最下位の立っているビットを取り出す\"\"\"\n    return n & (-n)\n\ndef popcount(n: int) -> int:\n    return bin(n).count('1')\n\n# 2の累乗判定\nfor n in [0, 1, 2, 3, 4, 6, 8, 16]:\n    print(f\"is_power_of_2({n:2d}) = {is_power_of_2(n)}\")\n\nprint()\n\n# LSB\nn = 0b10110  # 22\nprint(f\"n   = {n:05b} ({n})\")\nprint(f\"LSB = {lsb(n):05b} ({lsb(n)})\")\n\nprint()\n\n# ポップカウント\nfor n in [0b0000, 0b1010, 0b1111, 255]:\n    print(f\"popcount({n:08b}) = {popcount(n)}\")","key":"Xt2PTR0s8H"},{"type":"outputs","id":"f7tvqkfG69ja61VDNLpNr","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"is_power_of_2( 0) = False\nis_power_of_2( 1) = True\nis_power_of_2( 2) = True\nis_power_of_2( 3) = False\nis_power_of_2( 4) = True\nis_power_of_2( 6) = False\nis_power_of_2( 8) = True\nis_power_of_2(16) = True\n\nn   = 10110 (22)\nLSB = 00010 (2)\n\npopcount(00000000) = 0\npopcount(00001010) = 2\npopcount(00001111) = 4\npopcount(11111111) = 8\n"},"children":[],"key":"u1H9sXTzAb"}],"key":"LgOjOuw50r"}],"key":"oKX1VtyZRG"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：部分集合の列挙（ビット全探索）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AJX1azuJsB"}],"identifier":"id","label":"応用：部分集合の列挙（ビット全探索）","html_id":"id-4","implicit":true,"key":"Cl7pXXcL9N"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"n 個の要素からなる集合の全部分集合を ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AYrYvNvG5z"},{"type":"inlineCode","value":"0","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"nHV6GorYZx"},{"type":"text","value":" から ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"VHgkKl2ct8"},{"type":"inlineCode","value":"2^n - 1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ozz2KIUcCx"},{"type":"text","value":" までのビット列で表現する。各ビットが「その要素を選ぶかどうか」に対応する。計算量は O(2^n)。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"uaF5Yk9Mv0"}],"key":"j0dfcnU1E6"}],"key":"DCJ50kwO5y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"items = [\"A\", \"B\", \"C\"]\nn = len(items)\n\nprint(\"全部分集合:\")\nfor mask in range(1 << n):\n    subset = [items[i] for i in range(n) if (mask >> i) & 1]\n    print(f\"  {mask:03b} -> {subset}\")\n\nprint()\n\n# 応用例: 合計がちょうど target になる部分集合を列挙\nvalues = [1, 3, 5, 7]\ntarget = 8\nn = len(values)\n\nprint(f\"values={values}, target={target} になる部分集合:\")\nfor mask in range(1 << n):\n    subset = [values[i] for i in range(n) if (mask >> i) & 1]\n    if sum(subset) == target:\n        print(f\"  {subset}\")","key":"gyk2IC6bYW"},{"type":"outputs","id":"2pKueblWWbFHCPmz3NMeR","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"全部分集合:\n  000 -> []\n  001 -> ['A']\n  010 -> ['B']\n  011 -> ['A', 'B']\n  100 -> ['C']\n  101 -> ['A', 'C']\n  110 -> ['B', 'C']\n  111 -> ['A', 'B', 'C']\n\nvalues=[1, 3, 5, 7], target=8 になる部分集合:\n  [3, 5]\n  [1, 7]\n"},"children":[],"key":"UNbBLDZhJN"}],"key":"NF8J6PS1Ej"}],"key":"RvAoVCGmLq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：ビット DP","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wtVWUKiBmy"}],"identifier":"id-dp","label":"応用：ビット DP","html_id":"id-dp","implicit":true,"key":"EiByauWrwq"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"状態を集合（ビット列）で表すDPをビットDPという。典型例として巡回セールスマン問題（TSP）がある。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lQtISHOkM1"}],"key":"sw44sTJYBb"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"inlineCode","value":"dp[S][v]","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"vD3OcR9W6G"},{"type":"text","value":" = 頂点集合 S を訪問済みで、現在頂点 v にいるときの最小コスト。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"ALYBpvLjDO"}],"key":"Tify0ISUav"},{"type":"math","value":"dp[S | (1 << u)][u] = \\min(dp[S | (1 << u)][u], \\; dp[S][v] + \\text{cost}[v][u])","position":{"start":{"line":7,"column":1},"end":{"line":9,"column":1}},"html":"<span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" display=\"block\"><semantics><mrow><mi>d</mi><mi>p</mi><mo stretchy=\"false\">[</mo><mi>S</mi><mi mathvariant=\"normal\">∣</mi><mo stretchy=\"false\">(</mo><mn>1</mn><mo>&lt;</mo><mo>&lt;</mo><mi>u</mi><mo stretchy=\"false\">)</mo><mo stretchy=\"false\">]</mo><mo stretchy=\"false\">[</mo><mi>u</mi><mo stretchy=\"false\">]</mo><mo>=</mo><mi>min</mi><mo>⁡</mo><mo stretchy=\"false\">(</mo><mi>d</mi><mi>p</mi><mo stretchy=\"false\">[</mo><mi>S</mi><mi mathvariant=\"normal\">∣</mi><mo stretchy=\"false\">(</mo><mn>1</mn><mo>&lt;</mo><mo>&lt;</mo><mi>u</mi><mo stretchy=\"false\">)</mo><mo stretchy=\"false\">]</mo><mo stretchy=\"false\">[</mo><mi>u</mi><mo stretchy=\"false\">]</mo><mo separator=\"true\">,</mo><mtext>  </mtext><mi>d</mi><mi>p</mi><mo stretchy=\"false\">[</mo><mi>S</mi><mo stretchy=\"false\">]</mo><mo stretchy=\"false\">[</mo><mi>v</mi><mo stretchy=\"false\">]</mo><mo>+</mo><mtext>cost</mtext><mo stretchy=\"false\">[</mo><mi>v</mi><mo stretchy=\"false\">]</mo><mo stretchy=\"false\">[</mo><mi>u</mi><mo stretchy=\"false\">]</mo><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">dp[S | (1 &lt;&lt; u)][u] = \\min(dp[S | (1 &lt;&lt; u)][u], \\; dp[S][v] + \\text{cost}[v][u])</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">d</span><span class=\"mord mathnormal\">p</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\" style=\"margin-right:0.05764em;\">S</span><span class=\"mord\">∣</span><span class=\"mopen\">(</span><span class=\"mord\">1</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">&lt;&lt;</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">u</span><span class=\"mclose\">)]</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\">u</span><span class=\"mclose\">]</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mop\">min</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">d</span><span class=\"mord mathnormal\">p</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\" style=\"margin-right:0.05764em;\">S</span><span class=\"mord\">∣</span><span class=\"mopen\">(</span><span class=\"mord\">1</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">&lt;&lt;</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">u</span><span class=\"mclose\">)]</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\">u</span><span class=\"mclose\">]</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\">d</span><span class=\"mord mathnormal\">p</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\" style=\"margin-right:0.05764em;\">S</span><span class=\"mclose\">]</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">v</span><span class=\"mclose\">]</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord text\"><span class=\"mord\">cost</span></span><span class=\"mopen\">[</span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">v</span><span class=\"mclose\">]</span><span class=\"mopen\">[</span><span class=\"mord mathnormal\">u</span><span class=\"mclose\">])</span></span></span></span></span>","enumerator":"1","key":"wvCBSqA6ht"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"計算量: O(2^n × n^2)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"i3SRT3y4OT"}],"key":"A8TD6W1mXl"}],"key":"CNYK8VJp9n"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import math\n\ndef tsp(cost: list[list[int]]) -> int:\n    \"\"\"TSP: 全頂点を1度ずつ巡回して0に戻る最小コスト\"\"\"\n    n = len(cost)\n    INF = math.inf\n    # dp[mask][v]: mask の頂点を訪問済みで現在 v にいる最小コスト\n    dp = [[INF] * n for _ in range(1 << n)]\n    dp[1][0] = 0  # 頂点0からスタート（bit 0 が立った状態）\n\n    for S in range(1 << n):\n        for v in range(n):\n            if dp[S][v] == INF:\n                continue\n            if not (S >> v) & 1:\n                continue\n            for u in range(n):\n                if (S >> u) & 1:\n                    continue  # 既訪問\n                nS = S | (1 << u)\n                dp[nS][u] = min(dp[nS][u], dp[S][v] + cost[v][u])\n\n    full = (1 << n) - 1\n    return min(dp[full][v] + cost[v][0] for v in range(1, n))\n\n# 4頂点の例\ncost = [\n    [0, 2, 9, 10],\n    [1, 0, 6,  4],\n    [15, 7, 0, 8],\n    [6, 3, 12, 0],\n]\nprint(f\"TSP最小コスト: {tsp(cost)}\")  # 期待値: 21","key":"DBVWkIHQpU"},{"type":"outputs","id":"yvkZroRcaynn9WshdMQJD","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"TSP最小コスト: 21\n"},"children":[],"key":"G7Fbuy5j3Z"}],"key":"gPsEL7ydiX"}],"key":"jS1rs88XXJ"}],"key":"MuoljBKot2"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"数学的なアルゴリズム","url":"/software-engineering/algorithms/mathematic-algorithms","group":"ソフトウェア工学"},"next":{"title":"プログラミング","url":"/software-engineering/programming","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}