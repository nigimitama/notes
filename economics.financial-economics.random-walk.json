ey":"ONgbFV9JVF"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"ランダムウォークは代表的な単位根過程、すなわち、その差分系列が定常過程となる確率過程である。","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"YC2wXGyRA0"}],"key":"rIbMsv7Hu7"}],"key":"elqkOHZpOg"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"データ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qhBxkk8vWM"}],"identifier":"id","label":"データ","html_id":"id-2","implicit":true,"key":"J2ZWzA4MEU"}],"key":"NnAY4S5ovp"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport japanize_matplotlib\nimport seaborn as sns\nimport yfinance as yf\n\nticker = yf.Ticker(\"^N225\")\ndf = ticker.history(period=\"5y\")\nprices = df[\"Close\"]\nreturns = prices.pct_change(1)\n\nfig, axes = plt.subplots(ncols=2, figsize=[8, 2])\naxes[0].hist(prices, bins=30)\naxes[0].set(xlabel=\"価格\", title=\"日経平均の分布\")\n\naxes[1].hist(returns, bins=30)\naxes[1].set(xlabel=\"価格変化率\",\n            title=f\"日経平均の日次リターン \\n（平均={returns.mean():.1%}, 標準偏差={returns.std():.1%}）\")\nfig.show()","visibility":"hide","key":"Ht3VXE3AiK"},{"type":"outputs","id":"SAQQvit0LcEDAHH91NmXM","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"74358db994c3b11dd9baa24e09cdd09b","path":"/notes/build/74358db994c3b11dd9baa24e09cdd09b.png"},"text/plain":{"content":"<Figure size 800x200 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"SBJrnxTQFe"}],"visibility":"show","key":"mjsmLu3Fo4"}],"visibility":"show","key":"x0FvjegGmj"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"fig, axes = plt.subplots(nrows=2, figsize=[4, 3], sharex=True)\naxes[0].plot(prices)\naxes[0].set(ylabel=\"日経平均\")\naxes[1].plot(returns)\naxes[1].set(ylabel=\"日次リターン\")\nfig.show()","visibility":"hide","key":"bmVZiBGHpH"},{"type":"outputs","id":"VHo7G2fE9PgmoW4d0RMEP","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e253d1fe9b3736abda5b44d49727c3db","path":"/notes/build/e253d1fe9b3736abda5b44d49727c3db.png"},"text/plain":{"content":"<Figure size 400x300 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"eEhOzD0M6p"}],"visibility":"show","key":"d9oQUxBP0n"}],"visibility":"show","key":"z0IUYT50AO"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ランダムウォークを10個生成するとつぎのようになる。","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fsp7CL3s5W"}],"key":"GaLA6LCppH"}],"key":"P1TqUVcRnD"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nbase_price = 100\n\n   \ndef gen_prices(seed, n = 250 * 3):\n    np.random.seed(seed)\n    returns_ = np.random.normal(loc=returns.mean(), scale=returns.std(), size=n)\n\n    prev_price = base_price\n    prices_ = [prev_price]\n    for ret in returns_:\n        price_ = prev_price * (1 + ret)\n        prices_.append(price_)\n        prev_price = price_\n    return prices_\n\nfig, ax = plt.subplots()\nfor seed in range(10):\n    prices_ = gen_prices(seed)\n    ax.plot(prices_, label=f\"seed={seed}, 最安値={min(prices_):.1f}\")\nax.set(ylabel=\"シミュレーション\")\nax.legend()\nfig.show()","visibility":"hide","key":"cnRCLDdzy5"},{"type":"outputs","id":"W9XAvwe-gU040fkPePBBl","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"02130b77b08456e2e13acf69588b89ed","path":"/notes/build/02130b77b08456e2e13acf69588b89ed.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"yXxxreZI5L"}],"visibility":"show","key":"Fz2b7cYzQ3"}],"visibility":"show","key":"eOEiwBpC6A"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"元本割れが9割","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Nh3DdE0FJd"}],"identifier":"id-9","label":"元本割れが9割","html_id":"id-9","implicit":true,"key":"QcuaQ1ouV4"}],"key":"UI971ODoy7"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"もっと試行回数を増やし、最安値が初期値を下回った（元本割れした）率を計算する","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"n6VicXTyzD"}],"key":"jUBkUI819z"}],"key":"AT9n75RSHw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import pandas as pd\n\nresults = []\nfor n_years in [1, 2, 5, 7, 10]:\n    for seed in range(100):\n        prices_ = gen_prices(seed, n=250*n_years)\n        results.append({\n            \"期間（年数）\": n_years,\n            \"元本割れ率\": min(prices_) < base_price,\n            \"最安値\": min(prices_),\n            \"最高値\": max(prices_),\n        })\n\npd.DataFrame(results).groupby(\"期間（年数）\").mean().round(3)","key":"kDR1ROXpv3"},{"type":"outputs","id":"Mx7qjE3RJ2Awem2ujTAI3","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":87,"metadata":{},"data":{"text/html":{"content":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-