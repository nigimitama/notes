e = Node(data)\n        new_node.next = self.head\n        self.head = new_node\n\n    def delete(self, data):\n        \"\"\"指定した値を持つ最初のノードを削除\"\"\"\n        if self.head is None:\n            return\n\n        # 先頭ノードが削除対象の場合\n        if self.head.data == data:\n            self.head = self.head.next\n            return\n\n        # 削除対象のノードを探す\n        current = self.head\n        while current.next is not None:\n            if current.next.data == data:\n                current.next = current.next.next\n                return\n            current = current.next\n\n    def search(self, data):\n        \"\"\"指定した値を持つノードを検索\"\"\"\n        current = self.head\n        while current is not None:\n            if current.data == data:\n                return True\n            current = current.next\n        return False\n\n    def display(self):\n        \"\"\"リストの全要素を表示\"\"\"\n        elements = []\n        current = self.head\n        while current is not None:\n            elements.append(current.data)\n            current = current.next\n        return elements","visibility":"show","key":"LhzF01xcTr"},{"type":"outputs","id":"ugrphYMhr4vRp22VeZHDN","children":[],"visibility":"show","key":"retvEHG32b"}],"visibility":"show","key":"NxerumRm6c"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# 使用例\nll = LinkedList()\nll.insert(3)\nll.insert(2)\nll.insert(1)\nprint(\"リスト:\", ll.display())\nprint(\"2を検索:\", ll.search(2))\nll.delete(2)\nprint(\"2を削除後:\", ll.display())","visibility":"show","key":"qGAbf6Kdpc"},{"type":"outputs","id":"_W3WOPkbw7L3ewkQZ-Euc","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"リスト: [1, 2, 3]\n2を検索: True\n2を削除後: [1, 3]\n"},"children":[],"key":"Gj6YxlBHu8"}],"visibility":"show","key":"BynrNc7rfC"}],"visibility":"show","key":"K5KXg6DG0c"},{"type":"block","kind":"notebook-content","children":[{"type":"card","children":[{"type":"c