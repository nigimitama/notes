{"version":3,"kind":"Notebook","sha256":"5736422979b3d1eef8f0b16323737b2fa75966a5ec221c686711f4da166e1417","slug":"mathematics.linear-algebra.eigenvalue.eigenvalue-and-covariance","location":"/mathematics/linear_algebra/eigenvalue/eigenvalue_and_covariance.ipynb","dependencies":[],"frontmatter":{"title":"固有値と共分散","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":3}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/mathematics/linear_algebra/eigenvalue/eigenvalue_and_covariance.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/mathematics/linear_algebra/eigenvalue/eigenvalue_and_covariance.ipynb","exports":[{"format":"ipynb","filename":"eigenvalue_and_covariance.ipynb","url":"/notes/build/eigenvalue_and_covar-df18f716408e7993ff74ce816a78ad68.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"主成分分析ではデータの分散を情報の量として扱い、固有値を用いて分散が最大化される軸を選ぶ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hIHP0Qfz0v"}],"key":"fVTNIRVN69"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"また、因子分析ではいくつの因子を使うかの判断基準のひとつにガットマン基準（固有値が1以上の因子を使う）というものがある。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QwTc61VrhU"}],"key":"TtBnDzlCOE"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"固有値と共分散や相関の関係を調べてみる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"NoIqypp92n"}],"key":"C11T9CyxtK"}],"visibility":"show","key":"lPfsAJJtHR"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"相関係数の異なるデータをいくつか生成して固有値と固有ベクトル（PC1, PC2）を出してみる。","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"u8zOHoegQM"}],"key":"SYQTBHL7yL"}],"key":"qyys62LY3d"},{"type":"block","kind":"notebook-code","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nimport japanize_matplotlib\n\nn = 1000\nnp.random.seed(0)\n\n# いくつかの相関係数で試す\nrhoset = [1, 0.5, 0]\nfig, axes = plt.subplots(figsize=[12, 4], ncols=len(rhoset))\n\nfor i, rho in enumerate(rhoset):\n    true_cov = np.array([[1, rho],\n                         [rho, 1]])\n    X = np.random.multivariate_normal(mean=[0,0], cov=true_cov, size=n)\n    # Cov = np.cov(X, rowvar=False)\n    Corr = np.corrcoef(X, rowvar=False)\n    # 固有値分解で主成分を取得（共分散を最大化する軸が固有ベクトルになるという定理のため）\n    # 共分散より相関係数を使うほうが対角成分が1になって安定するので、相関を使うことにする\n    lambdas, vectors = np.linalg.eig(Corr)\n\n    axes[i].scatter(X[:, 0], X[:, 1])\n    axes[i].axline(xy1=(0, 0), xy2=(vectors[:, 0]), color=\"coral\", label=f\"PC1={vectors[:, 0].round(3)}\")\n    axes[i].axline(xy1=(0, 0), xy2=(vectors[:, 1]), color=\"orange\", label=f\"PC2={vectors[:, 1].round(3)}\")\n    axes[i].set(xlabel=\"x1\", ylabel=\"x2\", xlim=(-3, 3), ylim=(-3, 3), title=f\"ρ={rho}, 固有値λ={lambdas.round(3)}\")\n    axes[i].legend()\nfig.show()\n","visibility":"show","key":"PkSQbPEKAQ"},{"type":"outputs","id":"zSBChUK6ELkxnwcDwfmmx","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"c4db54b756fcb244fa8400757d3ec9d3","path":"/notes/build/c4db54b756fcb244fa8400757d3ec9d3.png"},"text/plain":{"content":"<Figure size 1200x400 with 3 Axes>","content_type":"text/plain"}}},"children":[],"key":"iqWHDunYrE"}],"visibility":"show","key":"PQAq0sSOB9"}],"visibility":"show","key":"eugmJVtSCw"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"inlineMath","value":"\\rho=1","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>ρ</mi><mo>=</mo><mn>1</mn></mrow><annotation encoding=\"application/x-tex\">\\rho=1</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.625em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\">ρ</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">1</span></span></span></span>","key":"yPTksmfHgq"},{"type":"text","value":"のとき、固有値","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jHbCl7XYOc"},{"type":"inlineMath","value":"\\lambda=(2, 0)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>λ</mi><mo>=</mo><mo stretchy=\"false\">(</mo><mn>2</mn><mo separator=\"true\">,</mo><mn>0</mn><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">\\lambda=(2, 0)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6944em;\"></span><