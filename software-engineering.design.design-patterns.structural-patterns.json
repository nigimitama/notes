umn":1},"end":{"line":3,"column":1}},"key":"aQe9ZFfwMs"}],"key":"aIwKxRoOmL"}],"key":"HqQ7MqPyX8"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapter","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mPs0tcYF2B"}],"identifier":"adapter","label":"Adapter","html_id":"adapter","implicit":true,"key":"sazJdn9v7o"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"インターフェースに互換性のないクラス同士を仲介し、既存コードを変更せずに接続するパターン。外部ライブラリやレガシーAPIを\n自分のコードの期待するインターフェースに合わせたいときによく使う。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NAneUqkqwn"}],"key":"XXbrnXtYOy"},{"type":"code","lang":"python","value":"class LegacyPrinter:\n    def print_message(self, msg):\n        print(f\"[legacy] {msg}\")\n\nclass ModernPrinter:\n    def print(self, msg):\n        raise NotImplementedError\n\nclass PrinterAdapter(ModernPrinter):\n    def __init__(self, legacy: LegacyPrinter):\n        self.legacy = legacy\n\n    def print(self, msg):\n        self.legacy.print_message(msg)\n\nprinter: ModernPrinter = PrinterAdapter(LegacyPrinter())\nprinter.print(\"hello\")","position":{"start":{"line":6,"column":1},"end":{"line":24,"column":1}},"key":"l77IaVwb3C"}],"key":"encMUEacDc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Decorator","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"e7q0dN0rey"}],"identifier":"decorator","label":"Decorator","html_id":"decorator","implicit":true,"key":"nsmfxBMCIU"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"既存のオブジェクトを別のオブジェクトでラップし、動的に振る舞いを追加するパターン。継承によるサブクラスの組み合わせ爆発を避けられる。\nPythonの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dkTdYOcpdH"},{"type":"inlineCode","value":"@decorator","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"OLBreZUdbh"},{"type":"text","value":" 構文は関数版のこのパターン。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Ct0kZGsemj"}],"key":"l0GvdB6K6V"},{"type":"code","lang":"python","value":"class Coffee:\n    def cost(self):\n        return 300\n\nclass MilkDecorator:\n    def __init__(self, coffee):\n        self.coffee = coffee\n\n    def cost(self):\n        return self.coffee.cost() + 50\n\ndrink = MilkDecorator(Coffee())\nprint(drink.cost())  # 350","position":{"start":{"line":6,"column":1},"end":{"line":20,"column":1}},"key":"Re55U6CkKp"}],"key":"kPC9NA3kcj"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Facade","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IQEE6JkGdE"}],"identifier":"facade","label":"Facade","html_id":"facade","implicit":true,"key":"yNRZlzekDk"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"複雑なサブシステム群に対して、単純化された統一インターフェースを提供するパターン。利用者はサブシステムの内部構造を\n意識せずに済むようになる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"HW0n4Iwr8H"}],"key":"ZMwewcYto6"},{"type":"code","lang":"python","value":"class CPU:\n    def start(self): print(\"CPU start\")\n\nclass Memory:\n    def load(self): print(\"Memory load\")\n\nclass Disk:\n    def read(self): print(\"Disk read\")\n\nclass ComputerFacade:\n    def __init__(self):\n        self.cpu, self.memory, self.disk = CPU(), Memory(), Disk()\n\n    def start_computer(self):\n        self.cpu.start()\n        self.memory.load()\n        self.disk.read()\n\nComputerFacade().start_computer()","position":{"start":{"line":6,"column":1},"end":{"line":26,"column":1}},"key":"Dcf8fldnkj"}],"key":"RSMBXSlbqS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Composite","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"dJVvkdrCOQ"}],"identifier":"composite","label":"Composite","html_id":"composite","implicit":true,"key":"WOK55QeteL"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"個々のオブジェクトとその集合を同じインターフェースで扱えるようにし、木構造（部分-全体階層）を統一的に扱うパターン。\nファイルシステムのファイル/ディレクトリ、UIコンポーネントツリーなどが典型例。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"E7TEBOmTIz"}],"key":"iLCWZ0MXp1"},{"type":"code","lang":"python","value":"class FileSystemItem:\n    def size(self): raise NotImplementedError\n\nclass File(FileSystemItem):\n    def __init__(self, size):\n        self._size = size\n\n    def size(self):\n        return self._size\n\nclass Directory(FileSystemItem):\n    def __init__(self):\n        self.children = []\n\n    def add(self, item: FileSystemItem):\n        self.children.append(item)\n\n    def size(self):\n        return sum(child.size() for child in self.children)\n\nroot = Directory()\nroot.add(File(100))\nsub = Directory()\nsub.add(File(50))\nroot.add(sub)\nprint(root.size())  # 150","position":{"start":{"line":6,"column":1},"end":{"line":33,"column":1}},"key":"PqhjUzt9ee"}],"key":"s8FsBuxh0q"}],"key":"X1z3nlzbTT"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"生成に関するパターン（Creational Patterns）","url":"/software-engineering/design/design-patterns/creational-patterns","group":"ソフトウェア工学"},"next":{"title":"振る舞いに関するパターン（Behavioral Patterns）","url":"/software-engineering/design/design-patterns/behavioral-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}