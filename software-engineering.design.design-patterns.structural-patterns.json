スの組み合わせ爆発を避けられる。\nPythonの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dABPU0zIxe"},{"type":"inlineCode","value":"@decorator","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"w6ioosyw0r"},{"type":"text","value":" 構文は関数版のこのパターン。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bhqH8jXh3h"}],"key":"h2BAS8mstX"},{"type":"code","lang":"python","value":"class Coffee:\n    def cost(self):\n        return 300\n\nclass MilkDecorator:\n    def __init__(self, coffee):\n        self.coffee = coffee\n\n    def cost(self):\n        return self.coffee.cost() + 50\n\ndrink = MilkDecorator(Coffee())\nprint(drink.cost())  # 350","position":{"start":{"line":6,"column":1},"end":{"line":20,"column":1}},"key":"ruhzLaUBme"}],"key":"aru9EgFv2R"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Facade","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"l74758kJZB"}],"identifier":"facade","label":"Facade","html_id":"facade","implicit":true,"key":"b5mrYlCBvH"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"複雑なサブシステム群に対して、単純化された統一インターフェースを提供するパターン。利用者はサブシステムの内部構造を\n意識せずに済むようになる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"k2TAwRzVVX"}],"key":"LU0PVdt56V"},{"type":"code","lang":"python","value":"class CPU:\n    def start(self): print(\"CPU start\")\n\nclass Memory:\n    def load(self): print(\"Memory load\")\n\nclass Disk:\n    def read(self): print(\"Disk read\")\n\nclass ComputerFacade:\n    def __init__(self):\n        self.cpu, self.memory, self.disk = CPU(), Memory(), Disk()\n\n    def start_computer(self):\n        self.cpu.start()\n        self.memory.load()\n        self.disk.read()\n\nComputerFacade().start_computer()","position":{"start":{"line":6,"column":1},"end":{"line":26,"column":1}},"key":"qnbPkTdYom"}],"key":"v1hRWqXapI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Composite","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"RHhHq8A8JC"}],"identifier":"composite","label":"Composite","html_id":"composite","implicit":true,"key":"MCbOWVHLDt"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"個々のオブジェクトとその集合を同じインターフェースで扱えるようにし、木構造（部分-全体階層）を統一的に扱うパターン。\nファイルシステムのファイル/ディレクトリ、UIコンポーネントツリーなどが典型例。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pS3R0au4xH"}],"key":"ZsHvqA0qMc"},{"type":"code","lang":"python","value":"class FileSystemItem:\n    def size(self): raise NotImplementedError\n\nclass File(FileSystemItem):\n    def __init__(self, size):\n        self._size = size\n\n    def size(self):\n        return self._size\n\nclass Directory(FileSystemItem):\n    def __init__(self):\n        self.children = []\n\n    def add(self, item: FileSystemItem):\n        self.children.append(item)\n\n    def size(self):\n        return sum(child.size() for child in self.children)\n\nroot = Directory()\nroot.add(File(100))\nsub = Directory()\nsub.add(File(50))\nroot.add(sub)\nprint(root.size())  # 150","position":{"start":{"line":6,"column":1},"end":{"line":33,"column":1}},"key":"z5D22Vs8wT"}],"key":"bEwd7wZeSG"}],"key":"ZtYoPlpRlW"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"生成に関するパターン（Creational Patterns）","url":"/software-engineering/design/design-patterns/creational-patterns","group":"ソフトウェア工学"},"next":{"title":"振る舞いに関するパターン（Behavioral Patterns）","url":"/software-engineering/design/design-patterns/behavioral-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}