ecute(self, data):\n        result = 1\n        for x in data: result *= x\n        return result\n\ndef run(strategy: Strategy, data):\n    return strategy.execute(data)\n\nprint(run(Add(), [1, 2, 3]))\nprint(run(Multiply(), [1, 2, 3]))","visibility":"show","key":"DF4CgReIG9"},{"type":"outputs","id":"t4J6A17d8RJqDvE8Rgfaa","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"6\n6\n"},"children":[],"key":"TSeXyIMXRX"}],"visibility":"show","key":"qSUxhB719g"}],"visibility":"show","key":"lJQwgtq5oI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"State","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"T4erA1rPdE"}],"identifier":"state","label":"State","html_id":"state","implicit":true,"key":"KPePu0uskm"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"オブジェクトの内部状態に応じて振る舞いを切り替えるパターン。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KHAuKMuPRS"},{"type":"inlineCode","value":"if","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NlQbZUeR1h"},{"type":"text","value":"/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ICcHGjRt1f"},{"type":"inlineCode","value":"switch","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"e3k1i9yLo2"},{"type":"text","value":" による状態分岐の乱立を、状態ごとのクラスに置き換える。\nStrategyと構造は似ているが、Stateはオブジェクト自身が状態遷移を管理する点が異なる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Elgv7KFplG"}],"key":"zpcbYoyUTx"},{"type":"code","lang":"python","value":"class State:\n    def handle(self, order): raise NotImplementedError\n\nclass PendingState(State):\n    def handle(self, order):\n        print(\"支払い待ち → 発送準備へ\")\n        order.state = ShippedState()\n\nclass ShippedState(State):\n    def handle(self, order):\n        print(\"発送済み → これ以上遷移しない\")\n\nclass Order:\n    def __init__(self):\n        self.state: State = PendingState()\n\n    def proceed(self):\n        self.state.handle(self)\n\norder = Order()\norder.proceed()","position":{"start":{"line":6,"column":1},"end":{"line":28,"column":1}},"key":"Rd45FoCC8c"}],"key":"bcMIRXR1Xm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Command","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MpNjZS0YrV"}],"identifier":"command","label":"Command","html_id":"command","implicit":true,"key":"wV1Rwlbhxb"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"「実行してほしい操作」をオブジェクトとしてカプセル化するパターン。呼び出し元（Invoker）と実行対象（Receiver）を分離でき、\nコマンドのキューイング・ログ記録・Undo/Redoの実装が容易になる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gV4LMOJvx2"}],"key":"OF12vr7S0Y"},{"type":"code","lang":"python","value":"class Light:\n    def on(self): print(\"light on\")\n    def off(self): print(\"light off\")\n\nclass Command:\n    def execute(self): raise NotImplementedError\n\nclass LightOnCommand(Command):\n    def __init__(self, light):\n        self.light = light\n\n    def execute(self):\n        self.light.on()\n\nclass RemoteControl:\n    def __init__(self):\n        self.history = []\n\n    def submit(self, command: Command):\n        command.execute()\n        self.history.append(command)\n\nremote = RemoteControl()\nremote.submit(LightOnCommand(Light()))","position":{"start":{"line":6,"column":1},"end":{"line":31,"column":1}},"key":"UKr6rqIzeb"}],"key":"xuOH9ZY3Pm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Iterator","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DHMKtCwURF"}],"identifier":"iterator","label":"Iterator","html_id":"iterator","implicit":true,"key":"fn0nWMgdBu"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"集約オブジェクトの内部表現を公開せずに、要素へ順次アクセスする手段を提供するパターン。Pythonでは ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xvfBZnm30B"},{"type":"inlineCode","value":"__iter__","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"taCcPrvnvZ"},{"type":"text","value":" /\n","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"DQhA5TkbxL"},{"type":"inlineCode","value":"__next__","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"j3qU1b85dl"},{"type":"text","value":" プロトコルとしてすでに言語仕様に組み込まれており、独自コンテナ型を作るときに自然と使うことになる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"R0vPzHimeu"}],"key":"I59iRODi6h"},{"type":"code","lang":"python","value":"class Range3:\n    def __init__(self, n):\n        self.n = n\n\n    def __iter__(self):\n        self.i = 0\n        return self\n\n    def __next__(self):\n        if self.i >= self.n:\n            raise StopIteration\n        self.i += 1\n        return self.i - 1\n\nfor x in Range3(3):\n    print(x)","position":{"start":{"line":6,"column":1},"end":{"line":23,"column":1}},"key":"Cs3rw3Rob7"}],"key":"Smess22pLX"}],"key":"EwHmMXySc7"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"構造に関するパターン（Structural Patterns）","url":"/software-engineering/design/design-patterns/structural-patterns","group":"ソフトウェア工学"},"next":{"title":"ドメイン駆動設計（DDD）","url":"/software-engineering/design/domain-driven-design","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}