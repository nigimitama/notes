en":[{"type":"text","value":"状態が変わったら通知（イベントリスナー）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kXkA2zGUVp"}],"key":"OIO3G5UpH7"}],"key":"FtxKj1Bg1m"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Subject:\n    def __init__(self):\n        self.observers = []\n\n    def attach(self, observer):\n        self.observers.append(observer)\n\n    def notify(self, msg):\n        for ob in self.observers:\n            ob.update(msg)\n\nclass Observer:\n    def update(self, msg):\n        print(\"Got:\", msg)\n\ns = Subject()\ns.attach(Observer())\ns.notify(\"Update available\")","visibility":"show","key":"pQdTMHYrK7"},{"type":"outputs","id":"HFLC9LFBrAGh6V5sq113M","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Got: Update available\n"},"children":[],"key":"RQmFrmREiJ"}],"visibility":"show","key":"t9OheajmVL"}],"visibility":"show","key":"quH8RP13Du"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Strategy","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"viaxosHBqJ"}],"identifier":"strategy","label":"Strategy","html_id":"strategy","implicit":true,"key":"x6IfwVv6XY"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"アルゴリズムを切り替えられるようにする","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mcg4DYBwXx"}],"key":"RjmBvMlFmV"}],"key":"AAQAStX399"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"class Strategy:\n    def execute(self, data):\n        pass\n\nclass Add(Strategy):\n    def execute(self, data):\n        return sum(data)\n\nclass Multiply(Strategy):\n    def execute(self, data):\n        result = 1\n        for x in data: result *= x\n        return result\n\ndef run(strategy: Strategy, data):\n    return strategy.execute(data)\n\nprint(run(Add(), [1, 2, 3]))\nprint(run(Multiply(), [1, 2, 3]))","visibility":"show","key":"aYw7pbUuje"},{"type":"outputs","id":"Nq1lnalwTajhAKgEI8YaY","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"6\n6\n"},"children":[],"key":"hCCmI4dl78"}],"visibility":"show","key":"BUSZRwoSTj"}],"visibility":"show","key":"dIBc4xrqUW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"State","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YjsLyLdZNx"}],"identifier":"state","label":"State","html_id":"state","implicit":true,"key":"Tru99qLt1A"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"オブジェクトの内部状態に応じて振る舞いを切り替えるパターン。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"U9IGE6F9JM"},{"type":"inlineCode","value":"if","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gvQWoGRlVB"},{"type":"text","value":"/","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"aZBNlmuuaX"},{"type":"inlineCode","value":"switch","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Y17VEjzqaW"},{"type":"text","value":" による状態分岐の乱立を、状態ごとのクラスに置き換える。\nStrategyと構造は似ているが、Stateはオブジェクト自身が状態遷移を管理する点が異なる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"cugXoZhMaY"}],"key":"hxGDHdArSC"},{"type":"code","lang":"python","value":"class State:\n    def handle(self, order): raise NotImplementedError\n\nclass PendingState(State):\n    def handle(self, order):\n        print(\"支払い待ち → 発送準備へ\")\n        order.state = ShippedState()\n\nclass ShippedState(State):\n    def handle(self, order):\n        print(\"発送済み → これ以上遷移しない\")\n\nclass Order:\n    def __init__(self):\n        self.state: State = PendingState()\n\n    def proceed(self):\n        self.state.handle(self)\n\norder = Order()\norder.proceed()","position":{"start":{"line":6,"column":1},"end":{"line":28,"column":1}},"key":"H9QjmEWX5w"}],"key":"LiVRuA0DIz"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Command","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"f4je9vtvud"}],"identifier":"command","label":"Command","html_id":"command","implicit":true,"key":"XUjba5LSvv"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"「実行してほしい操作」をオブジェクトとしてカプセル化するパターン。呼び出し元（Invoker）と実行対象（Receiver）を分離でき、\nコマンドのキューイング・ログ記録・Undo/Redoの実装が容易になる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"nTAHTDy7iX"}],"key":"L4KLOfTKkT"},{"type":"code","lang":"python","value":"class Light:\n    def on(self): print(\"light on\")\n    def off(self): print(\"light off\")\n\nclass Command:\n    def execute(self): raise NotImplementedError\n\nclass LightOnCommand(Command):\n    def __init__(self, light):\n        self.light = light\n\n    def execute(self):\n        self.light.on()\n\nclass RemoteControl:\n    def __init__(self):\n        self.history = []\n\n    def submit(self, command: Command):\n        command.execute()\n        self.history.append(command)\n\nremote = RemoteControl()\nremote.submit(LightOnCommand(Light()))","position":{"start":{"line":6,"column":1},"end":{"line":31,"column":1}},"key":"lWNWTDsp66"}],"key":"CEQQlfNBDf"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Iterator","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IQpPpptAUg"}],"identifier":"iterator","label":"Iterator","html_id":"iterator","implicit":true,"key":"OLzG9WL6IV"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"集約オブジェクトの内部表現を公開せずに、要素へ順次アクセスする手段を提供するパターン。Pythonでは ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"rFS2IHd98O"},{"type":"inlineCode","value":"__iter__","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IXxi8Abd6T"},{"type":"text","value":" /\n","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JvIvBllkYV"},{"type":"inlineCode","value":"__next__","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KZ4ihYgwXf"},{"type":"text","value":" プロトコルとしてすでに言語仕様に組み込まれており、独自コンテナ型を作るときに自然と使うことになる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NGxnD10eYI"}],"key":"FfewtSi0rd"},{"type":"code","lang":"python","value":"class Range3:\n    def __init__(self, n):\n        self.n = n\n\n    def __iter__(self):\n        self.i = 0\n        return self\n\n    def __next__(self):\n        if self.i >= self.n:\n            raise StopIteration\n        self.i += 1\n        return self.i - 1\n\nfor x in Range3(3):\n    print(x)","position":{"start":{"line":6,"column":1},"end":{"line":23,"column":1}},"key":"hpmK36FwD9"}],"key":"CBvsOiSbK1"}],"key":"Ro5AgnI9CF"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"構造に関するパターン（Structural Patterns）","url":"/software-engineering/design/design-patterns/structural-patterns","group":"ソフトウェア工学"},"next":{"title":"ドメイン駆動設計（DDD）","url":"/software-engineering/design/domain-driven-design","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}