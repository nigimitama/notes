eta  ~ normal(0, 1);\n  sigma ~ normal(0, 1); // <lower=0> にしているので半正規分布\n  y ~ normal(x * beta + alpha, sigma);  // likelihood\n}","position":{"start":{"line":3,"column":1},"end":{"line":21,"column":1}},"key":"Gkvu81m3J4"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"inlineCode","value":"cmdstanpy","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"cC0Vxdjn6P"},{"type":"text","value":"パッケージを使う場合の例","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"DSH0xRfLiC"}],"key":"NQ50gnEhwT"},{"type":"code","lang":"python","value":"from cmdstanpy import CmdStanModel\nmodel = CmdStanModel(stan_file=\"hoge.stan\")\n\ndata = {\"N\": N, \"K\": K, \"X\": X, \"y\": y}\nfit = model.sample(\n    data=data,\n    chains=4,\n    iter_warmup=1000,\n    iter_sampling=1000,\n    seed=0,\n)\n\ndf = fit.draws_pd()  # pandas DataFrame\nprint(df[[\"alpha\", \"beta[1]\", \"beta[2]\", \"beta[3]\", \"sigma\"]].describe())","position":{"start":{"line":25,"column":1},"end":{"line":40,"column":1}},"key":"ebda8gZM6m"}],"key":"FychgUNOzb"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"NumPyro","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SNpQQegmwB"}],"identifier":"numpyro","label":"NumPyro","html_id":"numpyro","implicit":true,"key":"untuGzY80m"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"JAXという高速な科学計算ライブラリを使っている","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kyhcQTk9kZ"}],"key":"ywWA4qA2cW"}],"key":"o1CKHYprfn"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import jax\nimport jax.numpy as jnp\nimport numpyro\nimport numpyro.distributions as dist\nfrom numpyro.infer import MCMC, NUTS\n\ndef model(X, y=None):\n    N, K = X.shape\n    alpha = numpyro.sample(\"alpha\", dist.Normal(0.0, 1.0))\n    beta  = numpyro.sample(\"beta\",  dist.Normal(0.0, 1.0).expand([K]))\n    sigma = numpyro.sample(\"sigma\", dist.HalfNormal(1.0))\n    mu = alpha + jnp.dot(X, beta)\n    numpyro.sample(\"y\", dist.Normal(mu, sigma), obs=y)\n\nnuts = NUTS(model)\nmcmc = MCMC(nuts, num_warmup=1000, num_samples=1000, num_chains=4, progress_bar=False)\nmcmc.run(jax.random.PRNGKey(0), X=jnp.array(X), y=jnp.array(y))\n\nsamples = mcmc.get_samples(group_by_chain=False)\n# samples[\"beta\"] shape: (num_draws, K)\nprint({k: (v.mean(0), v.std(0)) for k, v in samples.items() if k in [\"alpha\",\"sigma\"]})\nprint(\"beta mean:\", samples[\"beta\"].mean(0))\nprint(\"beta sd  :\", samples[\"beta\"].std(0))","visibility":"show","key":"TL09KPUmQA"},{"type":"outputs","id":"3gWxgBGJF1ZuTPWcOZGWO","children":[{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"/tmp/ipykernel_54342/2230612519.py:16: UserWarning: There are not enough devices to run parallel chains: expected 4 but got 1. Chains will be drawn sequentially. If you are running MCMC in CPU, consider using `numpyro.set_host_device_count(4)` at the beginning of your program. You can double-check how many devices are available in your system using `jax.local_device_count()`.\n  mcmc = MCMC(nuts, num_warmup=1000, num_samples=1000, num_chains=4, progress_bar=False)\n"},"children":[],"key":"pgSMZVvJB8"},{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"{'alpha': (Array(0.97254834, dtype=float64), Array(0.05002473, dtype=float64)), 'sigma': (Array(0.71080548, dtype=float64), Array(0.03604194, dtype=float64))}\nbeta mean: [ 0.43455282 -1.26495461  0.33638894]\nbeta sd  : [0.04932507 0.05165164 0.05145463]\n"},"children":[],"key":"WV6Cu1nt2g"}],"visibility":"show","key":"eteUzNvfGD"}],"visibility":"show","key":"VvVaoEoE7t"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"PyMC","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wEfBN3sO03"}],"identifier":"pymc","label":"PyMC","html_id":"pymc","implicit":true,"key":"EbjPc86zX4"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"NumPyroと近い書き味だが、サンプラーを他のものにすることもできる","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AiztW8jiFc"}],"key":"R5j7ZVKOQM"},{"type":"heading","depth":3,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"特徴：MCMCサンプラーを選べる","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"uXNnfq8dcC"}],"identifier":"id-mcmc","label":"特徴：MCMCサンプラーを選べる","html_id":"id-mcmc","implicit":true,"key":"Of8UIfpUTd"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Python NUTS sampler （デフォルト、NumPyroより速いことも）","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"pPAKI2zVmu"}],"key":"dhJ6DITLtf"}],"key":"Xe7UW83co4"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"NumPyro JAX NUTS sampler","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"TYIZMovyqW"}],"key":"jglzXee7LS"}],"key":"FYuPT84ir4"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"BlackJAX NUTS sampler（大規模データで速いらしい）","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"aIAWHHCeZW"}],"key":"zlu1MLx2oG"}],"key":"qESt15JvSJ"},{"type":"listItem","spread":true,"position":{"start":{"line":10,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Nutpie NUTS sampler（Rustで書かれていてJAXくらい速いらしい）","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"sKaghl1I5o"}],"key":"lrw4w2L5pV"}],"key":"Jrz6ND8kPf"}],"key":"k2Qm33Goo9"},{"type":"code","lang":"python","value":"pm.sample(nuts_sampler=\"blackjax\")","position":{"start":{"line":12,"column":1},"end":{"line":14,"column":1}},"key":"EY9JgefEEQ"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"link","url":"https://www.pymc.io/projects/examples/en/latest/samplers/fast_sampling_with_jax_and_numba.html","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Faster Sampling with JAX and Numba — PyMC example gallery","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"kfpDx3Br7y"}],"urlSource":"https://www.pymc.io/projects/examples/en/latest/samplers/fast_sampling_with_jax_and_numba.html","key":"fW9FCUkzLa"}],"key":"SHQ1M6gjP7"}],"key":"HyXDHKphWN"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import pymc as pm\nimport numpy as np\n\nwith pm.Model() as m:\n    alpha = pm.Normal(\"alpha\", mu=0.0, sigma=5.0)\n    beta  = pm.Normal(\"beta\",  mu=0.0, sigma=2.0, shape=K)\n    sigma = pm.HalfNormal(\"sigma\", sigma=2.0)\n\n    mu = alpha + pm.math.dot(X, beta)\n    y_obs = pm.Normal(\"y\", mu=mu, sigma=sigma, observed=y)\n\n    idata = pm.sample(\n        draws=1000,\n        tune=1000,\n        chains=4,\n        random_seed=0,\n        target_accept=0.8,\n    )\n\n# ArviZでまとめて比較しやすい\nimport arviz as az\ndisplay(az.summary(idata, var_names=[\"alpha\",\"beta\",\"sigma\"]))","visibility":"show","key":"n8ZZmO2BGb"},{"type":"outputs","id":"PfgNjX-ShKGIufPW27Wl1","children":[{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"Initializing NUTS using jitter+adapt_diag...\nMultiprocess sampling (4 chains in 4 jobs)\nNUTS: [alpha, beta, sigma]\n/home/mitama/.local/share/uv/python/cpython-3.10.18-linux-x86_64-gnu/lib/python3.10/multiprocessing/popen_fork.py:66: RuntimeWarning: os.fork() was called. os.fork() is incompatible with multithreaded code, and JAX is multithreaded, so this will likely lead to a deadlock.\n  self.pid = os.fork()\n"},"children":[],"key":"aaQc1UKS71"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"b30694295e4047fb8a2d1b3e85210bb9\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"Output()","content_type":"text/plain"}}},"children":[],"key":"cTDIKRJthk"},{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"/home/mitama/.local/share/uv/python/cpython-3.10.18-linux-x86_64-gnu/lib/python3.10/multiprocessing/popen_fork.py:66: RuntimeWarning: os.fork() was called. os.fork() is incompatible with multithreaded code, and JAX is multithreaded, so this will likely lead to a deadlock.\n  self.pid = os.fork()\n"},"children":[],"key":"k5FAc4HvVm"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"></pre>\n","content_type":"text/html"},"text/plain":{"content":"","content_type":"text/plain"}}},"children":[],"key":"ats8I0X67j"},{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"Sampling 4 chains for