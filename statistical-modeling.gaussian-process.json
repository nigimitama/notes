{"version":3,"kind":"Notebook","sha256":"5bddc16a62cba2bcd5f0ed26aaf57456fb18657aab09303d8ecfa8abf2dc9226","slug":"statistical-modeling.gaussian-process","location":"/statistical_modeling/gaussian_process.ipynb","dependencies":[],"frontmatter":{"title":"ガウス過程回帰","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":1}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/statistical_modeling/gaussian_process.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/statistical_modeling/gaussian_process.ipynb","exports":[{"format":"ipynb","filename":"gaussian_process.ipynb","url":"/notes/build/gaussian_process-6bbea35c0bbe97197ff5cc3a9d88a8e8.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ガウス過程というランダムな関数の確率分布を利用した回帰モデル","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fmsmrODimy"}],"key":"eeKuORbLPc"}],"key":"BVMKKloxpD"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\nX = np.linspace(start=0, stop=10, num=1_000).reshape(-1, 1)\ny = np.squeeze(X * np.sin(X))\n\nimport matplotlib.pyplot as plt\n\nplt.plot(X, y, label=r\"$f(x) = x \\sin(x)$\", linestyle=\"dotted\")\nplt.legend()\nplt.xlabel(\"$x$\")\nplt.ylabel(\"$f(x)$\")\n_ = plt.title(\"True generative process\")","visibility":"hide","key":"EtHQvt1uUA"},{"type":"outputs","id":"xVxtKm5py62kRTFgQw_2I","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"f5f6e92c4ba558472cc3e0c75a994535","path":"/notes/build/f5f6e92c4ba558472cc3e0c75a994535.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"gV4zNgUjeM"}],"visibility":"show","key":"xRG4GwZArh"}],"visibility":"show","key":"tmGQiLnivs"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"rng = np.random.RandomState(1)\ntraining_indices = rng.choice(np.arange(y.size), size=6, replace=False)\nX_train, y_train = X[training_indices], y[training_indices]\n\nfrom sklearn.gaussian_process import GaussianProcessRegressor\nfrom sklearn.gaussian_process.kernels import RBF\n\nkernel = 1 * RBF(length_scale=1.0, length_scale_bounds=(1e-2, 1e2))\nnoise_std = 0.75\ny_train_noisy = y_train + rng.normal(loc=0.0, scale=noise_std, size=y_train.shape)\ngaussian_process = GaussianProcessRegressor(kernel=kernel, alpha=noise_std**2, n_restarts_optimizer=9)\ngaussian_process.fit(X_train, y_train_noisy)\n\nmean_prediction, std_prediction = gaussian_process.predict(X, return_std=True)\n\nplt.plot(X, y, label=r\"$f(x) = x \\sin(x)$\", linestyle=\"dotted\")\nplt.errorbar(\n    X_train,\n    y_train_noisy,\n    noise_std,\n    linestyle=\"None\",\n    color=\"tab:blue\",\n    marker=\".\",\n    markersize=10,\n    label=\"Observations\",\n)\nplt.plot(X, mean_prediction, label=\"Mean prediction\")\nplt.fill_between(\n    X.ravel(),\n    mean_prediction - 1.96 * std_prediction,\n    mean_prediction + 1.96 * std_prediction,\n    color=\"tab:orange\",\n    alpha=0.5,\n    label=r\"95% confidence interval\",\n)\nplt.legend()\nplt.xlabel(\"$x$\")\nplt.ylabel(\"$f(x)$\")\n_ = plt.title(\"Gaussian process regression on a noisy dataset\")","visibility":"hide","key":"wuclvyuVtI"},{"type":"outputs","id":"x4Pb_44KAOpyjU1SoXzHT","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"da