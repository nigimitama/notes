gn:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mop\">lo<span style=\"margin-right:0.01389em;\">g</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\">n</span><span class=\"mclose\">)</span></span></span></span>","key":"HhCvJumiaA"}],"key":"JN3BZTlPO0"}],"key":"stod02rlBn"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"ステップ2を ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"wi01VUYOxR"},{"type":"inlineMath","value":"n-1","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>n</mi><mo>−</mo><mn>1</mn></mrow><annotation encoding=\"application/x-tex\">n-1</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6667em;vertical-align:-0.0833em;\"></span><span class=\"mord mathnormal\">n</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">1</span></span></span></span>","key":"WxKkGEqL2h"},{"type":"text","value":" 回繰り返す","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"tCxYmKBJJ0"}],"key":"IfOmORm34e"}],"key":"YO94oMEd46"}],"key":"PBquxklTDi"}],"key":"ocPtECZ5P5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def heap_sort(arr: list) -> list:\n    a = arr.copy()\n    n = len(a)\n\n    # Build Max-Heap: 末尾の非葉ノードから根に向かって sift-down\n    for i in range(n // 2 - 1, -1, -1):\n        _sift_down(a, i, n)\n\n    # 根（最大値）を末尾と交換しながら縮小\n    for end in range(n - 1, 0, -1):\n        a[0], a[end] = a[end], a[0]\n        _sift_down(a, 0, end)\n\n    return a\n\ndef _sift_down(a: list, i: int, heap_size: int) -> None:\n    \"\"\"インデックス i の要素をヒープ性が回復するまで下げる\"\"\"\n    while True:\n        largest = i\n        left = 2 * i + 1\n        right = 2 * i + 2\n        if left < heap_size and a[left] > a[largest]:\n            largest = left\n        if right < heap_size and a[right] > a[largest]:\n            largest = right\n        if largest == i:\n            break\n        a[i], a[largest] = a[largest], a[i]\n        i = largest","key":"HM1lzlMpPb"},{"type":"outputs","id":"nwOlvWNQAzkYR18sbhgoU","children":[],"key":"Uzx8bjvpZR"}],"key":"HiAZ1e4tsD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import random\n\ndata = [12, 11, 13, 5, 6, 7]\nprint(\"入力:\", data)\nprint(\"出力:\", heap_sort(data))\n\nrandom.seed(4)\nlarge = random.sample(range(10000), 100)\nassert heap_sort(large) == sorted(large)\nprint(\"ランダム100件: OK\")\n\n# 最悪ケース（既ソート済み）でも O(n log n)\nsorted_data = list(range(500))\nassert heap_sort(sorted_data) == sorted_data\nprint(\"既ソート済み500件: OK\")","key":"ibYoxBRqre"},{"type":"outputs","id":"rYoJ2eW3pMsQJgk5glRpw","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"入力: [12, 11, 13, 5, 6, 7]\n出力: [5, 6, 7, 11, 12, 13]\nランダム100件: OK\n既ソート済み500件: OK\n"},"children":[],"key":"MFpEtkijRX"}],"key":"lqWNVgIFk5"}],"key":"VlUWwyDQnQ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Python の ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hV9nCgtMrc"},{"type":"inlineCode","value":"heapq","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SlfrgaXeRK"},{"type":"text","value":" を使った実装","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"UyQHIFmPS3"}],"identifier":"python-heapq","label":"Python の heapq を使った実装","html_id":"python-heapq","implicit":true,"key":"BmcJPFNHVI"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Python 標準ライブラリの ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zNbp106Omd"},{"type":"inlineCode","value":"heapq","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ka0bKIndaK"},{"type":"text","value":" は最小ヒープを提供する。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"l8VJp85wuL"}],"key":"dtqEfP8all"}],"key":"ROzE7zp0vJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import heapq\n\ndef heap_sort_heapq(arr: list) -> list:\n    h = arr.copy()\n    heapq.heapify(h)          # O(n)\n    return [heapq.heappop(h) for _ in range(len(h))]  # O(n log n)\n\ndata = [12, 11, 13, 5, 6, 7]\nprint(heap_sort_heapq(data))\nassert heap_sort_heapq(data) == sorted(data)","key":"CHqCRvJZ1W"},{"type":"outputs","id":"pAfDZqnpXIeYG82IWj17U","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[5, 6, 7, 11, 12, 13]\n"},"children":[],"key":"qM45VgIxOT"}],"key":"iVMa8BphIS"}],"key":"XsUBKT1x9s"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：Top-K 問題","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"dstbwn3ikv"}],"identifier":"id-top-k","label":"応用：Top-K 問題","html_id":"id-top-k","implicit":true,"key":"N3Ea96ZKA7"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"配列から上位 ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"tCmS33fYMg"},{"type":"inlineMath","value":"k","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>k</mi></mrow><annotation encoding=\"application/x-tex\">k</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03148em;\">k</span></span></span></span>","key":"JRJ2t7peGf"},{"type":"text","value":" 件を求める場合、全体をソートするより","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Jefd570LTX"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"サイズ ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ikQXZ15Cv3"},{"type":"inlineMath","value":"k","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>k</mi></mrow><annotation encoding=\"application/x-tex\">k</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03148em;\">k</span></span></span></span>","key":"PJwxEBqDbD"},{"type":"text","value":" の最小ヒープを維持する","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IRBV6cA3n6"}],"key":"ptPyMoyJLo"},{"type":"text","value":"方が効率的。計算量 ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"eVyofMgRKh"},{"type":"inlineMath","value":"O(n \\log k)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>O</mi><mo stretchy=\"false\">(</mo><mi>n</mi><mi>log</mi><mo>⁡</mo><mi>k</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">O(n \\log k)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">O</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">n</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mop\">lo<span style=\"margin-right:0.01389em;\">g</span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03148em;\">k</span><span class=\"mclose\">)</span></span></span></span>","key":"jvKBI8jw1o"},{"type":"text","value":"。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ScKQMFaMUD"}],"key":"m5pry3GnRA"}],"key":"dNnHcBU0DT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import heapq\n\ndef top_k_largest(arr: list, k: int) -> list:\n    \"\"\"配列から上位 k 件を返す（降順）\"\"\"\n    return heapq.nlargest(k, arr)\n\ndef top_k_largest_manual(arr: list, k: int) -> list:\n    \"\"\"サイズ k の最小ヒープで手動実装\"\"\"\n    heap = arr[:k]\n    heapq.heapify(heap)\n    for x in arr[k:]:\n        if x > heap[0]:\n            heapq.heapreplace(heap, x)\n    return sorted(heap, reverse=True)\n\ndata = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]\nk = 3\nprint(f\"データ: {data}\")\nprint(f\"Top-{k}: {top_k_largest(data, k)}\")\nprint(f\"Top-{k} (手動): {top_k_largest_manual(data, k)}\")","key":"Zb22txkMp1"},{"type":"outputs","id":"xXlYJ0UVrQF9Pa77iU4Zq","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"データ: [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]\nTop-3: [9, 6, 5]\nTop-3 (手動): [9, 6, 5]\n"},"children":[],"key":"LqwIV8jKOY"}],"key":"WYR5SS75fN"}],"key":"BbqG7VhAP2"}],"key":"fv6VV5X8hD"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"クイックソート","url":"/software-engineering/algorithms/sorting-algorithms/quick-sort","group":"ソフトウェア工学"},"next":{"title":"計数ソート・基数ソート","url":"/software-engineering/algorithms/sorting-algorithms/counting-sort","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}