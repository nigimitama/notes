tor":"2","key":"zjh4uTMnPP"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"はスケール","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"lX2o9z2zPs"},{"type":"inlineMath","value":"\\sigma","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>σ</mi></mrow><annotation encoding=\"application/x-tex\">\\sigma</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">σ</span></span></span></span>","key":"kqLxWqHkTa"},{"type":"text","value":"がハイパーパラメータであり、スケールの設定次第でHSICの値は変わる。","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"j02oq1Q5ul"}],"key":"BQsj29KKGs"},{"type":"heading","depth":3,"position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"特徴","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"TFaxgPpmOA"}],"identifier":"id","label":"特徴","html_id":"id-1","implicit":true,"key":"E04huGW1Io"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":31,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"カーネル次第で非常に多様な非線形関係を検出","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"Rme9PJCTFD"}],"key":"SlQqwmmEeM"}],"key":"r7dvNPABFl"},{"type":"listItem","spread":true,"position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"多変量にも自然に拡張できる","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"e0kUc0J99D"}],"key":"UjfbR4Mbvh"}],"key":"Ngwpg9urpx"},{"type":"listItem","spread":true,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"ハイパーパラメータに依存","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"csdXlHbSFl"}],"key":"hLzI1NMnfC"}],"key":"fDedIohy3L"}],"key":"AMnhGwOe0u"}],"key":"jI8kn5GIIO"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"実装","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WjeGsT8LgN"}],"identifier":"id","label":"実装","html_id":"id-2","implicit":true,"key":"OQN7CKw0c8"}],"key":"OAh9b7tBuq"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nfrom sklearn.metrics.pairwise import rbf_kernel\n\ndef hsic(X, Y, sigma_x=None, sigma_y=None):\n    \"\"\"\n    X: shape (n, d1)\n    Y: shape (n, d2)\n    \"\"\"\n    if len(X.shape) == 1:\n        X = X.reshape(-1, 1)\n    if len(Y.shape) == 1:\n        Y = Y.reshape(-1, 1)\n\n    # set sigma by median of distance\n    sigma_x = sigma_x or median_sigma(X)\n    sigma_y = sigma_y or median_sigma(Y)\n        \n    n = X.shape[0]\n    K = rbf_kernel(X, X, gamma=1/(2*sigma_x**2))\n    L = rbf_kernel(Y, Y, gamma=1/(2*sigma_y**2))\n    H = np.eye(n) - np.ones((n, n)) / n\n    return (1 / (n - 1)**2) * np.trace(K @ H @ L @ H)\n\ndef median_sigma(X):\n    # set sigma by median of distance\n    dists = np.sqrt(((X[:, None, :] - X[None, :, :])**2).sum(axis=2))\n    return np.median(dists)\n\n# サンプルデータ\nnp.random.seed(0)\nx = np.linspace(0, 10, 200).reshape(-1, 1)\ny = np.sin(x) + 0.3*np.random.randn(200, 1)\n\n# HSIC の実行\nvalue = hsic(x, y)\nprint(\"HSIC:\", value)","visibility":"show","key":"EkHnm6b6ep"},{"type":"outputs","id":"Mn7nBt0yn1g_2g0G6JDee","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"HSIC: 0.011830828031023408\n"},"children":[],"key":"QMKyBW0nPZ"}],"visibility":"show","key":"yOw1l0XPPF"}],"visibility":"show","key":"PBPLsiQBjk"},{"type":"block","kind":"notebook-code","data":{"jupyter":{"source_hidden":true},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfig, axes = plt.subplots(figsize=[10, 2.5], ncols=3)\n\ntrue_r = 0\nmu = np.array([0.0, 0.0])\nSigma = np.array([[1.0, true_r], [true_r, 1.0]])\nsamples = np.random.multivariate_normal(mu, Sigma, size=100)\nx = samples[:, 0]\ny = samples[:, 1]\naxes[0].scatter(x, y)\naxes[0].set_title(f\"HSIC = {hsic(x, y):.3f}\")\n\nx = np.linspace(-10, 10, 15)\ny = 1 / (1 + np.exp(-x))\naxes[1].scatter(x, y)\naxes[1].set_title(f\"HSIC = {hsic(x, y):.3f}\")\n\nx = np.linspace(-3, 3, 100)\ny = x**2 + np.random.random(len(x))\naxes[2].scatter(x, y)\naxes[2].set_title(f\"HSIC = {hsic(x, y):.3f}\")\n\n%matplotlib inline","visibility":"hide","key":"bmMGdo27Jr"},{"type":"outputs","id":"FIxhl-PBIC6Wr8LpVxhY4","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"a9b3e8dfe55837089434e4dcfceed6e4","path":"/notes/build/a9b3e8dfe55837089434e4dcfceed6e4.png"},"text/plain":{"content":"<Figure size 1000x250 with 3 Axes>","content_type":"text/plain"}}},"children":[],"key":"jllEajltig"}],"visibility":"show","key":"vOMfD5W3U6"}],"visibility":"show","key":"g9zlDtyzyv"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"HSICを使った独立性検定","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PgxKtsY0yT"}],"identifier":"hsic","