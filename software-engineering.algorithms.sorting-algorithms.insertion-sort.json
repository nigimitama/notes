"入力:\", data)\nprint(\"出力:\", insertion_sort(data))\n\n# ほぼソート済みデータで高速動作を確認\nnearly_sorted = list(range(100))\nnearly_sorted[50], nearly_sorted[51] = nearly_sorted[51], nearly_sorted[50]\nassert insertion_sort(nearly_sorted) == list(range(100))\nprint(\"ほぼソート済み100件: OK\")\n\nrandom.seed(1)\nlarge = random.sample(range(1000), 20)\nassert insertion_sort(large) == sorted(large)\nprint(\"ランダム20件: OK\")","key":"KtsPSJ6ZmY"},{"type":"outputs","id":"AAk4PUCjEVUdL0BX0fhNU","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"入力: [12, 11, 13, 5, 6]\n出力: [5, 6, 11, 12, 13]\nほぼソート済み100件: OK\nランダム20件: OK\n"},"children":[],"key":"aqRkM9kEJi"}],"key":"CgEOBpZx0L"}],"key":"rDquVyhMK3"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ステップ可視化","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NLPxdG9Fpw"}],"identifier":"id","label":"ステップ可視化","html_id":"id-1","implicit":true,"key":"OaWh2Qf9FX"}],"key":"z9KwDrxfSG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def insertion_sort_verbose(arr: list) -> list:\n    a = arr.copy()\n    for i in range(1, len(a)):\n        key = a[i]\n        j = i - 1\n        while j >= 0 and a[j] > key:\n            a[j + 1] = a[j]\n            j -= 1\n        a[j + 1] = key\n        print(f\"i={i}, key={key}: {a}\")\n    return a\n\ndata = [5, 3, 8, 1, 4]\nprint(\"入力:\", data)\ninsertion_sort_verbose(data)","key":"tCjlPuKVVX"},{"type":"outputs","id":"19LPEDbMoHVMQd-McFnMz","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"入力: [5, 3, 8, 1, 4]\ni=1, key=3: [3, 5, 8, 1, 4]\ni=2, key=8: [3, 5, 8, 1, 4]\ni=3, key=1: [1, 3, 5, 8, 4]\ni=4, key=4: [1, 3, 4, 5, 8]\n"},"children":[],"key":"rFnlIH8zpL"},{"type":"output","jupyter_data":{"output_type":"execut