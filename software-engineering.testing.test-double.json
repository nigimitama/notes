client.get_weather(city)\n        return f\"The weather in {city} is {weather}.\"","visibility":"show","key":"e7nVwHhYpm"},{"type":"outputs","id":"XuQEq5q5z48B2eJ_4ihtZ","children":[],"visibility":"show","key":"No2Xqz6Rxq"}],"visibility":"show","key":"Awoh1R2EdF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"WeatherAPIStubを作り、決め打ちの値を返すようにする","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"j35IQHi4N0"}],"key":"ZhRMkK2pHR"}],"key":"QrAz5HQEbV"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# --- スタブの実装 ---\nclass WeatherAPIStub(WeatherAPIClient):\n    def get_weather(self, city: str) -> str:\n        # 都市ごとに決め打ちの返り値を用意する\n        stub_data = {\n            \"Tokyo\": \"Sunny\",\n            \"Osaka\": \"Cloudy\",\n        }\n        return stub_data[city]\n\n# --- テスト ---\ndef test_weather_service():\n    stub_client = WeatherAPIStub()  # ← スタブを注入\n    service = WeatherService(api_client=stub_client)\n\n    assert service.get_forecast_message(\"Tokyo\") == \"The weather in Tokyo is Sunny.\"\n    assert service.get_forecast_message(\"Osaka\") == \"The weather in Osaka is Cloudy.\"\n\ntest_weather_service()","visibility":"show","key":"idBJmMY001"},{"type":"outputs","id":"4gwpdC5SCRX0w6MqPDxpY","children":[],"visibility":"show","key":"ivSn7q6YXn"}],"visibility":"show","key":"G1UtiuGjXZ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"unittestのMagicMockでスタブを書く","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JbN5ydOANx"}],"identifier":"unittest-magicmock","label":"unittestのMagicMockでスタブを書く","html_id":"unittest-magicmock","implicit":true,"key":"mBXfXZ87x6"},{"t