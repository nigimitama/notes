j4VubSmyKs"},{"type":"text","value":"の最小値のインデックス（lower_bound）","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"zVz5hIaK2v"}],"key":"k9k9YQ8sA8"}],"key":"NIIJH38Kbf"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"bisect_right(a, x)","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"nlBd1TwbRy"},{"type":"text","value":" → ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"DRwr49tyY4"},{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"x より大きい","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"Pc9cpaa3lc"}],"key":"a4aqpmu3Ji"},{"type":"text","value":"最小値のインデックス（upper_bound）","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"R00HYVbc2N"}],"key":"r9EVS09Hu6"}],"key":"Wa3gaf0560"}],"key":"yMFOCmRv23"}],"key":"omA1NjmwxB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"a = [1, 3, 5, 5, 7, 9]\n\ndef lower_bound(a, x):\n    \"\"\"x 以上の最小値を返す（存在しなければ None）\"\"\"\n    i = bisect_left(a, x)\n    return a[i] if i < len(a) else None\n\ndef upper_bound(a, x):\n    \"\"\"x より大きい最小値を返す（存在しなければ None）\"\"\"\n    i = bisect_right(a, x)\n    return a[i] if i < len(a) else None\n\nprint(lower_bound(a, 5))   # 5  (5以上の最小値)\nprint(upper_bound(a, 5))   # 7  (5より大きい最小値)\nprint(lower_bound(a, 6))   # 7  (6以上の最小値)\nprint(upper_bound(a, 9))   # None (9より大きい値がない)","key":"mv9eojrPbS"},{"type":"outputs","id":"QXkxHcv5GDkrGLvNkNjvy","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"5\n7\n7\nNone\n"},"children":[],"key":"hdnEDXGoJM"}],"key":"VMP2vWm1bl"}],"key":"M9FNql0Z3T"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":4,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"範囲内の要素数を数える","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AFyzKYs6WH"}],"identifier":"id","label":"範囲内の要素数を数える","html_id":"id-3","implicit":true,"key":"LMTrg61xtu"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"inlineCode","value":"bisect_right(a, hi) - bisect_left(a, lo)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"EqXtmoCmiS"},{"type":"text","value":" で ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AGCSzrUxeF"},{"type":"inlineCode","value":"lo <= x <= hi","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pKvCX13AkM"},{"type":"text","value":" を満たす要素数が求まる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pGIF38UZ0H"}],"key":"Iejm7w3a3K"}],"key":"wquPzLpjyK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def count_range(a, lo, hi):\n    \"\"\"a の中で lo <= x <= hi を満たす要素数を返す\"\"\"\n    return bisect_right(a, hi) - bisect_left(a, lo)\n\na = [1, 2, 3, 4, 5, 6, 7]\nprint(count_range(a, 3, 5))   # 3  ([3, 4, 5])\nprint(count_range(a, 1, 7))   # 7\nprint(count_range(a, 4, 4))   # 1  ([4])","key":"dfTs5d1odV"},{"type":"outputs","id":"yjptDgkAGr-sx-2UPqSGL","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"3\n7\n1\n"},"children":[],"key":"eVJ3HwgliY"}],"key":"YzAUMGRbbU"}],"key":"xMDRMEJDA7"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考文献","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"A1FDpdooi8"}],"identifier":"id","label":"参考文献","html_id":"id-4","implicit":true,"key":"S