"value":"jjbrophy47/tree_influence: Influence Estimation for Gradient-Boosted Decision Trees","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"UWOqLOXP3q"}],"urlSource":"https://github.com/jjbrophy47/tree_influence","error":true,"key":"B4v8vRb9O0"}],"key":"YXHqWbCu55"}],"key":"Wg5TLYF7Pc"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Paper: ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"Q2JHIbBZUF"},{"type":"link","url":"https://jmlr.org/papers/v24/22-0449.html","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Brophy, J., Hammoudeh, Z., & Lowd, D. (2023). Adapting and Evaluating Influence-Estimation Methods for Gradient-Boosted Decision Trees. J. Mach. Learn. Res., 24, 154-1.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"E3fkEbEOqg"}],"urlSource":"https://jmlr.org/papers/v24/22-0449.html","key":"uKIK68earz"}],"key":"P9h9ByCvaQ"}],"key":"ybOZdNjBSX"}],"key":"Qc2WjWPSfy"}],"key":"u2kUF7q6f6"},{"type":"block","kind":"notebook-content","children":[{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":1,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"❌️ 途中で ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"T687LdNCjN"},{"type":"inlineMath","value":"n","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>n</mi></mrow><annotation encoding=\"application/x-tex\">n</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">n</span></span></span></span>","key":"Y44hQlEMX5"},{"type":"text","value":"×木の数のnp.arrayを作るタイミングがあり、例えば100万レコード×5万の決定木ではfloat32だとしても186GiBになってしまう","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"akQj4E1hj7"}],"key":"DVIPd75iYj"}],"key":"oMPyOq5M0k"},{"type":"listItem","spread":true,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"❌️ 2024年ごろから更新が停止しておりPython3.11以降はサポートしていない","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"A2hm1BCZbh"}],"key":"ZC2enphh7O"}],"key":"fJgLhiUoBI"}],"key":"n7OfxeBXVa"}],"key":"VdaOEeIh9a"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"import numpy as np\nfrom sklearn.datasets import load_iris\nfrom sklearn.model_selection import train_test_split\nfrom lightgbm import LGBMClassifier\nfrom tree_influence.explainers import BoostIn\n\n# load iris data\ndata = load_iris()\nX, y = data['data'], data['target']\n\n# use two classes, then split into train and test\nidxs = np.where(y != 2)[0]\nX, y = X[idxs], y[idxs]\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.1, random_state=1)\n\n# train GBDT model\nmodel = LGBMClassifier().fit(X_train, y_train)\n\n# fit influence estimator\nexplainer = BoostIn().fit(model, X_train, y_train)\n\n# estimate training influences on each test instance\ninfluence = explainer.get_local_influence(X_test, y_test)  # shape=(no. train, no. test)\n\n# extract influence values for the first test instance\nvalues = influence[:, 0]  # shape=(no. train,)\n\n# sort training examples from:\n# - most positively influential (decreases loss of the test instance the most), to\n# - most negatively influential (increases loss of the test instance the most)\ntraining_idxs = np.argsort(values)[::-1]","position":{"start":{"line":1,"column":1},"end":{"line":33,"column":1}},"key":"beQ00xyzzm"}],"key":"KgtsTzKd2w"}],"key":"PFQyjARKU1"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Influence Function 線形回帰での例","url":"/machine-learning/explainability/influence-function-with-linear-regression","group":"機械学習"},"next":{"title":"Model Class Reliance (MCR)","url":"/machine-learning/explainability/model-class-reliance","group":"機械学習"}}},"domain":"http://localhost:3000"}