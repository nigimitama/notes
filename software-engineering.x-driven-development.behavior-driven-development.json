d into integer\n    assert number > 1 or number == 0\n    context.tests_count = number\n\n@then('behave will test them for us!')\ndef step_impl(context):\n    assert context.failed is False\n    assert context.tests_count >= 0","position":{"start":{"line":15,"column":1},"end":{"line":32,"column":1}},"key":"vdAFBiI3Ys"}],"key":"M53iGdBcQU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"link","url":"https://github.com/pytest-dev/pytest-bdd","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Pytest-BDD","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OCDQ16s6Gm"}],"urlSource":"https://github.com/pytest-dev/pytest-bdd","error":true,"key":"uZcut200AQ"},{"type":"text","value":"（Python）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xStZ72T2Ts"}],"identifier":"pytest-bdd-python","label":"Pytest-BDD（Python）","html_id":"pytest-bdd-python","implicit":true,"key":"tcX03B6WvY"},{"type":"code","lang":"gherkin","value":"# content of publish_article.feature\n\nFeature: Blog\n    A site where you can publish your articles.\n\n    Scenario: Publishing the article\n        Given I'm an author user\n        And I have an article\n\n        When I go to the article page\n        And I press the publish button\n\n        Then I should not see the error message\n        And the article should be published","position":{"start":{"line":3,"column":1},"end":{"line":18,"column":1}},"key":"scEc6hPrdw"},{"type":"code","lang":"python","value":"# content of test_publish_article.py\n\nfrom pytest_bdd import scenario, given, when, then\n\n@scenario('publish_article.feature', 'Publishing the article')\ndef test_publish():\n    pass\n\n\n@given(\"I'm an author user\")\ndef author_user(auth, author):\n    auth['user'] = author.user\n\n\n@given(\"I have an article\", target_fixture=\"article\")\ndef article(author):\n    return create_test_article(author=author)\n\n\n@when(\"I go to the article page\")\ndef go_to_article(article, browser):\n    browser.visit(urljoin(browser.url, '/manage/articles/{0}/'.format(article.id)))\n\n\n@when(\"I press the publish button\")\ndef publish_article(browser):\n    browser.find_by_css('button[name=publish]').first.click()\n\n\n@then(\"I should not see the error message\")\ndef no_error_message(browser):\n    with pytest.raises(ElementDoesNotExist):\n        browser.find_by_css('.message.error').first\n\n\n@then(\"the article should be published\")\ndef article_is_published(article):\n    article.refresh()  # Refresh the object in the SQLAlchemy session\n    assert article.is_published","position":{"start":{"line":21,"column":1},"end":{"line":61,"column":1}},"key":"imL40VOpKx"}],"key":"wk91oGRDq2"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"link","url":"https://rspec.toolboxforweb.xyz/ja/","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"RSpec","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"BwvThy7uoo"}],"urlSource":"https://rspec.toolboxforweb.xyz/ja/","key":"jjfdAlCJBh"},{"type":"text","value":"（Ruby）","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"aHqG2X9vfA"}],"identifier":"rspec-ruby","label":"RSpec（Ruby）","html_id":"rspec-ruby","implicit":true,"key":"x8begkIn04"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"RSpecはRubyのテストフレームワーク。Gherkin記法は使わないがBDDを謳っている","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"spgbsncbn3"}],"key":"UbaXzxveyS"},{"type":"blockquote","position":{"start":{"line":7,"column":1},"end":{"line":9,"column":1}},"