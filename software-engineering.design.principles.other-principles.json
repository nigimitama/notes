f peek_next_item(queue):\n    return queue[0]\n\ndef remove_next_item(queue):\n    queue.pop(0)","position":{"start":{"line":8,"column":1},"end":{"line":20,"column":1}},"key":"EVTicu6lUT"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"CQSを","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"T79R5ScDLD"},{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"システム全体","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"H84uH6n23A"}],"key":"UDMX0rh3PV"},{"type":"text","value":"の書き込み・読み取りモデルの分離にまで拡張した設計が ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"lWdIh7WAIv"},{"type":"link","url":"/software-engineering/software-architecture/distributed/cqrs","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"CQRS","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"IG4MtfCNuS"}],"urlSource":"../../software_architecture/distributed/cqrs.ipynb","dataUrl":"/software-engineering.software-architecture.distributed.cqrs.json","internal":true,"protocol":"file","key":"mqQCEsxMkE"},{"type":"text","value":"。\nCQSが1メソッド単位のミクロな規律であるのに対し、CQRSはモデル・データストアのレベルにまで分離を広げたマクロな適用といえる。","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"D0i4310tFr"}],"key":"AfXdilZ9gL"}],"key":"YQbh740tsN"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"最小驚きの原則（Principle of Least Astonishment）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"iHKjsk9qjB"}],"identifier":"id-principle-of-least-astonishment","label":"最小驚きの原則（Principle of Least Astonishment）","html_id":"id-principle-of-least-astonishment","implicit":true,"key":"JNatYuovW5"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"インターフェースや関数の振る舞いは、利用者の直感的な予想と一致しているべき、という原則。名前から推測される動作と\n実際の動作にギャップがあると、バグの温床になったり誤用を招いたりする。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"r0dSCJrhxB"}],"key":"n54iCIa4fP"},{"type":"code","lang":"python","value":"# 驚きがある例：get_ という名前なのに副作用（保存）を持つ\ndef get_user(user_id):\n    user = db.find(user_id)\n    log_access(user_id)  # ログを書き込むだけならまだしも…\n    user.last_accessed = now()\n    db.save(user)  # 「取得」のはずが実は書き込みも行っている\n    return user","position":{"start":{"line":6,"column":1},"end":{"line":14,"column":1}},"key":"MXgQvPK8gn"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"「読み取り専用に見える関数名なのに書き込みをする」は上述のCQS違反の典型例でもあり、最小驚きの原則とCQSは\n同じ問題を別の角度から捉えたものといえる。","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"hEVh9h5UVe"}],"key":"BAXh6XdqIy"}],"key":"CXdUsFGqol"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"契約による設計・防御的プログラミング","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tORev3lyK0"}],"identifier":"id","label":"契約による設計・防御的プログラミング","html_id":"id","implicit":true,"key":"xVuiWQUTGt"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"契約による設計（Design by Contract, DbC）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bu0iUAXkgN"}],"key":"xlLQnhMQOH"},{"type":"text","value":"：関数やメソッドが満たすべき「事前条件（呼び出す側の責任）」\n「事後条件（実装する側の責任）」「不変条件」を契約として明示する考え方。Bertrand Meyer が Eiffel 言語で提唱した。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Jik3UruvIR"}],"key":"yuwjBkIPiE"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"防御的プログラミング（Defensive Programming）","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"QheWd4RB2p"}],"key":"ySPGlIYgBY"},{"type":"text","value":"：呼び出し側が契約を破る可能性を前提に、関数の内部で入力を\n検証し続ける考え方。","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"SK4IIpGtCq"}],"key":"InebGZCSFz"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"両者はしばしば対立する考え方として語られる。DbCは「契約を守るのは呼び出し側の責任。契約違反はバグなので早期に\n例外で落とす」という立場を取り、際限のない防御的チェックによるコードの肥大化を避けようとする。","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"aK3K45tBMj"}],"key":"sOObfin0hC"},{"type":"code","lang":"python","value":"def withdraw(self, amount):\n    assert amount > 0, \"事前条件違反: amount は正の数でなければならない\"  # 契約の明示\n    assert amount <= self.balance, \"事前条件違反: 残高不足\"\n    self.balance -= amount\n    assert self.balance >= 0  # 事後条件・不変条件の確認","position":{"start":{"line":12,"column":1},"end":{"line":18,"column":1}},"key":"selhaZsyPk"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"一方で、","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"slGj3p3aiY"},{"type":"strong","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"外部からの入力","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"MXcoUlnPmU"}],"key":"FO8CPKAC7c"},{"type":"text","value":"（ユーザー入力、外部APIのレスポンスなど、契約を強制できない境界）に対しては防御的な\n検証が必要になる。「信頼できる内部コード間ではDbC的に契約を明示し、信頼できない外部境界では防御的に検証する」という\n使い分けが実践的。","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"arMrTGw3BO"}],"key":"BtZW4vMjg1"}],"key":"yFJkjfKRrO"}],"key":"R0W2SAgEsj"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"基本原則（KISS・YAGNI・DRYほか）","url":"/software-engineering/design/principles/basic-principles","group":"ソフトウェア工学"},"next":{"title":"デザインパターン","url":"/software-engineering/design/design-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}