f peek_next_item(queue):\n    return queue[0]\n\ndef remove_next_item(queue):\n    queue.pop(0)","position":{"start":{"line":8,"column":1},"end":{"line":20,"column":1}},"key":"P2vkXy1dqZ"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"CQSを","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"NpnWUSBdaw"},{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"システム全体","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"uP1hXORbqN"}],"key":"APyHtJ9Chj"},{"type":"text","value":"の書き込み・読み取りモデルの分離にまで拡張した設計が ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"VxQCldItuY"},{"type":"link","url":"/software-engineering/software-architecture/distributed/cqrs","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"CQRS","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"DvCOHZhljt"}],"urlSource":"../../software_architecture/distributed/cqrs.ipynb","dataUrl":"/software-engineering.software-architecture.distributed.cqrs.json","internal":true,"protocol":"file","key":"ZXTf1NE3hd"},{"type":"text","value":"。\nCQSが1メソッド単位のミクロな規律であるのに対し、CQRSはモデル・データストアのレベルにまで分離を広げたマクロな適用といえる。","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"NYQat9zjcC"}],"key":"ysHoGiatme"}],"key":"ZHIbnQJgwD"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"最小驚きの原則（Principle of Least Astonishment）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Q2aTnZAbYe"}],"identifier":"id-principle-of-least-astonishment","label":"最小驚きの原則（Principle of Least Astonishment）","html_id":"id-principle-of-least-astonishment","implicit":true,"key":"DYvL5TqIfT"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"インターフェースや関数の振る舞いは、利用者の直感的な予想と一致しているべき、という原則。名前から推測される動作と\n実際の動作にギャップがあると、バグの温床になったり誤用を招いたりする。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kjFxM2E4mL"}],"key":"XdcPLXtn80"},{"type":"code","lang":"python","value":"# 驚きがある例：get_ という名前なのに副作用（保存）を持つ\ndef get_user(user_id):\n    user = db.find(user_id)\n    log_access(user_id)  # ログを書き込むだけならまだしも…\n    user.last_accessed = now()\n    db.save(user)  # 「取得」のはずが実は書き込みも行っている\n    return user","position":{"start":{"line":6,"column":1},"end":{"line":14,"column":1}},"key":"UMVRFodF9F"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"「読み取り専用に見える関数名なのに書き込みをする」は上述のCQS違反の典型例でもあり、最小驚きの原則とCQSは\n同じ問題を別の角度から捉えたものといえる。","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"sqhBs64w9i"}],"key":"SAKOCbaoq7"}],"key":"FOU8Mp9UV4"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"契約による設計・防御的プログラミング","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gRi1tx2Dil"}],"identifier":"id","label":"契約による設計・防御的プログラミング","html_id":"id","implicit":true,"key":"uk30xqqdOv"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"契約による設計（Design by Contract, DbC）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gP1JU6lYiR"}],"key":"OfsifhH5RD"},{"type":"text","value":"：関数やメソッドが満たすべき「事前条件（呼び出す側の責任）」\n「事後条件（実装する側の責任）」「不変条件」を契約として明示する考え方。Bertrand Meyer が Eiffel 言語で提唱した。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AcVTj1Tapn"}],"key":"VigkLVOyNx"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"防御的プログラミング（Defensive Programming）","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"iZPGS5ze7x"}],"key":"rNtYcMJ1c8"},{"type":"text","value":"：呼び出し側が契約を破る可能性を前提に、関数の内部で入力を\n検証し続ける考え方。","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"McZDT064Jf"}],"key":"h0mZ4Gyks5"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"両者はしばしば対立する考え方として語られる。DbCは「契約を守るのは呼び出し側の責任。契約違反はバグなので早期に\n例外で落とす」という立場を取り、際限のない防御的チェックによるコードの肥大化を避けようとする。","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"h4k6FJOMCM"}],"key":"NFqRCLcImp"},{"type":"code","lang":"python","value":"def withdraw(self, amount):\n    assert amount > 0, \"事前条件違反: amount は正の数でなければならない\"  # 契約の明示\n    assert amount <= self.balance, \"事前条件違反: 残高不足\"\n    self.balance -= amount\n    assert self.balance >= 0  # 事後条件・不変条件の確認","position":{"start":{"line":12,"column":1},"end":{"line":18,"column":1}},"key":"Nm6fDBzsl0"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"一方で、","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"nQno3GdedN"},{"type":"strong","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"外部からの入力","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"hVnF7Axsx1"}],"key":"AInhO2ruWE"},{"type":"text","value":"（ユーザー入力、外部APIのレスポンスなど、契約を強制できない境界）に対しては防御的な\n検証が必要になる。「信頼できる内部コード間ではDbC的に契約を明示し、信頼できない外部境界では防御的に検証する」という\n使い分けが実践的。","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"FvoDUtNeZl"}],"key":"Pj9NmdRe6C"}],"key":"qxY82Ych8f"}],"key":"FMVVZRneao"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"基本原則（KISS・YAGNI・DRYほか）","url":"/software-engineering/design/principles/basic-principles","group":"ソフトウェア工学"},"next":{"title":"デザインパターン","url":"/software-engineering/design/design-patterns","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}