    return []\n    return [node.val] + preorder(node.left) + preorder(node.right)\n\ndef inorder(node):\n    \"\"\"中順（左 → 根 → 右）\"\"\"\n    if node is None:\n        return []\n    return inorder(node.left) + [node.val] + inorder(node.right)\n\ndef postorder(node):\n    \"\"\"後順（左 → 右 → 根）\"\"\"\n    if node is None:\n        return []\n    return postorder(node.left) + postorder(node.right) + [node.val]\n\ndef bfs(root):\n    \"\"\"幅優先探索（BFS）\"\"\"\n    if root is None:\n        return []\n    result = []\n    queue = deque([root])\n    while queue:\n        node = queue.popleft()\n        result.append(node.val)\n        if node.left:\n            queue.append(node.left)\n        if node.right:\n            queue.append(node.right)\n    return result\n\n\n#       4\n#      / \\\n#     2   6\n#    / \\ / \\\n#   1  3 5  7\nroot = TreeNode(4)\nroot.left = TreeNode(2)\nroot.right = TreeNode(6)\nroot.left.left = TreeNode(1)\nroot.left.right = TreeNode(3)\nroot.right.left = TreeNode(5)\nroot.right.right = TreeNode(7)\n\nprint(\"preorder  :\", preorder(root))   # [4, 2, 1, 3, 6, 5, 7]\nprint(\"inorder   :\", inorder(root))    # [1, 2, 3, 4, 5, 6, 7]\nprint(\"postorder :\", postorder(root))  # [1, 3, 2, 5, 7, 6, 4]\nprint(\"BFS       :\", bfs(root))        # [4, 2, 6, 1, 3, 5, 7]","key":"wiZ9u7jb4a"},{"type":"outputs","id":"tBgUaW-xZU-ERK5rNKjlu","children":[],"key":"W1Ko1rPVua"}],"key":"Usj4jJlAZt"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"二分探索木（Binary Search Tree, BST）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VNaFk5SLnP"}],"identifier":"id-binary-search-tree-bst","label":"二分探索木（Binary Search Tree, BST）","html_id":"id-binary-search-tree-bst","implicit":true,"key":"bnxLQP2E0s"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"