er(self.root)","key":"ZXs9E3Uws8"},{"type":"outputs","id":"YE7oxU8DpN_ocnHrOmPmj","children":[],"key":"LARiKJ1uyq"}],"key":"mtwp2gMDfe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bst = BST()\nfor v in [5, 3, 7, 1, 4, 6, 8]:\n    bst.insert(v)\n\nprint(\"inorder:\", bst.inorder())   # [1, 3, 4, 5, 6, 7, 8]\nprint(\"search 4:\", bst.search(4))  # True\nprint(\"search 9:\", bst.search(9))  # False\n\nbst.delete(3)\nprint(\"3を削除後:\", bst.inorder())  # [1, 4, 5, 6, 7, 8]","key":"UOxcIULjVz"},{"type":"outputs","id":"vZUyXY6aaWz5bg1EGr6tU","children":[],"key":"wUJUoTUz5D"}],"key":"Albc9K3EGH"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量まとめ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gUWkUU1qz1"}],"identifier":"id","label":"計算量まとめ","html_id":"id","implicit":true,"key":"qn1tp5rJ4A"},{"type":"table","position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"操作","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"k7XATD91jM"}],"key":"vWcYjKkjsa"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"平均（平衡時）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YiyRcop6yN"}],"key":"l7OAnfJk9u"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"最悪（偏った木）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"j3T41oqasM"}],"