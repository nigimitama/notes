er(self.root)","key":"OnxK9pg131"},{"type":"outputs","id":"bhf1zWWAvCqxgFEQz1Yao","children":[],"key":"RLdPfc869K"}],"key":"RL28xjSwJM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bst = BST()\nfor v in [5, 3, 7, 1, 4, 6, 8]:\n    bst.insert(v)\n\nprint(\"inorder:\", bst.inorder())   # [1, 3, 4, 5, 6, 7, 8]\nprint(\"search 4:\", bst.search(4))  # True\nprint(\"search 9:\", bst.search(9))  # False\n\nbst.delete(3)\nprint(\"3を削除後:\", bst.inorder())  # [1, 4, 5, 6, 7, 8]","key":"QtnlSDpnxI"},{"type":"outputs","id":"5iU3dcaGAxmjI4CCsZH64","children":[],"key":"VT5qa3ScU7"}],"key":"YfjzEnssNj"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量まとめ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gjTgamqcqS"}],"identifier":"id","label":"計算量まとめ","html_id":"id","implicit":true,"key":"Y4rPwNhIku"},{"type":"table","position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"操作","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ZjiK24hFpK"}],"key":"Y4V6qxdxf5"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"平均（平衡時）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MCvYm7plG0"}],"key":"wLv6KA9lbm"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"最悪（偏った木）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KkKWdCAbgS"}],"