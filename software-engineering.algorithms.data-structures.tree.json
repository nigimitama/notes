er(self.root)","key":"PhrWnMi3yj"},{"type":"outputs","id":"taz4TsArrb9bYvEA2mZg6","children":[],"key":"HMGYHkjDIA"}],"key":"NVDy1acjvY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bst = BST()\nfor v in [5, 3, 7, 1, 4, 6, 8]:\n    bst.insert(v)\n\nprint(\"inorder:\", bst.inorder())   # [1, 3, 4, 5, 6, 7, 8]\nprint(\"search 4:\", bst.search(4))  # True\nprint(\"search 9:\", bst.search(9))  # False\n\nbst.delete(3)\nprint(\"3を削除後:\", bst.inorder())  # [1, 4, 5, 6, 7, 8]","key":"mcUAVPtrQF"},{"type":"outputs","id":"xs0xnP7VQ6ueS06bI8WEq","children":[],"key":"aoRl7IZfW5"}],"key":"wMFYKatujS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量まとめ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TxJgnO9WLY"}],"identifier":"id","label":"計算量まとめ","html_id":"id","implicit":true,"key":"WRzYaFTAzJ"},{"type":"table","position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"操作","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"spC2RZvz7M"}],"key":"iQp3x0uNvi"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"平均（平衡時）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Wh3nTbsLht"}],"key":"FYgJnRDI9U"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"最悪（偏った木）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"PtP6WxDUph"}],"