(sl)              # SortedList([1, 3, 4, 5, 6, 7])\nprint(sl[0])           # 最小値: 1\nprint(sl[-1])          # 最大値: 7\nsl.remove(3)\nprint(sl)              # SortedList([1, 4, 5, 6, 7])\nprint(sl.bisect_left(5))  # 5以上の最初のインデックス: 2","key":"VI0CLtZ31O"},{"type":"outputs","id":"Y8uUNxlZtqsqR6AZka5jc","children":[],"key":"nuXus7kPE3"}],"key":"Jfs1fI3xd3"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"木の高さ・サイズ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EvG0rz8pVy"}],"identifier":"id","label":"木の高さ・サイズ","html_id":"id-1","implicit":true,"key":"GIe2uqUJyj"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"再帰を使うと木のプロパティを簡潔に計算できる。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"D4D5LBs7I3"}],"key":"E9J8xOkDKH"}],"key":"SsDPwH1pRK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def height(node):\n    \"\"\"木の高さ（葉のheightは0）\"\"\"\n    if node is None:\n        return -1\n    return 1 + max(height(node.left), height(node.right))\n\ndef size(node):\n    \"\"\"木のノード数\"\"\"\n    if node is None:\n        return 0\n    return 1 + size(node.left) + size(node.right)\n\n\nbst2 = BST()\nfor v in [5, 3, 7, 1, 4, 6, 8]:\n    bst2.insert(v)\n\nprint(\"height:\", height(bst2.root))  # 2\nprint(\"size  :\", size(bst2.root))    # 7","key":"GkICRKOzRt"},{"type":"outputs","id":"KWG45_5zEYHaawWkbXEo_","children":[],"key":"xokUWatBxX"}],"key":"DSbQlHIKd9"}],"key":"kx4a4pyNjo"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"ハッシュテーブル","url":"/software-engineering/algorithms/data-structures/hash-table","group":"ソフトウェア工学"},"next":{"title":"グラフ","url":"/software-engineering/algorithms/data-structures/graph","group":"ソフ