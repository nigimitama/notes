er(self.root)","key":"Ifqkf9wkGS"},{"type":"outputs","id":"cpCgZ4QpCZJG38skSimnU","children":[],"key":"wfsdsmQaTA"}],"key":"PvGVzLJehi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bst = BST()\nfor v in [5, 3, 7, 1, 4, 6, 8]:\n    bst.insert(v)\n\nprint(\"inorder:\", bst.inorder())   # [1, 3, 4, 5, 6, 7, 8]\nprint(\"search 4:\", bst.search(4))  # True\nprint(\"search 9:\", bst.search(9))  # False\n\nbst.delete(3)\nprint(\"3を削除後:\", bst.inorder())  # [1, 4, 5, 6, 7, 8]","key":"U7h39ixDgZ"},{"type":"outputs","id":"h9n7Vmof2YuobFkaAzd1v","children":[],"key":"NdV96GRQ4Q"}],"key":"JIC9agfJ16"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量まとめ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"N2ZXRh03n3"}],"identifier":"id","label":"計算量まとめ","html_id":"id","implicit":true,"key":"aMyMMRFkj8"},{"type":"table","position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"操作","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jGNUhYHVCI"}],"key":"GiAizgjwAX"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"平均（平衡時）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xnKJIv1alY"}],"key":"Xm0QGqqbu4"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"最悪（偏った木）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JhFjitJqXg"}],"