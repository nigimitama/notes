er(self.root)","key":"hrbMSi6wNI"},{"type":"outputs","id":"EEMMcUwdaG3NLlDQSTGUU","children":[],"key":"Ymx2PXdy8d"}],"key":"qzgtBwN97Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bst = BST()\nfor v in [5, 3, 7, 1, 4, 6, 8]:\n    bst.insert(v)\n\nprint(\"inorder:\", bst.inorder())   # [1, 3, 4, 5, 6, 7, 8]\nprint(\"search 4:\", bst.search(4))  # True\nprint(\"search 9:\", bst.search(9))  # False\n\nbst.delete(3)\nprint(\"3を削除後:\", bst.inorder())  # [1, 4, 5, 6, 7, 8]","key":"QNPOBcyN12"},{"type":"outputs","id":"mbjMomx-ZGjxR8mPx2y0t","children":[],"key":"yTCHI8cwrz"}],"key":"zp5rinnRmO"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"計算量まとめ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ibyk0dw94H"}],"identifier":"id","label":"計算量まとめ","html_id":"id","implicit":true,"key":"D7pu0LH1J9"},{"type":"table","position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"操作","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bNsJtjrbit"}],"key":"NniK3k10eg"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"平均（平衡時）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"PSeHdTAGjj"}],"key":"lZUOMBgxfx"},{"type":"tableCell","header":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"最悪（偏った木）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IcrBCIluD8"}],"