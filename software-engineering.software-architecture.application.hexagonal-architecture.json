        result = self.db.query(\"SELECT * FROM orders WHERE id = ?\", order_id)\n        return Order(**result)\n\n# 外部サービスアダプター\nclass StripePaymentGateway(PaymentGateway):\n    def process_payment(self, amount, card_info):\n        # Stripe API呼び出し\n        pass","position":{"start":{"line":85,"column":1},"end":{"line":106,"column":1}},"key":"t1WSrbdbt7"}],"key":"UzUekDigvI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"完全な実装例","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BmwqpeEvD8"}],"identifier":"id","label":"完全な実装例","html_id":"id-2","implicit":true,"key":"F1q6pqMAMS"},{"type":"code","lang":"python","value":"# === アプリケーションコア ===\n\n# ドメインモデル\nclass Order:\n    def __init__(self, id, customer_id, items, total):\n        self.id = id\n        self.customer_id = customer_id\n        self.items = items\n        self.total = total\n\n# 出力ポート（インターフェース）\nclass OrderRepository(ABC):\n    @abstractmethod\n    def save(self, order): pass\n    \n    @abstractmethod\n    def find_by_id(self, order_id): pass\n\n# 入力ポートの実装（ユースケース）\nclass OrderServiceImpl(OrderService):\n    def __init__(self, order_repository: OrderRepository):\n        self.order_repository = order_repository\n    \n    def create_order(self, customer_id, items):\n        total = sum(item.price for item in items)\n        order = Order(\n            id=generate_id(),\n            customer_id=customer_id,\n            items=items,\n            total=total\n        )\n        self.order_repository.save(order)\n        return order\n    \n    def get_order(self, order_id):\n        return self.order_repository.find_by_id(order_id)\n\n# === アダプター ===\n\n# 入力アダプター（REST API）\nclass RestOrderController:\n    def __init__(self, order_service: OrderService):\n        self.order_service = order_service\n    \n    def post_order(self, request):\n        order = self.order_service.create_order(\n            request[\"customer_id\"],\n            request[\"items\"]\n        )\n        return {\"order_id\": order.id}\n\n# 出力アダプター（データベース）\nclass MongoOrderRepository(OrderRepository):\n    def __init__(self, mongo_client):\n        self.db = mongo_client.orders\n    \n    def save(self, order):\n        self.db.insert_one({\n            \"id\": order.id,\n            \"customer_id\": order.customer_id,\n            \"items\": order.items,\n            \"total\": order.total\n        })\n    \n    def find_by_id(self, order_id):\n        result = self.db.find_one({\"id\": order_id})\n        return Order(**result) if result else None","position":{"start":{"line":3,"column":1},"end":{"line":71,"column":1}},"key":"Ckra9nLMTE"}],"key":"ChtXfoMwIX"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"メリット","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"az0BXxce98"}],"identifier":"id","label":"メリット","html_id":"id-3","implicit":true,"key":"z6P2riNEQW"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"テスタビリティ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pd3Q2UIXuV"}],"key":"GZJkdC4qVV"}],"key":"w7HBRAFRQJ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4