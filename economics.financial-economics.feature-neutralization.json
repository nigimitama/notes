{"version":3,"kind":"Notebook","sha256":"6b91c3871d1434c6d7c93460e1055fc118ecf75f3145dd365eef98b1abf67167","slug":"economics.financial-economics.feature-neutralization","location":"/economics/financial_economics/feature_neutralization.ipynb","dependencies":[],"frontmatter":{"title":"Feature Neutralization","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":2}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/economics/financial_economics/feature_neutralization.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/economics/financial_economics/feature_neutralization.ipynb","exports":[{"format":"ipynb","filename":"feature_neutralization.ipynb","url":"/notes/build/feature_neutralizati-452ee6ce8cfc7baa591d5bbcd020c5d7.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"feature neutralization（factor neutralization）はKaggleやNumeraiで使われる特徴量の変換手法","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JQaXN9L39y"}],"key":"m3OkmXgacX"},{"type":"blockquote","position":{"start":{"line":5,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"feature neutralizationはneutralにしたい変数を、ターゲットに対して直交化して置き換える処理をしています。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"D6EoxNXl6X"}],"key":"EjxnBy96p0"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"link","url":"https://yaakublog.com/numerai-feature-neutralization","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"feature neutralizationによる正則化 | Coding Memorandum","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"IcBCWVOGgO"}],"urlSource":"https://yaakublog.com/numerai-feature-neutralization","key":"gHhmgki82Z"}],"key":"LvySeu10x8"}],"key":"Vcco09RHxT"}],"key":"t2mfIbdqXr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import pandas as pd\nimport numpy as np\n\ndef neutralize_series(series, by, proportion=1.0):\n    scores = series.values.reshape(-1, 1)\n    exposures = by.values.reshape(-1, 1)\n\n    # this line makes series neutral to a constant column so that it's centered and for sure gets corr 0 with exposures\n    exposures = np.hstack(\n        (exposures, np.array([np.mean(series)] * len(exposures)).reshape(-1, 1))\n    )\n\n    correction = proportion * (exposures.dot(np.linalg.lstsq(exposures, scores)[0]))\n    corrected_scores = scores - correction\n    neutralized = pd.Series(corrected_scores.ravel(), index=series.index)\n    return neutralized","key":"RcyGlfQtVy"},{"type":"outputs","id":"Fa5HPJwda4VE5eTtPFc_y","children":[],"key":"GuztLtcpR2"}],"key":"aLgvKmrI36"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nn = 100\nnp.random.seed(0)\nx = np.random.normal(size=n)\ny = 10 * x + np.random.normal(size=n)\n\ny_ = neutralize_series(pd.Series(y), pd.Series(x), proportion=1.0)\n\nfig, ax = plt.subplots()\nax.scatter(x, y, label=\"raw\")\nax.scatter(x, y_, label=\"neutralized\")\nax.set(xlabel=\"x\", ylabel=\"y\")\nax.legend()\nfig.show()","key":"CCwXIf4BnT"},{"type":"outputs","id":"Rm9wGYPbeypu5x4OdE88_","children":[{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"/tmp/ipykernel_331/527208119.py:13: FutureWarning: `rcond` parameter will change to the default of machine precision times ``max(M, N)`` where M and N are the input matrix dimensions.\nTo use the future default and silence this warning we advise to pass `rcond=None`, to keep using the old, explicitly pass `rcond=-1`.\n  correction = proportion * (exposures.dot(np.linalg.lstsq(exposures, scores)[0]))\n"},"children":[],"key":"FI6ESBctxq"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"fdee47b69b8f81593a023154f096c2fa","path":"/notes/build/fdee47b69b8f81593a023154f096c2fa.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Zr69SScfHr"}],"key":"cEe0xVeIXy"}],"key":"Xwho1KOkPA"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OskG1qmiki"}],"identifier":"id","label":"参考","html_id":"id","implicit":true,"key":"WNprI62RaR"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://www.kaggle.com/code/code1110/janestreet-avoid-overfit-feature-neutralization","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"[JaneStreet] Avoid Overfit: Feature Neutralization | Kaggle","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vf6rxuEBLT"}],"urlSource":"https://www.kaggle.com/code/code1110/janestreet-avoid-overfit-feature-neutralization","key":"lCrn25jbgf"}],"key":"RbZDzYpXZ5"}],"key":"JPdoNIKa2c"},{"type":"lis