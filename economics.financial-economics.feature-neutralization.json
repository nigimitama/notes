{"version":3,"kind":"Notebook","sha256":"6b91c3871d1434c6d7c93460e1055fc118ecf75f3145dd365eef98b1abf67167","slug":"economics.financial-economics.feature-neutralization","location":"/economics/financial_economics/feature_neutralization.ipynb","dependencies":[],"frontmatter":{"title":"Feature Neutralization","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"mitama","family":"mitama"},"name":"mitama","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/nigimitama/notes","copyright":"© mitama","numbering":{"title":{"offset":2}},"source_url":"https://github.com/nigimitama/notes/blob/main/book/economics/financial_economics/feature_neutralization.ipynb","edit_url":"https://github.com/nigimitama/notes/edit/main/book/economics/financial_economics/feature_neutralization.ipynb","exports":[{"format":"ipynb","filename":"feature_neutralization.ipynb","url":"/notes/build/feature_neutralizati-be207c9a04d900096ac94d5be3fca3a9.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"feature neutralization（factor neutralization）はKaggleやNumeraiで使われる特徴量の変換手法","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KTtgbDPhLo"}],"key":"y13eJEwnmA"},{"type":"blockquote","position":{"start":{"line":5,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"feature neutralizationはneutralにしたい変数を、ターゲットに対して直交化して置き換える処理をしています。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Ki6AelQfhU"}],"key":"Ndx7UYcwoJ"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"link","url":"https://yaakublog.com/numerai-feature-neutralization","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"feature neutralizationによる正則化 | Coding Memorandum","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"rgr9Ildh6s"}],"urlSource":"https://yaakublog.com/numerai-feature-neutralization","key":"dMtpSaLrVX"}],"key":"jT8dZ04ojr"}],"key":"E4kkvMeHIZ"}],"key":"sBs7NmlJVm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import pandas as pd\nimport numpy as np\n\ndef neutralize_series(series, by, proportion=1.0):\n    scores = series.values.reshape(-1, 1)\n    exposures = by.values.reshape(-1, 1)\n\n    # this line makes series neutral to a constant column so that it's centered and for sure gets corr 0 with exposures\n    exposures = np.hstack(\n        (exposures, np.array([np.mean(series)] * len(exposures)).reshape(-1, 1))\n    )\n\n    correction = proportion * (exposures.dot(np.linalg.lstsq(exposures, scores)[0]))\n    corrected_scores = scores - correction\n    neutralized = pd.Series(corrected_scores.ravel(), index=series.index)\n    return neutralized","key":"p7ighWAfFn"},{"type":"outputs","id":"JAg5e7vKMw48wbZ5Qkjpr","children":[],"key":"tuSJraWfYD"}],"key":"vVk4N8tS3n"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nn = 100\nnp.random.seed(0)\nx = np.random.normal(size=n)\ny = 10 * x + np.random.normal(size=n)\n\ny_ = neutralize_series(pd.Series(y), pd.Series(x), proportion=1.0)\n\nfig, ax = plt.subplots()\nax.scatter(x, y, label=\"raw\")\nax.scatter(x, y_, label=\"neutralized\")\nax.set(xlabel=\"x\", ylabel=\"y\")\nax.legend()\nfig.show()","key":"KXHTUl8ykh"},{"type":"outputs","id":"QnhSYvpj2gtCRMaspOv3Z","children":[{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"/tmp/ipykernel_331/