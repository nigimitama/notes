#!/bin/sh
# run dev server
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

HTML_PATH="$PROJECT_DIR/book/_build/html"
if [ ! -d "$HTML_PATH" ]; then
  echo "📙building a book..."
  cd "$PROJECT_DIR/book" && uv run jupyter-book build --html
fi
cd "$HTML_PATH" && python3 -m http.server
