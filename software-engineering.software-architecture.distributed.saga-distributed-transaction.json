,"column":1}},"key":"tn0BsB4USq"}],"key":"gXJK3uhug0"},{"type":"text","value":"\nを逆順に実行することで、全体の整合性を（結果整合性として）保つ。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ogn0DRIW3Z"}],"key":"v0MRynUKMS"},{"type":"code","lang":"python","value":"# 注文フロー: 在庫予約 → 決済 → 配送手配\n# いずれかが失敗したら、それ以前の成功済みステップを補償する\n\ndef place_order_saga(order):\n    reserve_inventory(order)          # Step 1\n    try:\n        charge_payment(order)         # Step 2\n    except PaymentFailed:\n        release_inventory(order)      # Step 1 の補償\n        raise\n\n    try:\n        arrange_shipping(order)       # Step 3\n    except ShippingFailed:\n        refund_payment(order)         # Step 2 の補償\n        release_inventory(order)      # Step 1 の補償\n        raise","position":{"start":{"line":7,"column":1},"end":{"line":25,"column":1}},"key":"E1e95hcwvC"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"補償トランザクションは「なかったことにする」処理であり、真の意味でのロールバックではない（例：一度送った確認メールを\n取り消すことはできず、代わりに「キャンセルのお知らせ」を送るなど）。そのため、各ステップは","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"CgfY6b1CSL"},{"type":"strong","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"べき等","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"AIGII0Y5bO"}],"key":"w6I2aEtn58"},{"type":"text","value":"かつ\n","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"H7FWb8EdaP"},{"type":"strong","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"補償可能","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"GoG2RSYh5s"}],"key":"AXhfLT0RCR"},{"type":"text","value":"であるように設計する必要がある。","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"VoobmcinxX"}],"key":"J3lEzbxWHv"}],"key":"AvzEkiIoPD"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"オーケストレーション型 vs コレオグラフィ型","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kGPvcpBpSC"}],"identifier":"id-vs","label":"オーケストレーション型 vs コレオグラフィ型","html_id":"id-vs","implicit":true,"key":"dvkkbHfDeD"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"オーケストレーション型（Orchestration）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JNP9apNwdv"}],"key":"PKG9SMIT7V"},{"type":"text","value":"：中心となるオーケストレーターが各サービスに指示を出し、\nSagaの進行を一元管理する。フローが追いやすい反面、オーケストレーターが複雑化しやすい。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KGCyBzMSib"}],"key":"VhLC2hJrsY"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"コレオグラフィ型（Choreography）","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"cibvkvhtN4"}],"key":"ScI6S1SNOI"},{"type":"text","value":"：中心の管理者を置かず、各サービスが","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"ZFUQTFGnkS"},{"type":"link","url":"/software-engineering/software-architecture/distributed/event-driven","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"イベント駆動アーキテクチャ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"FfveWDQAfp"}],"urlSource":"event_driven.ipynb","dataUrl":"/software-engineering.software-architecture.distributed.event-driven.json","internal":true,"protocol":"file","key":"p4WcRNbt9c"},{"type":"text","value":"\nでイベントを発行・購読し合いながら、自律的に次のステップへ連鎖させる。サービス間の結合は弱いが、\n全体のフローが複数サービスのイベントハンドラに分散し、追跡が難しくなりやすい。","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"ZO7Kq2wvXE"}],"key":"wC0aIGphBF"},{"type":"code","lang":"python","value":"# コレオグラフィ型の例: 各サービスが前段のイベントを購読して自律的に動く\nclass InventoryService:\n    def on_order_created(self, event):\n        self.reserve(event.order_id)\n        publish(\"InventoryReserved\", order_id=event.order_id)\n\nclass PaymentService:\n    def on_inventory_reserved(self, event):\n        self.charge(event.order_id)\n        publish(\"PaymentCompleted\", order_id=event.order_id)","position":{"start":{"line":10,"column":1},"end":{"line":21,"column":1}},"key":"skIHlGsX8R"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"サービス数が少ないうちはコレオグラフィ型がシンプルだが、ステップ数が増えるとフローの全体像が見えにくくなるため、\nオーケストレーション型に移行することも多い。","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"aCTN00mf5p"}],"key":"P2e7YPxhOi"}],"key":"LGHvyTwixB"}],"key":"duV2l0GVRQ"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"CQRS (Command Query Responsibility Segregation)","url":"/software-engineering/software-architecture/distributed/cqrs","group":"ソフトウェア工学"},"next":{"title":"API Gateway・BFF","url":"/software-engineering/software-architecture/distributed/api-gateway-bff","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}