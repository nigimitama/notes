dentifier":"protodash","label":"ProtoDash","html_id":"protodash-1","implicit":true,"key":"rg2G86he8H"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"inlineCode","value":"ProtodashExplainer","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"M0g0vkBDe2"},{"type":"text","value":" で実行できる","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"hrlIa9sWvj"}],"key":"mK9kJOiyjH"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"link","url":"https://aix360.readthedocs.io/en/latest/die.html#protodash-explainer","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Directly Interpretable Unsupervised Explainers — aix360 0.1 documentation","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"AJMjs6HXFs"}],"urlSource":"https://aix360.readthedocs.io/en/latest/die.html#protodash-explainer","key":"tmOLJxcGbi"}],"key":"ME68jkJsdj"},{"type":"code","lang":"python","value":"# 1. データの用意\n# https://scikit-learn.org/stable/datasets/real_world.html#california-housing-dataset\n# 1レコード = 地区ブロック\n# y: 10万ドル単位の、地区ブロックの住宅価格の中央値\nfrom sklearn.datasets import fetch_california_housing\nX, y = fetch_california_housing(as_frame=True, return_X_y=True)\nX.assign(y = y)\n\nfrom sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y)\n\n# 2. 予測モデルの学習\nfrom sklearn.ensemble import RandomForestRegressor\nmodel = RandomForestRegressor(max_depth=2, random_state=0)\nmodel.fit(X_train, y_train)\n\nfrom sklearn.metrics import mean_absolute_percentage_error\ny_pred = model.predict(X_test)\nprint(f\"MAPE={mean_absolute_percentage_error(y_test, y_pred):.1%}\")\n\n# 3. 説明\nfrom aix360.algorithms.protodash import ProtodashExplainer\ne = ProtodashExplainer()\ne.explain(\n    X=X_train, # X (double 2d array) – Dataset you want to explain.\n    Y=X_test, # Y (double 2d array) – Dataset to select prototypical explanations from.\n    m=3, # m (int) – Number of prototypes\n    kernelType=\"other\", # kernelType (str) – Type of kernel (viz. ‘Gaussian’, / ‘other’)\n)","position":{"start":{"line":8,"column":1},"end":{"line":38,"column":1}},"key":"xDn2zlu7eW"}],"key":"klLUxSfyLW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tyZIU6mN6y"}],"identifier":"id","label":"参考","html_id":"id-4","implicit":true,"key":"YWNInjzn1W"},{"type":"heading","depth":3,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"サーベイ・チュートリアル","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"uM7yYWTxEK"}],"identifier":"id","label":"サーベイ・チュートリアル","html_id":"id-5","implicit":true,"key":"s2feUY248F"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://speakerdeck.com/yuyay/jsai2023-tiyutoriaru-jie-shi-ke-neng-naji-jie-xue-xi-shuo-ming-haren-notameka","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"JSAI2023 チュートリアル「解釈可能な機械学習 〜説明は人のためか〜」 - Speaker Deck","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"FWRZcLmBzm"}],"urlSource":"https://speakerdeck.com/yuyay/jsai2023-tiyutoriaru-jie-shi-ke-neng-naji-jie-xue-xi-shuo-ming-haren-notameka","key":"FQuStzDg3f"}],"key":"OdM6DKbI1i"}],"key":"aMbcnLIXlN"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"