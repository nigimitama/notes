:"break","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"oucyDOASLT"},{"type":"text","value":"意義: 予測時に「どの訓練事例を参照したか」が構造として残るため、検索拡張モデルが持つ解釈性・頑健性などの有用な特性を備える。","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Ak0Y5NIEPi"}],"key":"RCVE4IoXZC"}],"key":"Zq8UmTE71O"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":4,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ProtoAttend","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XE6BkM5qkd"}],"identifier":"protoattend","label":"ProtoAttend","html_id":"protoattend","implicit":true,"key":"WnEqFNFRr3"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"link","url":"https://www.jmlr.org/papers/v21/20-042.html","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"ProtoAttend: Attention-Based Prototypical Learning","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"V2Y7hBI8cp"}],"urlSource":"https://www.jmlr.org/papers/v21/20-042.html","key":"ZNvs9KFC14"}],"key":"iOCdlSR8CZ"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"手法: 事前学習済みを含む広範なアーキテクチャに統合可能で、符号化表現とサンプルを関連付けるアテンション機構でプロトタイプ（少数の関連事例）を決定。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"aok2xRINII"},{"type":"break","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Ta5yRGDp5e"},{"type":"text","value":"結果: 元モデルの精度を犠牲にせず、(1)決定に最も関連するサンプルを出力するサンプルベース解釈、(2)最先端の信頼度推定、(3)分布ミスマッチ検出で最先端を達成。","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"A1rWbNiIsb"},{"type":"break","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"m9QSLws8NI"},{"type":"text","value":"意義: 最小の追加テスト時間・実用的な訓