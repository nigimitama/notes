dentifier":"protodash","label":"ProtoDash","html_id":"protodash-1","implicit":true,"key":"nbj2mj6CIr"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"inlineCode","value":"ProtodashExplainer","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lSoBXOx00T"},{"type":"text","value":" で実行できる","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pXSLPwp2xP"}],"key":"E1OYrRg77l"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"link","url":"https://aix360.readthedocs.io/en/latest/die.html#protodash-explainer","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Directly Interpretable Unsupervised Explainers — aix360 0.1 documentation","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Oxy4jdnyIy"}],"urlSource":"https://aix360.readthedocs.io/en/latest/die.html#protodash-explainer","key":"geDumTRGTt"}],"key":"gOE7RsEW3c"},{"type":"code","lang":"python","value":"# 1. データの用意\n# https://scikit-learn.org/stable/datasets/real_world.html#california-housing-dataset\n# 1レコード = 地区ブロック\n# y: 10万ドル単位の、地区ブロックの住宅価格の中央値\nfrom sklearn.datasets import fetch_california_housing\nX, y = fetch_california_housing(as_frame=True, return_X_y=True)\nX.assign(y = y)\n\nfrom sklearn.model_selection import train_test_split\nX_train, X_test, y_train, y_test = train_test_split(X, y)\n\n# 2. 予測モデルの学習\nfrom sklearn.ensemble import RandomForestRegressor\nmodel = RandomForestRegressor(max_depth=2, random_state=0)\nmodel.fit(X_train, y_train)\n\nfrom sklearn.metrics import mean_absolute_percentage_error\ny_pred = model.predict(X_test)\nprint(f\"MAPE={mean_absolute_percentage_error(y_test, y_pred):.1%}\")\n\n# 3. 説明\nfrom aix360.algorithms.protodash import ProtodashExplainer\ne = ProtodashExplainer()\ne.explain(\n    X=X_train, # X (double 2d array) – Dataset you want to explain.\n    Y=X_test, # Y (double 2d array) – Dataset to select prototypical explanations from.\n    m=3, # m (int) – Number of prototypes\n    kernelType=\"other\", # kernelType (str) – Type of kernel (viz. ‘Gaussian’, / ‘other’)\n)","position":{"start":{"line":8,"column":1},"end":{"line":38,"column":1}},"key":"jXwDkN9pDP"}],"key":"aiIUyawLq6"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"参考","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LpE4FfI3nG"}],"identifier":"id","label":"参考","html_id":"id-4","implicit":true,"key":"vDZeq8tnb6"},{"type":"heading","depth":3,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"サーベイ・チュートリアル","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NhjdembRzM"}],"identifier":"id","label":"サーベイ・チュートリアル","html_id":"id-5","implicit":true,"key":"P6HgUD5PeN"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://speakerdeck.com/yuyay/jsai2023-tiyutoriaru-jie-shi-ke-neng-naji-jie-xue-xi-shuo-ming-haren-notameka","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"JSAI2023 チュートリアル「解釈可能な機械学習 〜説明は人のためか〜」 - Speaker Deck","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"WzMGI8P1K0"}],"urlSource":"https://speakerdeck.com/yuyay/jsai2023-tiyutoriaru-jie-shi-ke-neng-naji-jie-xue-xi-shuo-ming-haren-notameka","key":"e12lJaf64D"}],"key":"KLa661BjXo"}],"key":"m2ST3QaZVD"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"