ult.extend(right[j:])\n    return result","key":"ghuY1FixHi"},{"type":"outputs","id":"QveqMQTctiyyo5T5EsCvA","children":[],"key":"F5zM5QpPyp"}],"key":"hTrC0ZgE6Q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"data = [38, 27, 43, 3, 9, 82, 10]\nprint(\"入力:\", data)\nprint(\"出力:\", merge_sort(data))","key":"BfakO0UYbS"},{"type":"outputs","id":"tsN3jbPuu2UzLMBQDsJxJ","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"入力: [38, 27, 43, 3, 9, 82, 10]\n出力: [3, 9, 10, 27, 38, 43, 82]\n"},"children":[],"key":"UWKJdL8QGd"}],"key":"RqgKtr4Yik"}],"key":"mp07eskTgN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import random\nrandom.seed(2)\nlarge = random.sample(range(10000), 100)\nassert merge_sort(large) == sorted(large)\nprint(\"ランダム100件: OK\")","key":"oVXgCddyei"},{"type":"outputs","id":"icuhiPNl116fmh2V8HSNF","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"ランダム100件: OK\n"},"children":[],"key":"OvFTwhizjB"}],"key":"l3j7Hqx0A0"}],"key":"toFwehfdOq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"in-place マージソート（Bottom-up）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"S76kOXRXKw"}],"identifier":"in-place-bottom-up","label":"in-place マージソート（Bottom-up）","html_id":"in-place-bottom-up","implicit":true,"key":"yh4i2MVVAq"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"再帰を使わず、マージ幅を 1 → 2 → 4 → ... と倍増させながらボトムアップで処理する。補助配列は使うが再帰スタックが不要。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"g7CDLFL0Of"}],"key":"MS5Rl1osfP"}],"key":"Hd1umVTivI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def merge_sort_bottomup(arr: list) -> list:\n    a = arr.copy()\n    n = len(a)\n    width = 1\n    while width < n:\n        for lo in range(0, n, 2 * width):\n            mid = min(lo + width, n)\n            hi = min(lo + 2 * width, n)\n            merged = _merge(a[lo:mid], a[mid:hi])\n            a[lo:hi] = merged\n        width *= 2\n    return a\n\ndata = [38, 27, 43, 3, 9, 82, 10]\nprint(merge_sort_bottomup(data))\nassert merge_sort_bottomup(data) == sorted(data)","key":"AVllo716s9"},{"type":"outputs","id":"IDRvxX-o4UWDz0QnpYJF8","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[3, 9, 10, 27, 38, 43, 82]\n"},"children":[],"key":"RNxWL5vsDK"}],"key":"gd51aRzqw8"}],"key":"fpFEt08fCc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：転倒数の計算","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bsmf5H1jIb"}],"identifier":"id","label":"応用：転倒数の計算","html_id":"id-1","implicit":true,"key":"u03mDgknym"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"転倒数（inversion count）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wpbXNMH0Ok"}],"key":"ubZ2lmU2M7"},{"type":"text","value":" とは配列の中で ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"iA8VToVBSg"},{"type":"inlineMath","value":"i < j","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>i</mi><mo>&lt;</mo><mi>j</mi></mrow><annotation encoding=\"application/x-tex\">i &lt; j</annota