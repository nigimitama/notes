ult.extend(right[j:])\n    return result","key":"MxBx8Mhir7"},{"type":"outputs","id":"cBSWk1RNbmfbUxFLfEYfr","children":[],"key":"dqVE4oOCHF"}],"key":"oCmbZT0LZJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"data = [38, 27, 43, 3, 9, 82, 10]\nprint(\"入力:\", data)\nprint(\"出力:\", merge_sort(data))","key":"u7TI8POWy7"},{"type":"outputs","id":"q2LC5y8XzZWQEqxOS6GMw","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"入力: [38, 27, 43, 3, 9, 82, 10]\n出力: [3, 9, 10, 27, 38, 43, 82]\n"},"children":[],"key":"UtiQN9hpRe"}],"key":"Xkn5cfjtx9"}],"key":"CVqx5ZnzYf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import random\nrandom.seed(2)\nlarge = random.sample(range(10000), 100)\nassert merge_sort(large) == sorted(large)\nprint(\"ランダム100件: OK\")","key":"PPMlPLCKLy"},{"type":"outputs","id":"pihTOJObK-hM-twNTUNm4","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"ランダム100件: OK\n"},"children":[],"key":"A8F0OgB9vh"}],"key":"v3TFovPz1t"}],"key":"b6y9VCIO2J"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"in-place マージソート（Bottom-up）","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vLU8DIDpar"}],"identifier":"in-place-bottom-up","label":"in-place マージソート（Bottom-up）","html_id":"in-place-bottom-up","implicit":true,"key":"w2ocuRrTiE"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"再帰を使わず、マージ幅を 1 → 2 → 4 → ... と倍増させながらボトムアップで処理する。補助配列は使うが再帰スタックが不要。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"thrijhWhdH"}],"key":"Hs8ecwKvVu"}],"key":"dvqJur22GR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def merge_sort_bottomup(arr: list) -> list:\n    a = arr.copy()\n    n = len(a)\n    width = 1\n    while width < n:\n        for lo in range(0, n, 2 * width):\n            mid = min(lo + width, n)\n            hi = min(lo + 2 * width, n)\n            merged = _merge(a[lo:mid], a[mid:hi])\n            a[lo:hi] = merged\n        width *= 2\n    return a\n\ndata = [38, 27, 43, 3, 9, 82, 10]\nprint(merge_sort_bottomup(data))\nassert merge_sort_bottomup(data) == sorted(data)","key":"A4avzZtaoz"},{"type":"outputs","id":"GByEtvPjtmw3pgVrSH_OW","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[3, 9, 10, 27, 38, 43, 82]\n"},"children":[],"key":"l40whSghxm"}],"key":"jfCFVzsNZP"}],"key":"W8JSjmZPdm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"応用：転倒数の計算","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"w3iJe0dVx4"}],"identifier":"id","label":"応用：転倒数の計算","html_id":"id-1","implicit":true,"key":"G8RHOa2jsO"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"転倒数（inversion count）","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"HAQs3E88TF"}],"key":"fKsdhvVfyo"},{"type":"text","value":" とは配列の中で ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gL1hmRwceT"},{"type":"inlineMath","value":"i < j","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>i</mi><mo>&lt;</mo><mi>j</mi></mrow><annotation encoding=\"application/x-tex\">i &lt; j</annota