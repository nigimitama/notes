n":1}},"key":"ZIurN7do5e"}],"key":"MqJMQquSGG"},{"type":"code","lang":"python","value":"# OCP準拠例\nfrom abc import ABC, abstractmethod\n\nclass Logger(ABC):\n    @abstractmethod\n    def log(self, message): pass\n\nclass ConsoleLogger(Logger):\n    def log(self, message):\n        print(message)\n\nclass FileLogger(Logger):\n    def log(self, message):\n        with open(\"log.txt\", \"a\") as f:\n            f.write(message + \"\\n\")\n\nclass SlackLogger(Logger):\n    def log(self, message):\n        send_to_slack(message)\n\n# 使用例\ndef run_process(logger: Logger):\n    logger.log(\"処理を開始します\")","position":{"start":{"line":34,"column":1},"end":{"line":58,"column":1}},"key":"LaTIlcRQi6"}],"key":"YGy0Eqmf8R"}],"key":"FLPwRkj2Pb"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"LSP: Liskov Substitution Principle","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tbehDt8Ywv"}],"identifier":"lsp-liskov-substitution-principle","label":"LSP: Liskov Substitution Principle","html_id":"lsp-liskov-substitution-principle","implicit":true,"key":"fMv4Yic6C0"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"リスコフの置換原則。「サブタイプは、そのスーパータイプと置き換えても、プログラムの正しさを壊してはならない」というもの。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Y4RFLjlYGI"}],"key":"EfctNh1PMb"},{"type":"details","children":[{"type":"summary","children":[{"type":"text","value":"例","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"L24xmq9cT9"}],"key":"wqtzvpe4xV"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"inlineCode","value":"Rectangle","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Wq0OBQ52or"},{"type":"text","value":" を継承した ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"hWW39RnYfc"},{"type":"inlineCode","value":"Square","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"q8mjqmyyH6"},{"type":"text","value":" が、親クラスの契約（幅と高さを独立に設定できる）を壊す典型例。","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"N2hKDUsDst"}],"key":"mgiJiPvWdw"},{"type":"code","lang":"python","value":"class Rectangle:\n    def __init__(self, width, height):\n        self.width = width\n        self.height = height\n\n    def set_width(self, w):\n        self.width = w\n\n    def set_height(self, h):\n        self.height = h\n\n    def area(self):\n        return self.width * self.height\n\n# LSP違反：Squareは幅と高さを独立に変更できないので、親の契約を壊す\nclass Square(Rectangle):\n    def set_width(self, w):\n        self.width = self.height = w\n\n    def set_height(self, h):\n        self.width = self.height = h\n\ndef resize_and_check(rect: Rectangle):\n    rect.set_width(5)\n    rect.set_height(4)\n    assert rect.area() == 20  # Squareを渡すと 16 になり失敗する","position":{"start":{"line":9,"column":1},"end":{"line":36,"column":1}},"key":"zCyzF9NSdC"}],"key":"n5DXnJ4kvi"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"「見た目は自然な継承関係（正方形は長方形の一種）」でも、","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"sQGLlfuuPA"},{"type":"strong","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"振る舞いの契約","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"CWibkSHWSt"}],"key":"nmADhmY5gP"},{"type":"text","value":"が壊れるなら継承すべきではない、という判断基準を与える。\n違反を見つけたら継承をやめて委譲やコンポジションに置き換えることが多い。","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"TNQyOnxwEP"}],"key":"oNh8h9rCVb"}],"key":"ZrN9VT6L9L"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ISP: Interface Segregation Principle","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XkYBB8WVfd"}],"identifier":"isp-interface-segregation-principle","label":"ISP: Interface Segregation Principle","html_id":"isp-interface-segregation-principle","implicit":true,"key":"raTnEJf91g"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"インターフェース分離の原則。「クライアントは、自分が使わないメソッドへの依存を強制されるべきではない」というもの。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"XgxqGigraz"}],"key":"PPBldaFQ0z"},{"type":"details","children":[{"type":"summary","children":[{"type":"text","value":"例","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"GUA2veOtHB"}],"key":"GDZ2qtTRz9"},{"type":"code","lang":"python","value":"from abc import ABC, abstractmethod\n\n# ISP違反：どんなワーカーにもscan()を実装させてしまう\nclass Worker(ABC):\n    @abstractmethod\n    def work(self): ...\n    @abstractmethod\n    def eat(self): ...\n    @abstractmethod\n    def scan(self): ...  # ロボットワーカーには不要\n\n# ISP準拠：役割ごとにインターフェースを分ける\nclass Workable(ABC):\n    @abstractmethod\n    def work(self): ...\n\nclass Eatable(ABC):\n    @abstractmethod\n    def eat(self): ...\n\nclass Scannable(ABC):\n    @abstractmethod\n    def scan(self): ...\n\nclass HumanWorker(Workable, Eatable):\n    def work(self): print(\"working\")\n    def eat(self): print(\"eating\")\n\nclass RobotWorker(Workable, Scannable):\n    def work(self): print(\"working\")\n    def scan(self): print(\"scanning\")","position":{"start":{"line":7,"column":1},"end":{"line":39,"column":1}},"key":"zBabWtK2kk"}],"key":"oAYbAbnwkw"},{"type":"paragraph","position":{"start":{"line":43,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"肥大化した「何でもインターフェース」を作ると、実装クラスが不要なメソッドのダミー実装を持つ羽目になる。\n用途ごとに小さなインターフェースへ分割することで、無関係な変更の影響を受けにくくなる。","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"T4k2xhcKP3"}],"key":"x0WUED3XVr"}],"key":"Bxyj6xTi3g"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"DIP: Dependency Inversion Principle","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cKDnXxKXa3"}],"identifier":"dip-dependency-inversion-principle","label":"DIP: Dependency Inversion Principle","html_id":"dip-dependency-inversion-principle","implicit":true,"key":"slCtoAGAcH"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"依存性逆転の原則。「上位モジュールは下位モジュールに依存すべきではなく、両者とも抽象に依存すべき」というもの。\n「抽象は詳細に依存してはならず、詳細が抽象に依存すべき」とも表現される。","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"DqmqK47uAT"}],"key":"u1hyyjTlIM"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":6,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"通常の依存の向き：上位（業務ロジック）→下位（DBアクセスなどの実装詳細）","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"qQ6KggYS7L"}],"key":"m3sWegeyuQ"}],"key":"ZDei1IlZxH"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"DIPを適用した依存の向き：上位・下位の両方が、間に挟んだ抽象（インターフェース）に依存する","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"du0OY57Qgj"}],"key":"CM4b2rWVnO"}],"key":"m7Swa1LI5E"}],"key":"bOrHwritet"},{"type":"details","children":[{"type":"summary","children":[{"type":"text","value":"例","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"pUPfR8ATOG"}],"key":"ByqrCEIj4a"},{"type":"code","lang":"python","value":"from abc import ABC, abstractmethod\n\n# 抽象（上位・下位の両方がここに依存する）\nclass NotificationSender(ABC):\n    @abstractmethod\n    def send(self, message: str): ...\n\n# 下位モジュール：抽象を実装する（＝抽象に依存する側に回る）\nclass EmailSender(NotificationSender):\n    def send(self, message: str):\n        print(f\"Email: {message}\")\n\n# 上位モジュール：具体的な実装ではなく抽象に依存する\nclass OrderService:\n    def __init__(self, sender: NotificationSender):\n        self.sender = sender\n\n    def complete_order(self):\n        self.sender.send(\"注文が完了しました\")\n\nservice = OrderService(EmailSender())\nservice.complete_order()","position":{"start":{"line":11,"column":1},"end":{"line":34,"column":1}},"key":"EFH35PXhBg"}],"key":"wT5zJvNxGg"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"DIPは ","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"UfMitUhq8P"},{"type":"link","url":"/software-engineering/design/design-patterns/dependency-injection","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"依存性注入（DI）","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"vsqMMFjisb"}],"urlSource":"../design_patterns/dependency_injection.ipynb","dataUrl":"/software-engineering.design.design-patterns.dependency-injection.json","internal":true,"protocol":"file","key":"ZxaFrzUwiM"},{"type":"text","value":" という実装テクニックによって実現されることが多い。\nDIPが「あるべき依存の向き」という設計原則で、DIはそれを実現する手段、という関係になる。\nまた、","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"KC8tgxpHqw"},{"type":"link","url":"/software-engineering/software-architecture/application/clean-architecture","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"クリーンアーキテクチャ","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"nDNNnOrn4c"}],"urlSource":"../../software_architecture/application/clean_architecture.ipynb","dataUrl":"/software-engineering.software-architecture.application.clean-architecture.json","internal":true,"protocol":"file","key":"QsC8naU3IG"},{"type":"text","value":" の「依存関係のルール」もDIPの応用。","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"JNsmlArSQA"}],"key":"wdjBcrpk78"}],"key":"m3bnW6Bzgz"}],"key":"wePleDgPye"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"結合度と凝集度（Coupling and Cohesion）","url":"/software-engineering/design/principles/coupling-and-cohesion","group":"ソフトウェア工学"},"next":{"title":"基本原則（KISS・YAGNI・DRYほか）","url":"/software-engineering/design/principles/basic-principles","group":"ソフトウェア工学"}}},"domain":"http://localhost:3000"}