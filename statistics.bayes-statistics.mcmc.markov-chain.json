":1,"column":1}},"key":"zyM84L3eJs"},{"type":"inlineMath","value":"\\pi","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>π</mi></mrow><annotation encoding=\"application/x-tex\">\\pi</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span></span></span></span>","key":"VAKEy3BNmw"},{"type":"text","value":"は","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vAe5cjUtum"}],"key":"slBS0SNqW1"},{"type":"math","value":"\\pi=\\pi P, \\quad \\sum_i \\pi_i=1","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"html":"<span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" display=\"block\"><semantics><mrow><mi>π</mi><mo>=</mo><mi>π</mi><mi>P</mi><mo separator=\"true\">,</mo><mspace width=\"1em\"/><munder><mo>∑</mo><mi>i</mi></munder><msub><mi>π</mi><mi>i</mi></msub><mo>=</mo><mn>1</mn></mrow><annotation encoding=\"application/x-tex\">\\pi=\\pi P, \\quad \\sum_i \\pi_i=1</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:2.3277em;vertical-align:-1.2777em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span><span class=\"mord mathnormal\" style=\"margin-right:0.13889em;\">P</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:1em;\"></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mop op-limits\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:1.05em;\"><span style=\"top:-1.8723em;margin-left:0em;\"><span class=\"pstrut\" style=\"height:3.05em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span><span style=\"top:-3.05em;\"><span class=\"pstrut\" style=\"height:3.05em;\"></span><span><span class=\"mop op-symbol large-op\">∑</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:1.2777em;\"><span></span></span></span></span></span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.3117em;\"><span style=\"top:-2.55em;margin-left:-0.0359em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.15em;\"><span></span></span></span></span></span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">1</span></span></span></span></span>","enumerator":"3","key":"W6KVR8gztk"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"を満たすベクトル。固有ベクトルで求めることもできる。","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"PPilzBSXgw"}],"key":"uQWzCpDBAe"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"（ベイズ推定の場合、定常分布じゃなくサンプルがほしいのと、状態が離散じゃなく連続であり遷移確率行列が明示的に求まらないのでこの方法は使わない）","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"mzOnF9iyq7"}],"key":"RLRwr3AdFF"}],"key":"wAS76ryP4X"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# -------------------------\n# 定常分布を求める（固有ベクトル法）\n# -------------------------\nw, v = np.linalg.eig(P.T)  # P^T の固有分解\nidx = np.argmin(np.abs(w - 1.0))  # 固有値1に最も近いもの\npi = np.real(v[:, idx])\npi = pi / pi.sum()  # 正規化\npi = np.maximum(pi, 0)  # 数値誤差で微小負になるのを対策\npi = pi / pi.sum()\n\nprint(\"stationary pi:\", dict(zip(states, pi.round(6))))","visibility":"show","key":"wJoY43Cmwl"},{"type":"outputs","id":"kpr3SAHp_ncF7byAJ9cLD","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"stationary pi: {'A': 0.268293, 'B': 0.47561, 'C': 0.256098}\n"},"children":[],"key":"FVJxnQ6gvM"}],"visibility":"show","key":"z7HALjNk8B"}],"visibility":"show","key":"lltRcwhXkx"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# -------------------------\n# 状態列サンプリング（経験分布）\n# -------------------------\nrng = np.random.default_rng(0)\n\ndef simulate_chain(P, start_state, T):\n    x = start_state\n    xs = [x]\n    for _ in range(T):\n        x = rng.choice(len(states), p=P[x])\n        xs.append(x)\n    return np.array(xs)\n\nT = 200000\nxs = simulate_chain(P, start_state=0, T=T)  # 0 = \"A\"\ncounts = np.bincount(xs, minlength=len(states))\nemp = counts / counts.sum()\n\nprint(\"empirical:\", dict(zip(states, emp.round(6))))\nprint(\"stationary:\", dict(zip(states, pi.round(6))))\n","visibility":"show","key":"lI4rXnxcgY"},{"type":"outputs","id":"4hGK7jnQSmST6MPVXYncn","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"empirical: {'A': 0.269089, 'B': 0.475783, 'C': 0.255129}\nstationary: {'A': 0.268293, 'B': 0.47561, 'C': 0.256098}\n"},"children":[],"key":"vTwaJXpQF2"}],"visibility":"show","key":"lZQU7JdVvv"}],"visibility":"show","key":"YnuddlC2lj"}],"key":"iJpHFeWpYp"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"ハミルトニアンモンテカルロ（HMC）法","url":"/statistics/bayes-statistics/mcmc/hamiltonian-monte-carlo","group":"統計学"},"next":{"title":"サンプリングの妥当性検証","url":"/statistics/bayes-statistics/mcmc/validation","group":"統計学"}}},"domain":"http://localhost:3000"}